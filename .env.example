# ============================================================
#  ZENIC-AGENTS v16 — Environment Variables (Phase 2: Scalability)
#
#  Copy this file to .env and customize for your environment:
#    cp .env.example .env
#
#  Never commit .env to version control — it may contain secrets.
# ============================================================

# ── Application Environment ─────────────────────────────────
# Determines which database backend and features to use.
#   development  → SQLite (default, no external services needed)
#   production   → PostgreSQL + Redis (requires docker compose up)
ZENIC_ENV=development

# ── Database ────────────────────────────────────────────────
# PostgreSQL connection string (only used when ZENIC_ENV=production).
# Supports SQLAlchemy-style DSN — the +asyncpg driver is auto-stripped
# by PostgreSQLDatabase._convert_dsn() for asyncpg compatibility.
#
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# Default matches docker-compose.yml: zenic/zenic@localhost:5432/zenic_db
DATABASE_URL=postgresql+asyncpg://zenic:zenic@localhost:5432/zenic_db

# ── Cache ───────────────────────────────────────────────────
# Cache provider selection.
#   memory    → In-process LRU cache (default, no external services)
#   redis     → Redis cache (requires docker compose up)
CACHE_PROVIDER=memory

# Redis connection URL (only used when CACHE_PROVIDER=redis).
#
# Format: redis://<host>:<port>/<db_number>
# Default matches docker-compose.yml: localhost:6379/db0
CACHE_URL=redis://localhost:6379/0

# ── Redis (standalone) ─────────────────────────────────────
# General Redis URL for session storage, rate limiting, etc.
# Can be the same as CACHE_URL or point to a different Redis instance.
REDIS_URL=redis://localhost:6379/0

# ── Vector Store (Phase 4.1) ───────────────────────────────
# Enable/disable vector search operations.
#   true     → Enable vector store (default)
#   false    → Disable vector operations
VECTOR_ENABLED=true

# Embedding dimensions for the vector store.
# Must match the model output (384 for fastembed/all-MiniLM-L6-v2).
VECTOR_DIMENSIONS=384

# HNSW index parameters for PostgreSQL pgvector.
# M: Graph connectivity (higher = better recall, more memory)
# ef_construction: Index build quality (higher = slower build, better recall)
# ef_search: Query-time search quality (higher = slower query, better recall)
VECTOR_HNSW_M=16
VECTOR_HNSW_EF_CONSTRUCTION=64
VECTOR_EF_SEARCH=40

# Vector store table name in PostgreSQL.
VECTOR_TABLE_NAME=zenic_vectors

# ── Docker Compose Quick Start ─────────────────────────────
# 1. Start infrastructure services:
#      docker compose up -d
#
# 2. Switch to production mode:
#      ZENIC_ENV=production
#      DATABASE_URL=postgresql+asyncpg://zenic:zenic@localhost:5432/zenic_db
#      CACHE_PROVIDER=redis
#      CACHE_URL=redis://localhost:6379/0
#      REDIS_URL=redis://localhost:6379/0
#
# 3. Run the agent or tests:
#      python -m src.entrypoints.main
#      pytest tests/test_postgresql_e2e.py -v
#      pytest tests/test_redis_integration.py -v
