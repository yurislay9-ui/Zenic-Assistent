# ============================================================
#  ZENIC-AGENTS v3 - Environment Configuration Template
#  Standalone Assistant Agent (no external API connections)
# ============================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo como .env en la raiz del proyecto:
#    cp .env.example .env
# 2. Rellena los valores necesarios
# 3. NUNCA subas .env a GitHub (ya esta en .gitignore)
#
# Compatible con: Termux + proot-distro (Debian ARM) / Local / VPS
# ============================================================

# ── DATA DIRECTORY ─────────────────────────────────────────
# Directorio de datos del sistema (SQLite, cache, etc.)
# En Termux: /data/data/com.termux/files/home/.zenic_agents
ZENIC_DATA_DIR=

# ── MODEL MANAGER ─────────────────────────────────────────
# Presupuesto de RAM en MB para modelos AI (Qwen ~400MB + SemanticEngine ~150MB)
# Default: 4096
ZENIC_RAM_BUDGET_MB=4096

# Segundos de inactividad antes de auto-descargar un modelo (default: 3600)
ZENIC_MODEL_IDLE_TIMEOUT=3600

# Carga perezosa: modelos se cargan solo al primer uso (default: 1=on)
ZENIC_LAZY_LOAD=1

# Auto-descarga: descargar modelos inactivos para liberar RAM (default: 0=off)
ZENIC_AUTO_UNLOAD=0

# Precarga de modelos: cargar modelos al inicio (default: 1=on)
ZENIC_PRELOAD_MODELS=1

# ── ONNXRUNTIME FIX (proot-distro) ────────────────────────
# Deshabilitar GPU discovery (falla en proot-distro)
ORT_DISABLE_GPU=1
OMP_NUM_THREADS=4
ONNXRUNTIME_NUM_THREADS=4
CUDA_VISIBLE_DEVICES=

# ── REQUEST TIMEOUT ───────────────────────────────────────
# Timeout en segundos para operaciones del engine (default: 120)
ZENIC_REQUEST_TIMEOUT=120
