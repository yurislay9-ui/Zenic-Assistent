# ============================================================
#  ZENIC OMNISCALE X v16 - Environment Configuration Template
#  Scraper Inteligente + GitHub Metrics
# ============================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo como .env en la raiz del proyecto:
#    cp .env.example .env
# 2. Rellena los valores con tus credenciales
# 3. NUNCA subas .env a GitHub (ya esta en .gitignore)
#
# Compatible con: Termux + proot-distro (Debian ARM) / Redmi 12R Pro
# ============================================================

# ── GITHUB API ──────────────────────────────────────────────
# Tu Personal Access Token de GitHub (PAT)
# Genera uno en: https://github.com/settings/tokens
# Permisos necesarios: public_repo, read:user
# Sin token: 60 requests/hora | Con token: 5000 requests/hora
GITHUB_TOKEN=tu_github_personal_access_token_aqui

# GitHub API Key alternativa (misma que GITHUB_TOKEN, para compatibilidad)
GITHUB_API_KEY=

# ── GITHUB METRICS ─────────────────────────────────────────
# Habilitar recopilacion de metricas de GitHub
GITHUB_METRICS_ENABLED=true

# Metricas a recolectar (comma-separated)
# Opciones: rate_limit, search_results, repo_stats
GITHUB_METRICS_COLLECT=rate_limit,search_results,repo_stats

# Intervalo de refresco de metricas en segundos (0 = solo on-demand)
GITHUB_METRICS_REFRESH_INTERVAL=300

# ── DEVDOCS (Logica y Sintaxis - 0 registro) ───────────────
# DevDocs provee documentacion de APIs y lenguajes
# URL base: https://devdocs.io/
# No requiere API key ni registro
DEVDOCS_BASE_URL=https://devdocs.io

# Lenguajes disponibles por defecto para consultas
DEVDOCS_DEFAULT_LANGUAGES=python,kotlin,javascript,typescript,html,css

# ── ICONSTACK (Iconos - 0 registro) ────────────────────────
# IconStack provee iconos para UIs generadas
# URL base: https://icon-icons.com/api/
# No requiere API key ni registro
ICONSTACK_BASE_URL=https://icon-icons.com

# Iconos por defecto para apps generadas
ICONSTACK_DEFAULT_STYLE=material

# ── PICSUM PHOTOS (Imagenes de Frontend - 0 registro) ─────
# Picsum.photos genera imagenes aleatorias profesionales
# URL base: https://picsum.photos
# 100% gratuito, sin API key, sin registro
# Ejemplo: https://picsum.photos/800/600
PICSUM_BASE_URL=https://picsum.photos

# Resolucion por defecto para prototipos de frontend
PICSUM_DEFAULT_WIDTH=800
PICSUM_DEFAULT_HEIGHT=600

# ── SCRAPER INTELIGENTE ────────────────────────────────────
# Timeout global para todas las fuentes de scraping (segundos)
SCRAPER_TIMEOUT=10

# Maximo de reintentos por fuente
SCRAPER_MAX_RETRIES=2

# Maximo de caracteres a retornar por fuente
SCRAPER_MAX_CHARS=2000

# Fuente preferida: github | devdocs | iconstack | picsum | auto
# "auto" = el scraper decide segun el tipo de consulta
SCRAPER_PREFERRED_SOURCE=auto

# ── ZENIC AUTH ─────────────────────────────────────────────
# Clave secreta para JWT (cambiar en produccion)
ZENIC_AUTH_SECRET=CHANGE_ME_GENERATE_A_SECURE_SECRET

# ── DATA DIRECTORY ─────────────────────────────────────────
# Directorio de datos del sistema (SQLite, cache, etc.)
# En Termux: /data/data/com.termux/files/home/.zenic_omniscale
ZENIC_DATA_DIR=

# ── REQUEST TIMEOUT ───────────────────────────────────────
# Timeout en segundos para requests del servidor HTTP (default: 120)
# El orchestrator pipeline puede tardar si necesita recargar modelos
# Aumentar si ves TimeoutError (primer request despues de idle puede tardar)
# NOTA: 600s es demasiado largo — Cline timeout es ~30-60s, asi que un
# timeout largo solo hace que el servidor parezca colgado
ZENIC_REQUEST_TIMEOUT=120

# ── MODEL MANAGER ─────────────────────────────────────────
# Presupuesto de RAM en MB para modelos AI (Qwen ~400MB + SemanticEngine ~150MB)
# Default: 4096 (coincide con el limite del ResourceGovernor)
# IMPORTANTE: Si este valor es menor que la RAM actual usada (~1654MB),
# el auto-unload descargara modelos agresivamente, causando que
# el servidor se quede sin modelo despues de cada request.
ZENIC_RAM_BUDGET_MB=4096

# Segundos de inactividad antes de auto-descargar un modelo (default: 3600)
# 3600 = 1 hora. Cline envia requests frecuentes, asi que 300s (5 min)
# es demasiado corto y causa cargas/descargas constantes.
ZENIC_MODEL_IDLE_TIMEOUT=3600

# Carga perezosa: modelos se cargan solo al primer request (default: 1=on)
ZENIC_LAZY_LOAD=1

# Auto-descarga: descargar modelos inactivos para liberar RAM (default: 0=off)
# IMPORTANTE: Poner a 0 para Cline. Si auto-unload=1, los modelos se
# descargan tras idle_timeout y el siguiente request tarda mucho en cargar
# o falla con timeout, causando que "se apague el motor".
ZENIC_AUTO_UNLOAD=0

# Precarga de modelos: cargar modelos al inicio en vez de al primer request (default: 1=on)
# Evita TimeoutError en el primer request despues de iniciar el servidor
# Poner a 0 para usar lazy-load (cargar solo al primer request)
ZENIC_PRELOAD_MODELS=1

# ── ONNXRUNTIME FIX (proot-distro) ────────────────────────
# Deshabilitar GPU discovery (falla en proot-distro)
ORT_DISABLE_GPU=1
OMP_NUM_THREADS=4
ONNXRUNTIME_NUM_THREADS=4
CUDA_VISIBLE_DEVICES=

# ── BIND IP (DATOS MOVILES / TERMUX) ─────────────────────
# IP local para mostrar en el banner y que Cline se conecte.
# En WiFi: se detecta automaticamente (no necesitas configurar esto)
# En DATOS MOVILES: Termux no puede detectar la IP automaticamente,
#   asi que necesitas configurarlo manualmente.
#
# COMO OBTENER TU IP:
#   1. Abre otra terminal en Termux
#   2. Ejecuta: ip addr show | grep 'inet '
#   3. Busca la IP de la interfaz rmnet0 o ccmni0 (datos moviles)
#   4. Pon esa IP aqui
#
# Si Cline esta en el MISMO telefono, usa 127.0.0.1 (no necesitas esto)
# Si Cline esta en OTRO dispositivo via hotspot, pon la IP del hotspot
#
# Dejar vacio = deteccion automatica (puede fallar en datos moviles)
# Ejemplo para datos moviles: ZENIC_BIND_IP=10.0.2.15
# Ejemplo para hotspot: ZENIC_BIND_IP=192.168.43.1
ZENIC_BIND_IP=

# ── RATE LIMITER ──────────────────────────────────────────
# Max requests por minuto por IP (default: auto basado en RAM)
# Aumentar si usas herramientas como Cline que mandan muchos requests
ZENIC_RATE_LIMIT_RPM=

# Max burst de requests por IP (default: 20)
ZENIC_RATE_LIMIT_BURST=20

# Max requests concurrentes globales (default: 60)
# IMPORTANTE: Cline envia multiples requests rapidos, 20 es muy bajo
# Si ves errores 429, aumenta este valor
ZENIC_RATE_LIMIT_CONCURRENT=60

# ── CLINE BYPASS FIX ─────────────────────────────────────
# IMPORTANT: When using Cline as the AI client, set ALL THREE to 1.
# These disable the shortcut paths that return empty/incomplete responses.
#
# Problem: Cline messages get caught by 3 bypass paths:
#   1. SmartMemory cache → returns truncated (500-char) cached response
#   2. Chat detect → misclassifies Cline messages as "simple chat"
#   3. Visual bypass → UI keywords trigger empty response generation
#
# Solution: Set these env vars to disable the shortcuts:
ZENIC_NO_CACHE=1
ZENIC_NO_CHAT_DETECT=1
ZENIC_NO_VISUAL_BYPASS=1
