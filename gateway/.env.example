# ─── Zenic-Agents v3.0 — Variables de Entorno ──────────────────────
# Copiar a .env y rellenar los valores.
# cp .env.example .env
# ⚠️ OBLIGATORIO: Ejecutar scripts/generate-env.sh para generar valores seguros.

# ─── Base de Datos (OBLIGATORIO) ──────────────────────────────────
# SQLite para desarrollo local. Para producción, migrar a PostgreSQL.
DATABASE_URL="file:./dev.db"

# ─── Autenticación (OBLIGATORIO en producción) ────────────────────
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET=""  # Generar con: openssl rand -base64 32

# ─── API Keys del Gateway (OBLIGATORIO en producción) ─────────────
# En desarrollo se generan keys efímeras automáticamente.
# En producción DEBEN configurarse (mínimo 32 caracteres cada una).
# Generar con: openssl rand -hex 32
ZENIC_ADMIN_KEY=""
ZENIC_DEMO_KEY=""

# ─── Wallet TRC20 de la plataforma (para pagos USDT) ─────────────
# Requerido para rutas de suscripción. Nombre exacto usado en código:
USDT_TRC20_COMPANY_WALLET="T..."

# ─── Playbook Certification (OBLIGATORIO en producción) ───────────
# Clave para firmar blueprints certificados con HMAC-SHA256.
# Mínimo 32 caracteres. Generar con: openssl rand -hex 32
PLAYBOOK_CERT_SECRET=""

# ─── License Signing Key (OBLIGATORIO si ECDSA no disponible) ─────
# Clave HMAC para firmar licencias cuando cryptography lib no está instalada.
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
ZENIC_SIGNING_KEY=""

# ─── Database Encryption (OBLIGATORIO para SQLCipher) ─────────────
# Passphrase para cifrado AES-256 de bases de datos SQLCipher.
# Mínimo 32 caracteres. Generar con: python -c "import secrets; print(secrets.token_hex(32))"
ZENIC_DB_PASSPHRASE=""

# ─── Entorno ──────────────────────────────────────────────────────
NODE_ENV="development"

# ─── Development Mode (SECURITY) ─────────────────────────────────
# ⚠️ SECURITY: Only for local development. NEVER enable in production.
# When set to "1" + NODE_ENV=development, allows auth bypass with
# viewer role for RBAC endpoints and owner role for tenant endpoints.
# Without this, RBAC and tenant endpoints are LOCKED (fail-closed).
# This is intentional — security must not be optional by default.
ZENIC_DEV_MODE="1"

# ─── Tenant Authentication (OBLIGATORIO en producción) ───────────
# Shared secret for tenant auth via x-tenant-token header.
# If not set, tenant endpoints are LOCKED (fail-closed, INVARIANT 4).
# Generar con: openssl rand -hex 32
ZENIC_TENANT_SECRET=""

# ─── Cifrado de Credenciales (OBLIGATORIO) ────────────────────────
# Clave AES-256-GCM para cifrar credenciales de servicios externos.
# ⚠️ OBLIGATORIO — la app FALLARÁ si está vacío.
# Generar con: openssl rand -hex 32
# NUNCA commitear este valor al repositorio.
ZENIC_ENCRYPTION_KEY=""
