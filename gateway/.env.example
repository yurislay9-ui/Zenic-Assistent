# ─── Zenic-Agents v3.0 — Variables de Entorno ──────────────────────
# Copiar a .env y rellenar los valores.
# cp .env.example .env

# ─── Base de Datos (OBLIGATORIO) ──────────────────────────────────
# SQLite para desarrollo local. Para producción, migrar a PostgreSQL.
DATABASE_URL="file:./dev.db"

# ─── Autenticación (FUTURO — NO ACTIVO) ───────────────────────────
# NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET="generar-con-openssl-rand-base64-32"

# ─── Wallet TRC20 de la plataforma (para pagos USDT) ─────────────
# PLATFORM_WALLET_TRC20="T..."

# ─── Entorno ──────────────────────────────────────────────────────
NODE_ENV="development"

# ─── Cifrado de Credenciales (OBLIGATORIO) ────────────────────────
# Clave AES-256 para cifrar credenciales de servicios externos.
# Generar con: openssl rand -hex 32
# NUNCA commitear este valor al repositorio.
ZENIC_ENCRYPTION_KEY=""
