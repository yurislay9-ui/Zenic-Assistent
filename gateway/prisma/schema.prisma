// Zenic-Agents v3 — MCP Gateway with RBAC & Audit
// Phase 1: Complete data model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users & Identity ──────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatar    String?
  status    String   @default("active") // active | suspended | deactivated
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roles     UserRole[]
  auditLogs AuditLog[]
  toolExecs ToolExecution[]

  @@map("users")
}

// ─── RBAC: Roles & Permissions ─────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  description String
  color       String   @default("#6b7280") // UI badge color
  isSystem    Boolean  @default(false)      // system roles cannot be deleted
  priority    Int      @default(0)          // higher = more permissions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "tool:execute", "audit:read", "policy:write"
  resource    String                          // e.g. "tool", "audit", "policy", "role", "server"
  action      String                          // e.g. "read", "write", "execute", "delete", "admin"
  displayName String
  description String
  isDangerous Boolean  @default(false)        // requires extra approval
  createdAt   DateTime @default(now())

  roles RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  grantedBy String?                // userId who granted
  expiresAt DateTime?              // optional expiry
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id         String   @id @default(cuid())
  roleId     String
  permissionId String
  constraints String? @default("{}") // JSON: { "tools": ["weather_*"], "maxCalls": 100 }
  createdAt  DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─── MCP Tools Registry ────────────────────────────────────────────

model McpTool {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "weather_lookup", "db_query", "file_read"
  displayName String
  description String
  category    String                          // e.g. "data", "communication", "compute", "storage", "external"
  version     String   @default("1.0.0")
  icon        String?                         // lucide icon name
  endpoint    String                          // URL or internal path
  method      String   @default("POST")       // HTTP method
  inputSchema String                          // JSON Schema for input validation
  outputSchema String?                        // JSON Schema for output validation
  timeout     Int      @default(30000)        // ms
  retries     Int      @default(2)
  rateLimit   Int      @default(100)          // calls per minute
  riskLevel   String   @default("low")        // low | medium | high | critical
  status      String   @default("active")     // active | deprecated | disabled | testing
  requiresApproval Boolean @default(false)    // needs human-in-the-loop
  tags        String   @default("[]")         // JSON array of tags
  metadata    String   @default("{}")         // JSON: extra config
  serverId    String?                          // linked MCP server
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  server      McpServer?  @relation(fields: [serverId], references: [id], onDelete: SetNull)
  executions  ToolExecution[]
  accessPolicies ToolAccessPolicy[]

  @@index([category])
  @@index([riskLevel])
  @@index([status])
  @@index([serverId])
  @@map("mcp_tools")
}

model McpServer {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  description   String
  url           String
  protocol      String   @default("http") // http | websocket | grpc | stdio
  status        String   @default("active") // active | unhealthy | offline | maintenance
  healthCheckUrl String?
  lastPing      DateTime?
  lastError     String?
  authType      String   @default("none") // none | api_key | oauth2 | mtls
  authConfig    String   @default("{}")   // JSON (encrypted at app layer)
  capabilities  String   @default("[]")   // JSON array
  metadata      String   @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tools McpTool[]

  @@index([status])
  @@map("mcp_servers")
}

// ─── Gateway Execution & Audit ──────────────────────────────────────

model ToolExecution {
  id           String   @id @default(cuid())
  toolId       String
  executorId   String?                        // userId or service account
  status       String   @default("pending")   // pending | approved | running | completed | failed | denied | timeout
  input        String                          // JSON input payload
  output       String?                         // JSON output payload
  errorMessage String?
  duration     Int?                            // ms
  verdict      String?                         // allow | deny | conditional
  verdictReason String?                        // why the verdict was given
  retryCount   Int      @default(0)
  parentExecId String?                         // for chained calls
  correlationId String?                        // cross-service tracing
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  tool        McpTool  @relation(fields: [toolId], references: [id], onDelete: Cascade)
  executor    User?    @relation(fields: [executorId], references: [id], onDelete: SetNull)
  auditLogId  String?  @unique
  auditLog    AuditLog?  @relation(fields: [auditLogId], references: [id], onDelete: SetNull)

  @@index([toolId])
  @@index([executorId])
  @@index([status])
  @@index([verdict])
  @@index([createdAt])
  @@map("tool_executions")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?                        // userId or "system"
  actorType    String   @default("user")      // user | system | service | agent
  action       String                          // e.g. "tool.execute", "role.assign", "policy.update"
  resource     String                          // e.g. "tool", "role", "policy"
  resourceId   String?                         // specific resource id
  resourceName String?                         // human-readable name
  severity     String   @default("info")      // debug | info | warn | error | critical
  outcome      String   @default("success")   // success | failure | denied | error
  details      String   @default("{}")        // JSON: before/after state, diff
  ipAddress    String?
  userAgent    String?
  sessionId    String?
  traceId      String?                         // distributed tracing
  tags         String   @default("[]")        // JSON array for filtering
  createdAt    DateTime @default(now())

  actor        User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  execution    ToolExecution? // reverse side of one-to-one

  @@index([actorId])
  @@index([action])
  @@index([resource])
  @@index([severity])
  @@index([outcome])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Access Policies & Rules ───────────────────────────────────────

model AccessPolicy {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  type        String   @default("allow")     // allow | deny | conditional | quota
  priority    Int      @default(0)           // higher = evaluated first
  isEnabled   Boolean  @default(true)
  conditions  String   @default("[]")        // JSON: array of condition objects
  effect      String   @default("allow")     // allow | deny | require_approval
  timeWindow  String?                         // JSON: { "start": "09:00", "end": "17:00", "tz": "UTC" }
  quota       String?                         // JSON: { "maxCalls": 100, "window": "1h" }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  toolAccessPolicies ToolAccessPolicy[]

  @@index([isEnabled])
  @@index([priority])
  @@map("access_policies")
}

model ToolAccessPolicy {
  id         String   @id @default(cuid())
  toolId     String
  policyId   String
  createdAt  DateTime @default(now())

  tool       McpTool      @relation(fields: [toolId], references: [id], onDelete: Cascade)
  policy     AccessPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([toolId, policyId])
  @@map("tool_access_policies")
}

// ─── Dashboard Metrics (materialized) ──────────────────────────────

model MetricSnapshot {
  id         String   @id @default(cuid())
  metricKey  String                          // e.g. "tools.total", "executions.today", "audit.critical_24h"
  metricValue Float
  dimensions String   @default("{}")        // JSON: { "category": "data", "riskLevel": "high" }
  capturedAt DateTime @default(now())

  @@unique([metricKey, dimensions])
  @@map("metric_snapshots")
}

// ─── Observability: Distributed Tracing (Phase 2) ──────────────────

model Trace {
  id          String   @id @default(cuid())
  traceId     String   @unique               // Distributed trace ID (W3C format)
  sessionId   String?                         // Business session ID
  decisionId  String?                         // Verdict decision correlation ID
  tenantId    String?                         // Tenant isolation
  rootSpanId  String?                         // First span in the trace
  status      String   @default("ok")        // ok | error | timeout | partial
  verdict     String?                         // allow | deny | conditional — final verdict
  duration    Int?                            // Total trace duration in ms
  spanCount   Int      @default(0)           // Number of spans in this trace
  serviceName String   @default("zenic-gateway")
  attributes  String   @default("{}")        // JSON: arbitrary key-value attributes
  createdAt   DateTime @default(now())
  completedAt DateTime?

  spans       Span[]

  @@index([traceId])
  @@index([sessionId])
  @@index([decisionId])
  @@index([tenantId])
  @@index([status])
  @@index([verdict])
  @@index([createdAt])
  @@map("traces")
}

model Span {
  id           String   @id @default(cuid())
  spanId       String   @unique               // W3C span ID
  traceId      String                         // FK to Trace.traceId
  parentSpanId String?                         // Parent span for nesting
  name         String                         // e.g. "gateway.tool_resolution", "gateway.auth_check"
  kind         String   @default("internal")  // internal | server | client | producer | consumer
  status       String   @default("ok")        // ok | error | timeout
  statusMessage String?                        // Error message if status=error
  startTime    DateTime                       // Span start timestamp
  endTime      DateTime?                      // Span end timestamp
  duration     Int?                           // Duration in ms
  service      String   @default("zenic-gateway")
  resource     String?                        // e.g. "tool", "policy", "role"
  resourceId   String?                        // e.g. tool name or ID
  action       String?                        // e.g. "execute", "check", "resolve"
  outcome      String?                        // success | failure | denied | error
  attributes   String   @default("{}")        // JSON: span-specific key-value attributes
  events       String   @default("[]")        // JSON: array of { name, timestamp, attributes }
  links        String   @default("[]")        // JSON: array of { traceId, spanId, attributes }
  createdAt    DateTime @default(now())

  trace        Trace    @relation(fields: [traceId], references: [traceId], onDelete: Cascade)

  @@index([spanId])
  @@index([traceId])
  @@index([parentSpanId])
  @@index([name])
  @@index([status])
  @@index([startTime])
  @@map("spans")
}

// ─── Observability: Metric Time Series (Phase 2) ───────────────────

model MetricSeries {
  id          String   @id @default(cuid())
  name        String   @unique               // e.g. "gateway.deny_rate", "business.cost_per_flow"
  description String
  category    String                          // business | security | resilience | operational
  unit        String   @default("count")      // count | ms | percent | usd | ratio
  labels      String   @default("{}")        // JSON: default labels for all points
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  points      MetricPoint[]

  @@index([category])
  @@map("metric_series")
}

model MetricPoint {
  id         String   @id @default(cuid())
  seriesId   String                         // FK to MetricSeries
  value      Float                           // The metric value
  labels     String   @default("{}")        // JSON: point-specific labels { "tool": "db_query", "risk": "high" }
  timestamp  DateTime                        // Observation time
  createdAt  DateTime @default(now())

  series     MetricSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@index([seriesId])
  @@index([timestamp])
  @@index([seriesId, timestamp])
  @@map("metric_points")
}

// ─── Policy Engine: Declarative Policies (Phase 3) ──────────────────

model DeclPolicy {
  id              String   @id @default(cuid())
  policyId        String   @unique               // Unique policy identifier (from YAML metadata.id)
  name            String                          // Human-readable name
  description     String                          // What the policy controls
  apiVersion      String   @default("policy.zenic.dev/v1")
  version         String   @default("1.0.0")     // Current active semantic version
  labels          String   @default("{}")        // JSON: category, criticality, etc.
  compliance      String   @default("[]")        // JSON: array of ComplianceMapping
  statements      String                          // JSON: array of PolicyStatement
  tests           String   @default("[]")        // JSON: array of PolicyTestCase
  isActive        Boolean  @default(true)         // Whether this policy is active
  sourceYaml      String?                         // Original YAML source (for round-trip)
  contentHash     String                          // SHA-256 of canonical JSON
  author          String?                         // Policy author
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  versions        DeclPolicyVersion[]

  @@index([policyId])
  @@index([isActive])
  @@index([contentHash])
  @@map("decl_policies")
}

model DeclPolicyVersion {
  id                String   @id @default(cuid())
  declPolicyId      String                         // FK to DeclPolicy
  version           String                         // Semantic version string
  contentHash       String                         // SHA-256 of document JSON at this version
  document          String                         // JSON: full PolicyDocument snapshot
  status            String   @default("active")   // draft | active | superseded | archived
  createdBy         String   @default("system")    // Who created this version
  changeDescription String   @default("")          // Commit message
  parentVersionId   String?                        // Previous version ID (for history chain)
  createdAt         DateTime @default(now())

  policy            DeclPolicy @relation(fields: [declPolicyId], references: [id], onDelete: Cascade)

  @@unique([declPolicyId, version])
  @@index([declPolicyId])
  @@index([status])
  @@index([contentHash])
  @@map("decl_policy_versions")
}

model DeclPolicyTestResult {
  id              String   @id @default(cuid())
  policyId        String                         // DeclPolicy.policyId
  version         String                         // Version tested
  totalTests      Int      @default(0)
  passed          Int      @default(0)
  failed          Int      @default(0)
  errors          Int      @default(0)
  suitePassed     Boolean  @default(false)
  results         String   @default("[]")        // JSON: array of PolicyTestResult
  duration        Int      @default(0)           // ms
  triggeredBy     String   @default("manual")    // manual | hot_reload | ci
  createdAt       DateTime @default(now())

  @@index([policyId])
  @@index([version])
  @@index([createdAt])
  @@map("decl_policy_test_results")
}

// ─── Playbooks: Industry Playbooks with ROI (Phase 4) ──────────────

model Playbook {
  id                    String    @id @default(cuid())
  playbookId            String    @unique               // From YAML metadata.id, e.g. "healthtech-clinic"
  name                  String                          // Human-readable name
  nameEn                String?                         // English name
  industry              String                          // e.g. "healthtech", "fintech", "edtech"
  subIndustry           String?                         // e.g. "clinic", "microfinance", "k12"
  apiVersion            String    @default("playbook.zenic.dev/v1")
  version               String    @default("1.0.0")    // Semantic version
  description           String
  icon                  String?                         // Emoji
  color                 String?                         // Hex color
  labels                String    @default("{}")        // JSON
  compliance            String    @default("[]")        // JSON array of standard names
  capabilities          String                          // JSON array of PlaybookCapability
  policies              String    @default("[]")        // JSON array of PolicyReference with policyId links to DeclPolicy
  roiConfig             String    @default("{}")        // JSON: PlaybookRoiConfig
  pricing               String    @default("{}")        // JSON: PlaybookPricing
  onboarding            String    @default("{}")        // JSON: PlaybookOnboardingConfig
  certificationStatus   String    @default("unsigned")  // unsigned | pending | certified | revoked
  certificationSignedBy String?
  certificationSignedAt DateTime?
  certificationSignature String?
  certificationHash     String?
  sourceYaml            String?                         // Original YAML source
  contentHash           String                          // SHA-256
  isActive              Boolean   @default(true)
  author                String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  versions              PlaybookVersion[]
  activations           PlaybookActivation[]
  metricsSnapshots      PlaybookMetricsSnapshot[]
  onboardingSessions    PlaybookOnboardingSession[]

  @@index([playbookId])
  @@index([industry])
  @@index([isActive])
  @@index([certificationStatus])
  @@index([contentHash])
  @@map("playbooks")
}

model PlaybookVersion {
  id                String   @id @default(cuid())
  playbookDbId      String                         // FK to Playbook.id
  version           String                         // Semantic version string
  contentHash       String                         // SHA-256 of document JSON at this version
  document          String                         // JSON: full PlaybookDocument snapshot
  status            String   @default("active")    // draft | active | superseded | archived
  createdBy         String   @default("system")     // Who created this version
  changeDescription String   @default("")           // Commit message
  parentVersionId   String?                         // Previous version ID (for history chain)
  createdAt         DateTime @default(now())

  playbook          Playbook  @relation(fields: [playbookDbId], references: [id], onDelete: Cascade)

  @@unique([playbookDbId, version])
  @@index([playbookDbId])
  @@index([status])
  @@index([contentHash])
  @@map("playbook_versions")
}

model PlaybookActivation {
  id               String    @id @default(cuid())
  playbookDbId     String                          // FK to Playbook.id
  tenantId         String
  selectedTier     String                          // starter | business | enterprise | on_premise_enterprise
  customConfig     String    @default("{}")        // JSON
  activatedPolicies String   @default("[]")        // JSON: array of policyId strings
  configuredTools  String    @default("[]")        // JSON
  roiProjection    String    @default("{}")        // JSON: RoiCalculation snapshot
  status           String    @default("active")    // active | suspended | deactivated
  activatedBy      String?
  activatedAt      DateTime  @default(now())
  deactivatedAt    DateTime?

  playbook         Playbook  @relation(fields: [playbookDbId], references: [id], onDelete: Cascade)

  @@index([playbookDbId])
  @@index([tenantId])
  @@index([status])
  @@map("playbook_activations")
}

model PlaybookMetricsSnapshot {
  id            String   @id @default(cuid())
  playbookDbId  String                         // FK to Playbook.id
  tenantId      String?
  operational   String   @default("{}")        // JSON: PlaybookOperationalMetrics
  roi           String   @default("{}")        // JSON: RoiCalculation
  uptimePct     Float    @default(99.9)
  capturedAt    DateTime @default(now())

  playbook      Playbook  @relation(fields: [playbookDbId], references: [id], onDelete: Cascade)

  @@index([playbookDbId])
  @@index([capturedAt])
  @@map("playbook_metrics_snapshots")
}

model PlaybookOnboardingSession {
  id             String    @id @default(cuid())
  playbookDbId   String                          // FK to Playbook.id
  tenantId       String?
  sessionId      String    @unique
  status         String    @default("in_progress") // in_progress | completed | abandoned
  currentStep    Int       @default(0)
  answers        String    @default("{}")          // JSON: field → answer
  configSnapshot String    @default("{}")          // JSON: resolved config
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?

  playbook       Playbook  @relation(fields: [playbookDbId], references: [id], onDelete: Cascade)

  @@index([playbookDbId])
  @@index([sessionId])
  @@index([status])
  @@map("playbook_onboarding_sessions")
}

// ─── Phase 4: Advanced Policy Engine ────────────────────────────────────

// Policy Sets — Composition of multiple policies
model PolicySet {
  id                  String   @id @default(cuid())
  setId               String   @unique               // From metadata.id
  name                String                          // Human-readable name
  description         String
  apiVersion          String   @default("policyset.zenic.dev/v1")
  version             String   @default("1.0.0")
  namespace           String?                         // Namespace this set belongs to
  labels              String   @default("{}")        // JSON
  policies            String                          // JSON: array of PolicySetEntry
  defaultMergeStrategy String  @default("priority_merge") // union | intersection | override | extend | priority_merge
  denyStopsEvaluation Boolean  @default(true)
  isActive            Boolean  @default(true)
  contentHash         String                          // SHA-256
  author              String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([setId])
  @@index([namespace])
  @@index([isActive])
  @@map("policy_sets")
}

// Policy Conflicts — Detected cross-policy conflicts
model PolicyConflictRecord {
  id              String   @id @default(cuid())
  conflictId      String   @unique               // Generated conflict ID
  type            String                          // effect_contradiction | priority_collision | condition_overlap | redundant_rule | shadow_rule | scope_conflict
  severity        String                          // critical | high | medium | low | info
  policyIdA       String                          // First policy's policyId
  versionA        String?                         // First policy version
  statementIdA    String                          // First statement ID
  effectA         String                          // First statement effect
  resourceA       String                          // First statement resource
  actionA         String                          // First statement action
  policyIdB       String                          // Second policy's policyId
  versionB        String?
  statementIdB    String
  effectB         String
  resourceB       String
  actionB         String
  description     String                          // Human-readable description
  suggestedResolution String                       // deny_wins | priority_wins | merge_conditions | first_match | manual
  resolved        Boolean  @default(false)
  resolutionStrategy String?                       // Strategy used to resolve
  resolvedBy      String?
  resolutionNote  String?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([severity])
  @@index([resolved])
  @@index([policyIdA])
  @@index([policyIdB])
  @@index([createdAt])
  @@map("policy_conflict_records")
}

// Policy Approval Requests — Draft → Review → Approve → Deploy
model PolicyApproval {
  id                  String   @id @default(cuid())
  approvalId          String   @unique               // Generated approval ID
  title               String                          // Request title
  description         String                          // Description of proposed change
  status              String   @default("draft")     // draft | pending_review | approved | rejected | cancelled | expired | deployed | rolled_back
  priority            String   @default("medium")    // low | medium | high | critical | emergency
  targetPolicyId      String?                         // Target policy (for modifications)
  previousVersion     String?                         // Previous version for rollback
  proposedDocument    String                          // JSON: PolicyDocument
  simulationId        String?                         // Linked simulation result
  requestedBy         String                          // Who requested
  requiredApprovals   Int      @default(1)
  currentApprovals    Int      @default(0)
  approvals           String   @default("[]")        // JSON: array of ApprovalDecision
  requiredReviewerRoles String @default("[]")        // JSON: array of role names
  autoApproveRules    String   @default("[]")        // JSON: array of AutoApproveRule
  autoApproved        Boolean  @default(false)
  expiresAt           DateTime?
  deployedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([approvalId])
  @@index([status])
  @@index([targetPolicyId])
  @@index([requestedBy])
  @@index([priority])
  @@index([createdAt])
  @@map("policy_approvals")
}

// Policy Templates — Parameterized policy templates
model PolicyTemplate {
  id                String   @id @default(cuid())
  templateId        String   @unique               // Unique template identifier
  name              String                          // Template name
  version           String   @default("1.0.0")
  description       String
  category          String                          // compliance | security | industry
  industry          String?                         // Target industry
  tags              String   @default("[]")         // JSON array
  parameters        String                          // JSON: array of TemplateParameter
  documentTemplate  String                          // JSON: PolicyDocumentTemplate
  defaults          String   @default("{}")         // JSON: default parameter values
  constraints       String   @default("[]")         // JSON: array of TemplateConstraint
  generatedCount    Int      @default(0)            // Number of policies generated
  isActive          Boolean  @default(true)
  author            String?
  sourceYaml        String?                         // Original YAML source
  contentHash       String                          // SHA-256
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([templateId])
  @@index([category])
  @@index([industry])
  @@index([isActive])
  @@map("policy_templates")
}

// Policy Namespaces — Multi-tenant policy scoping
model PolicyNamespace {
  id                  String   @id @default(cuid())
  namespaceId         String   @unique               // Unique namespace identifier
  name                String                          // Human-readable name
  description         String
  tenantId            String                          // Tenant this namespace belongs to
  parentNamespaceId   String?                         // Parent namespace ID (for hierarchy)
  path                String                          // e.g., "root/tenant-abc/department-finance"
  labels              String   @default("{}")        // JSON
  inheritFromParent   Boolean  @default(true)
  maxInheritanceDepth Int      @default(5)
  parentChildResolution String @default("deny_wins") // deny_wins | priority_wins | merge_conditions
  childCanOverrideParentDeny Boolean @default(false)
  childCanAddAllow    Boolean  @default(true)
  resolutionStrategy  String   @default("local_first") // local_first | priority_based | deny_wins | most_restrictive
  isolationLevel      String   @default("inherited")   // strict | selective | inherited | shared
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([namespaceId])
  @@index([tenantId])
  @@index([parentNamespaceId])
  @@index([path])
  @@index([isActive])
  @@map("policy_namespaces")
}

// Policy Simulations — What-if analysis results
model PolicySimulation {
  id                String   @id @default(cuid())
  simulationId      String   @unique               // Generated simulation ID
  name              String                          // Simulation name
  description       String
  proposedChanges   String                          // JSON: array of SimulationChange
  testRequests      String                          // JSON: array of PolicyEvaluationRequest
  verdictChanges    String   @default("[]")         // JSON: array of VerdictChange
  newConflicts      String   @default("[]")         // JSON: array of PolicyConflict
  resolvedConflicts String   @default("[]")         // JSON
  impactScore       Int      @default(0)            // 0-100
  riskLevel         String   @default("low")        // low | medium | high | critical
  riskFactors       String   @default("[]")         // JSON
  complianceImpact  String   @default("{}")         // JSON
  totalRequests     Int      @default(0)
  unchangedCount    Int      @default(0)
  newDenialsCount   Int      @default(0)
  newAllowancesCount Int     @default(0)
  requestedBy       String
  includeTrace      Boolean  @default(false)
  trace             String   @default("[]")         // JSON: array of SimulationTrace
  summary           String                          // Human-readable summary
  createdAt         DateTime @default(now())

  @@index([simulationId])
  @@index([requestedBy])
  @@index([riskLevel])
  @@index([createdAt])
  @@map("policy_simulations")
}

// Policy Impact Analysis — Dependency and blast radius tracking
model PolicyImpactAnalysis {
  id                    String   @id @default(cuid())
  analysisId            String   @unique             // Generated analysis ID
  policyId              String                        // Target policy
  proposedVersion       String?                       // Proposed new version
  analysisDepth         String   @default("standard") // quick | standard | deep
  directDependencies    String   @default("[]")       // JSON: array of DependencyRef
  indirectDependencies  String   @default("[]")       // JSON
  affectedSets          String   @default("[]")       // JSON
  affectedPlaybooks     String   @default("[]")       // JSON
  affectedTools         String   @default("[]")       // JSON
  blastRadius           String   @default("{}")       // JSON: BlastRadius
  downstreamChanges     String   @default("[]")       // JSON
  requestedBy           String
  summary               String
  createdAt             DateTime @default(now())

  @@index([analysisId])
  @@index([policyId])
  @@index([createdAt])
  @@map("policy_impact_analyses")
}

// Policy Verification Results — Constraint solver outputs
model PolicyVerification {
  id                String   @id @default(cuid())
  verificationId    String   @unique               // Generated verification ID
  policyIds         String                          // JSON: array of policy IDs verified
  consistent        Boolean                         // No contradictions
  complete          Boolean                         // All requests have matching rules
  hasUnreachableRules Boolean  @default(false)
  status            String                          // pass | fail | warning | error | timeout
  contradictions    String   @default("[]")        // JSON: array of Contradiction
  unreachableRules  String   @default("[]")        // JSON: array of UnreachableRule
  coverage          String   @default("{}")        // JSON: CoverageReport
  solverType        String   @default("ac3_csp")   // z3_sat | ac3_csp | brute_force | hybrid
  duration          Int      @default(0)           // ms
  summary           String
  createdAt         DateTime @default(now())

  @@index([verificationId])
  @@index([status])
  @@index([consistent])
  @@index([createdAt])
  @@map("policy_verifications")
}

// ─── Phase 5: Human-in-the-Loop Models ──────────────────────────────

model HitlApprovalRequest {
  id              String   @id @default(cuid())
  requestId       String   @unique
  title           String
  description     String
  type            String   // action_approval, policy_change, deployment, data_access
  status          String   @default("pending") // pending, approved, rejected, delegated, escalated, expired, undone
  priority        String   @default("medium") // low, medium, high, critical, emergency
  requesterId     String
  requesterName   String
  targetResource  String   // What resource is affected
  targetAction    String   // What action is being requested
  actionPayload   String   @default("{}") // JSON: action parameters
  undoPayload     String   @default("{}") // JSON: compensating action parameters
  isReversible    Boolean  @default(true)
  undoDeadline    DateTime? // When the undo window expires
  undoExecutedAt  DateTime? // When the undo was executed
  executedAt      DateTime? // When the approved action was executed
  executionResult String?  // JSON: result of the executed action
  requiredApprovals Int    @default(1)
  currentApprovals Int     @default(0)
  approvalPolicy  String   @default("{}") // JSON: quorum, unanimous, auto-approve rules
  deadline        DateTime? // When the request expires
  escalationLevel Int      @default(0)
  parentId        String?  // For sub-requests in multi-level chains
  tags            String   @default("[]") // JSON: string[]
  metadata        String   @default("{}") // JSON: additional metadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  decisions       HitlApprovalDecision[]
  delegations     HitlDelegation[]
  escalations     HitlEscalation[]
  undoActions     HitlUndoAction[]
  auditRecords    HitlApprovalAudit[]

  @@index([requesterId])
  @@index([status])
  @@index([priority])
  @@index([deadline])
  @@map("hitl_approval_requests")
}

model HitlApprovalDecision {
  id          String   @id @default(cuid())
  requestId   String
  decision    String   // approved, rejected
  decisionBy  String   // User ID
  decisionByName String
  role        String   // Reviewer's role
  comment     String   @default("")
  delegatedFrom String? // If this decision was made on behalf of someone
  decidedAt   DateTime @default(now())

  request     HitlApprovalRequest @relation(fields: [requestId], references: [requestId], onDelete: Cascade)

  @@index([requestId])
  @@index([decisionBy])
  @@map("hitl_approval_decisions")
}

model HitlDelegation {
  id              String   @id @default(cuid())
  requestId       String
  fromUserId      String
  fromUserName    String
  toUserId        String
  toUserName      String
  reason          String   @default("")
  expiresAt       DateTime?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  request         HitlApprovalRequest @relation(fields: [requestId], references: [requestId], onDelete: Cascade)

  @@index([requestId])
  @@index([fromUserId])
  @@index([toUserId])
  @@map("hitl_delegations")
}

model HitlEscalation {
  id              String   @id @default(cuid())
  requestId       String
  fromLevel       Int
  toLevel         Int
  fromUserId      String?
  toUserId        String?
  toRole          String
  reason          String   @default("")
  autoEscalated   Boolean  @default(false)
  createdAt       DateTime @default(now())

  request         HitlApprovalRequest @relation(fields: [requestId], references: [requestId], onDelete: Cascade)

  @@index([requestId])
  @@map("hitl_escalations")
}

model HitlUndoAction {
  id              String   @id @default(cuid())
  requestId       String
  undoType        String   // full_undo, partial_undo, compensating_action
  undoBy          String
  undoByName      String
  reason          String
  snapshotBefore  String   @default("{}") // JSON: state snapshot before action
  undoPayload     String   @default("{}") // JSON: undo action parameters
  undoResult      String?  // JSON: result of undo execution
  status          String   @default("pending") // pending, executed, failed, skipped
  executedAt      DateTime?
  createdAt       DateTime @default(now())

  request         HitlApprovalRequest @relation(fields: [requestId], references: [requestId], onDelete: Cascade)

  @@index([requestId])
  @@map("hitl_undo_actions")
}

model HitlApprovalAudit {
  id              String   @id @default(cuid())
  requestId       String
  eventType       String   // created, approved, rejected, delegated, escalated, executed, undone, expired, cancelled
  actorId         String
  actorName       String
  details         String   @default("{}") // JSON: event-specific details
  contentHash     String   // SHA-256 for integrity
  previousHash    String?  // Chain link for Merkle audit trail
  timestamp       DateTime @default(now())

  request         HitlApprovalRequest @relation(fields: [requestId], references: [requestId], onDelete: Cascade)

  @@index([requestId])
  @@index([eventType])
  @@index([timestamp])
  @@map("hitl_approval_audit")
}

model HitlDelegationRule {
  id              String   @id @default(cuid())
  fromUserId      String
  toUserId        String
  toUserName      String
  ruleName        String
  description     String   @default("")
  isActive        Boolean  @default(true)
  maxDepth        Int      @default(1)
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([fromUserId])
  @@index([toUserId])
  @@index([isActive])
  @@map("hitl_delegation_rules")
}

// ─── Phase 5: HITL Evidence & Justification ──────────────────────────

model HitlEvidence {
  id              String   @id @default(cuid())
  evidenceId      String   @unique               // Generated evidence ID
  requestId       String                         // FK to HitlApprovalRequest
  evidenceType    String                         // screenshot, log, data_snapshot, policy_result, audit_record, custom
  content         String                         // JSON: evidence content
  contentHash     String                         // SHA-256 for immutability
  source          String                         // Who/what provided the evidence
  description     String   @default("")
  createdAt       DateTime @default(now())

  @@index([requestId])
  @@index([evidenceType])
  @@index([contentHash])
  @@map("hitl_evidence")
}

model HitlJustification {
  id                      String   @id @default(cuid())
  justificationId         String   @unique               // Generated justification ID
  requestId               String                         // FK to HitlApprovalRequest
  decisionId              String?                        // FK to HitlApprovalDecision (if tied to a specific decision)
  reason                  String                         // Mandatory reason (min 20 chars for critical)
  riskAcknowledgment      Boolean  @default(false)       // "I understand the risks"
  complianceCheck         Boolean  @default(false)       // "I verified compliance"
  businessJustification   String   @default("")          // Business justification
  createdBy               String                         // User ID who provided justification
  createdByName           String                         // Display name
  contentHash             String                         // SHA-256 for immutability
  createdAt               DateTime @default(now())

  @@index([requestId])
  @@index([createdBy])
  @@index([contentHash])
  @@map("hitl_justifications")
}

model HitlExpiryRecord {
  id                  String   @id @default(cuid())
  requestId           String   @unique               // FK to HitlApprovalRequest
  expiresAt           DateTime                       // When the request expires
  autoRevertEnabled   Boolean  @default(true)         // Whether to auto-revert on expiry
  revertAction        String   @default("{}")         // JSON: compensating action for auto-revert
  notificationSchedule String  @default("[60,30,10,5]") // JSON: minutes before expiry to notify
  notificationsSent   String   @default("[]")         // JSON: array of { minutesBefore, sentAt }
  status              String   @default("active")     // active, expired, reverted, cancelled
  revertedAt          DateTime?
  revertResult        String?                        // JSON: result of revert execution
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([requestId])
  @@index([status])
  @@index([expiresAt])
  @@map("hitl_expiry_records")
}

model HitlEscalationSLA {
  id              String   @id @default(cuid())
  slaId           String   @unique               // Generated SLA ID
  requestId       String                         // FK to HitlApprovalRequest
  currentLevel    Int      @default(0)           // 0=L0, 1=L1, 2=L2, 3=L3
  targetRole      String                         // Role for this escalation level
  slaDeadline     DateTime                       // When the SLA expires
  breached        Boolean  @default(false)       // Whether the SLA was breached
  autoEscalated   Boolean  @default(false)       // Whether auto-escalation occurred
  escalatedAt     DateTime?                      // When the escalation happened
  escalationReason String  @default("")          // Why escalation happened
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([requestId])
  @@index([breached])
  @@index([slaDeadline])
  @@map("hitl_escalation_slas")
}

model HitlNotificationLog {
  id              String   @id @default(cuid())
  notificationId  String   @unique               // Generated notification ID
  requestId       String                         // FK to HitlApprovalRequest
  recipientId     String                         // User ID
  channel         String                         // in_app, email, slack, teams, whatsapp, sms, push, webhook
  event           String                         // approval_pending, approval_approved, etc.
  title           String
  body            String
  priority        String   @default("normal")    // low, normal, high, urgent
  status          String   @default("pending")   // pending, sent, failed, delivered
  metadata        String   @default("{}")        // JSON: additional metadata
  sentAt          DateTime?
  deliveredAt     DateTime?
  failedAt        DateTime?
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@index([requestId])
  @@index([recipientId])
  @@index([channel])
  @@index([status])
  @@index([event])
  @@map("hitl_notification_logs")
}

// ─── Subscriptions: USDT TRC20 Billing (Phase 6) ──────────────────────

model Subscription {
  id                  String    @id @default(cuid())
  subscriptionId      String    @unique               // e.g. "sub_abc123"
  tenantId            String    @unique               // One subscription per tenant
  tier                String                          // starter | business | enterprise | on_premise_enterprise | trial
  status              String                          // trial | active | past_due | cancelled | expired | suspended | pending_payment
  paymentMethod       String    @default("usdt_trc20") // Always USDT TRC20
  billingWalletAddress String                         // TRC20 wallet address for billing
  addOns              String    @default("[]")        // JSON array of add-on IDs
  startedAt           DateTime
  currentPeriodEnd    DateTime
  trialEndsAt         DateTime?
  trialCompletedAt    DateTime?                         // When trial was completed/converted
  autoRenew           Boolean   @default(true)
  lastPaymentTxHash   String?                         // TRC20 transaction hash
  lastPaymentAmount   Float?                          // USDT amount
  lastPaymentAt       DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  payments            SubscriptionPayment[]
  usageRecords        UsageRecord[]
  featureAccessLogs   FeatureAccessLog[]

  @@index([subscriptionId])
  @@index([tenantId])
  @@index([tier])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model SubscriptionPayment {
  id                    String   @id @default(cuid())
  paymentId             String   @unique               // Generated payment ID
  subscriptionDbId      String                         // FK to Subscription.id
  amountUsdt            Float                          // USDT amount
  walletFrom            String                         // Payer TRC20 address
  walletTo              String                         // Platform TRC20 address
  txHash                String                         // TRC20 transaction hash
  network               String   @default("TRC20")     // Always TRC20
  status                String                         // pending | confirming | confirmed | failed | expired | refunded
  verificationMethod    String   @default("manual_admin")  // manual_admin | semi_manual_onchain
  adminConfirmedBy      String?                            // Admin user ID who confirmed
  adminConfirmedAt      DateTime?                          // When admin confirmed
  adminNotes            String?                            // Admin notes on confirmation
  confirmations         Int      @default(0)
  requiredConfirmations Int      @default(20)          // TRC20 standard
  paidAt                DateTime?
  confirmedAt           DateTime?
  expiresAt             DateTime?
  metadata              String   @default("{}")        // JSON
  createdAt             DateTime @default(now())

  subscription          Subscription @relation(fields: [subscriptionDbId], references: [id], onDelete: Cascade)

  @@index([subscriptionDbId])
  @@index([paymentId])
  @@index([status])
  @@index([txHash])
  @@index([createdAt])
  @@map("subscription_payments")
}

model UsageRecord {
  id                String   @id @default(cuid())
  subscriptionDbId  String                         // FK to Subscription.id
  tenantId          String
  resource          String                         // e.g. "workflows", "actions_per_day", "policies"
  usageCount        Int      @default(0)
  limitValue        Int                            // 0 means unlimited
  periodStart       DateTime
  periodEnd         DateTime
  overageCount      Int      @default(0)
  overageChargeUsdt Float    @default(0.0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscription      Subscription @relation(fields: [subscriptionDbId], references: [id], onDelete: Cascade)

  @@index([subscriptionDbId])
  @@index([tenantId])
  @@index([resource])
  @@index([periodStart, periodEnd])
  @@map("usage_records")
}

// ─── Manual Payment Confirmation (Admin) ────────────────────────────

model ManualPaymentConfirmation {
  id              String   @id @default(cuid())
  paymentId       String   @unique               // Links to SubscriptionPayment.paymentId
  subscriptionId  String                         // Subscription subscriptionId
  tenantId        String
  amountUsdt      Float                          // USDT amount
  txHash          String                         // TRC20 transaction hash
  walletFrom      String                         // Payer TRC20 wallet
  walletTo        String                         // Platform TRC20 wallet
  verifiedByAdmin String                         // Admin user ID who verified
  adminNotes      String?                        // Admin notes
  status          String   @default("confirmed") // confirmed | rejected
  rejectionReason String?                        // Why rejected if rejected
  verifiedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())

  @@index([paymentId])
  @@index([subscriptionId])
  @@index([tenantId])
  @@index([verifiedByAdmin])
  @@map("manual_payment_confirmations")
}

model FeatureAccessLog {
  id                String   @id @default(cuid())
  subscriptionDbId  String                         // FK to Subscription.id
  tenantId          String
  feature           String                         // Feature name from Rust engine
  allowed           Boolean
  denialReason      String?                        // Why access was denied
  resource          String?                        // Associated resource
  userId            String?                        // User who attempted access
  ipAddress         String?                        // Request IP
  createdAt         DateTime @default(now())

  subscription      Subscription @relation(fields: [subscriptionDbId], references: [id], onDelete: Cascade)

  @@index([subscriptionDbId])
  @@index([tenantId])
  @@index([feature])
  @@index([allowed])
  @@index([createdAt])
  @@map("feature_access_logs")
}

// ─── Saga Pattern: Subscription Lifecycle Orchestration ──────────────

model SagaExecution {
  id                  String   @id @default(cuid())
  executionId         String   @unique               // e.g. "saga_trial_creation_abc123"
  sagaType            String                          // trial_creation | trial_conversion | payment_verification | cancellation | renewal | upgrade | downgrade | reactivation
  status              String   @default("pending")    // pending | running | completed | compensating | compensated | failed | timed_out | paused
  tenantId            String
  subscriptionId      String?                         // Linked subscription ID
  currentStepIndex    Int      @default(0)
  totalSteps          Int      @default(0)
  completedSteps      Int      @default(0)
  errorMessage        String?
  compensationReason  String?
  metadata            String   @default("{}")         // JSON: arbitrary metadata
  paymentCurrency     String   @default("USDT")
  paymentNetwork      String   @default("TRC20")
  startedAt           DateTime @default(now())
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  steps               SagaStepRecord[]

  @@index([executionId])
  @@index([sagaType])
  @@index([tenantId])
  @@index([status])
  @@index([subscriptionId])
  @@index([startedAt])
  @@map("saga_executions")
}

model SagaStepRecord {
  id                      String   @id @default(cuid())
  sagaExecutionDbId       String                         // FK to SagaExecution.id
  stepIndex               Int                            // Step order in the saga
  stepName                String                         // e.g. "validate_email", "create_trial_record"
  action                  String                         // Action to execute
  compensatingAction      String                         // Rollback action
  isCritical              Boolean  @default(true)        // Failure triggers compensation
  status                  String   @default("pending")   // pending | running | completed | failed | compensating | compensated | skipped
  input                   String   @default("{}")        // JSON: step input data
  output                  String   @default("{}")        // JSON: step output data
  errorMessage            String?                        // Error message if failed
  compensationError       String?                        // Error during compensation
  retryCount              Int      @default(0)
  requiresExternalInput   Boolean  @default(false)       // Pauses saga awaiting input
  startedAt               DateTime?
  completedAt             DateTime?
  compensationStartedAt   DateTime?
  compensationCompletedAt DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  sagaExecution           SagaExecution @relation(fields: [sagaExecutionDbId], references: [id], onDelete: Cascade)

  @@index([sagaExecutionDbId])
  @@index([stepIndex])
  @@index([status])
  @@map("saga_step_records")
}

// ─── Phase 5: Memory Chip — Adaptive Binary Memory ──────────────────

model MemoryMapping {
  id            String   @id @default(cuid())
  mappingId     String   @unique               // Unique mapping identifier
  origin        String                         // Source term/concept
  relation      String                         // Relationship type (e.g. "renamed_to", "maps_to", "classified_as")
  destination   String                         // Target term/concept
  mechanism     String                         // schema_drift | intent_routing | policy_refinement | ontology_base
  confidence    Float    @default(0.0)          // 0.0–1.0 confidence score
  tenantId      String   @default("__anonymous__")
  approved      Boolean  @default(false)        // Whether HITL approved this mapping
  merkleHash    String?                         // BLAKE3 hash of approved mapping
  metadata      String   @default("{}")         // JSON: additional metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  approvalRecord MemoryApprovalRecord?
  lifecycleEpisodes MemoryLifecycleEpisode[]

  @@index([mappingId])
  @@index([origin])
  @@index([tenantId])
  @@index([mechanism])
  @@index([approved])
  @@index([createdAt])
  @@map("memory_mappings")
}

model MemoryApprovalRecord {
  id                    String   @id @default(cuid())
  mappingId             String   @unique               // FK to MemoryMapping.mappingId
  adminEvidenceReview   Boolean                        // GRIETA 3: Must be true
  adminJustification    String                         // GRIETA 3: Min 50 chars
  riskAcknowledgment    Boolean                        // GRIETA 3: Must be true
  adminSessionId        String                         // GRIETA 3: Min 32 chars hex
  iaQuestion            String   @default("")          // IA question asked
  iaResponse            Boolean  @default(false)       // IA response
  evidenceFor           String   @default("[]")        // JSON: string[] evidence supporting
  evidenceAgainst       String   @default("[]")        // JSON: string[] evidence against
  consensusScore        Float    @default(0.0)         // 0.0–1.0 consensus score
  approvedBy            String?                         // Admin user ID
  approvedAt            DateTime?                       // When approval was granted
  merkleHash            String?                         // Hash of the approval payload
  yamlRendered          Boolean  @default(false)       // Whether YAML was rendered
  createdAt             DateTime @default(now())

  mapping               MemoryMapping @relation(fields: [mappingId], references: [mappingId], onDelete: Cascade)

  @@index([mappingId])
  @@index([adminSessionId])
  @@map("memory_approval_records")
}

model MemoryLifecycleEpisode {
  id            String   @id @default(cuid())
  episodeId     String   @unique               // Unique episode identifier
  mappingId     String                         // FK to MemoryMapping.mappingId
  currentPhase  String                         // observe | hypothesize | validate | approve | deploy | retire
  phaseHistory  String   @default("[]")        // JSON: array of { phase, timestamp }
  status        String   @default("active")    // active | completed | abandoned | failed
  tenantId      String   @default("__anonymous__")
  metadata      String   @default("{}")        // JSON: additional metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  completedAt   DateTime?

  mapping       MemoryMapping @relation(fields: [mappingId], references: [mappingId], onDelete: Cascade)

  @@index([episodeId])
  @@index([mappingId])
  @@index([tenantId])
  @@index([status])
  @@index([currentPhase])
  @@map("memory_lifecycle_episodes")
}

// ─── API Credentials (External AI Services) ──────────────────────────
// SECURITY: Campos sensibles (apiKey, apiSecret, password, username) se
// cifran con AES-256-GCM antes de persistir. Solo se enmascaran al leer.
// INVARIANT 4 — defensa en profundidad, la regla DENY es absoluta.

model ApiCredential {
  id            String   @id @default(cuid())
  name          String                          // Human-readable name e.g. "OpenAI Production"
  platform      String                          // Platform ID: openai, anthropic, google, azure, aws, custom, etc.
  type          String   @default("api_key")    // api_key | oauth2 | basic_auth | bearer | custom
  encryptedData String                          // AES-256-GCM encrypted JSON: { apiKey, apiSecret, password, username }
  iv            String                          // Initialization vector (hex)
  authTag       String                          // Authentication tag (hex)
  endpoint      String?                         // Custom endpoint URL if applicable
  scope         String   @default("[]")         // JSON: array of permission scopes
  isActive      Boolean  @default(true)
  lastVerified  DateTime?                       // When the key was last tested
  verifyStatus  String   @default("untested")   // untested | valid | invalid | error
  verifyMessage String?                         // Result message from last verification
  metadata      String   @default("{}")         // JSON: extra config (model, region, etc.)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([platform])
  @@index([isActive])
  @@index([verifyStatus])
  @@map("api_credentials")
}

// ─── Service Credentials (External Agent Connections) ────────────────
// SECURITY: Campos cifrados con AES-256-GCM (ver lib/crypto.ts).
// Los valores nunca se almacenan en localStorage ni en texto plano.
// INVARIANT 4 — defensa en profundidad, la regla DENY es absoluta.

model ServiceCredential {
  id            String   @id @default(cuid())
  serviceId     String                          // e.g. "jira", "slack", "whatsapp", "twilio"
  nombre        String                          // Human-readable service name
  encryptedData String                          // AES-256-GCM encrypted JSON of campos (key-value pairs)
  iv            String                          // Initialization vector (hex)
  authTag       String                          // Authentication tag (hex)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([serviceId])
  @@index([isActive])
  @@map("service_credentials")
}

// ─── Niche Templates & Files (Persistent, not in-memory) ────────────

model NicheTemplate {
  id            String   @id @default(cuid())
  nombre        String                          // Template name
  descripcion   String                          // Template description
  tipo          String   @default("documento")  // documento | formulario | flujo | registro
  nichoId       String                          // Industry niche ID
  estado        String   @default("borrador")   // lista | borrador
  sourceFileId  String?                         // FK to NicheTemplateFile that generated this
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([nichoId])
  @@index([estado])
  @@map("niche_templates")
}

model NicheTemplateFile {
  id                String   @id @default(cuid())
  nombre            String                          // Original file name
  tipo              String                          // MIME type
  tamano            Int                             // File size in bytes
  nichoId           String                          // Industry niche ID
  estado            String   @default("recibido")   // recibido | procesando | completado | error
  plantillaGenerada String?                         // Name of generated template
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([nichoId])
  @@index([estado])
  @@map("niche_template_files")
}
