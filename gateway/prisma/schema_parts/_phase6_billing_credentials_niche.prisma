// ─── Subscriptions: USDT TRC20 Billing (Phase 6) ──────────────────────

model Subscription {
  id                  String    @id @default(cuid())
  subscriptionId      String    @unique               // e.g. "sub_abc123"
  tenantId            String    @unique               // One subscription per tenant
  tier                String                          // starter | business | enterprise | on_premise_enterprise | trial
  status              String                          // trial | active | past_due | cancelled | expired | suspended | pending_payment
  paymentMethod       String    @default("usdt_trc20") // Always USDT TRC20
  billingWalletAddress String                         // TRC20 wallet address for billing
  addOns              String    @default("[]")        // JSON array of add-on IDs
  startedAt           DateTime
  currentPeriodEnd    DateTime
  trialEndsAt         DateTime?
  trialCompletedAt    DateTime?                         // When trial was completed/converted
  autoRenew           Boolean   @default(true)
  lastPaymentTxHash   String?                         // TRC20 transaction hash
  lastPaymentAmount   Float?                          // USDT amount
  lastPaymentAt       DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  payments            SubscriptionPayment[]
  usageRecords        UsageRecord[]
  featureAccessLogs   FeatureAccessLog[]

  @@index([subscriptionId])
  @@index([tenantId])
  @@index([tier])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model SubscriptionPayment {
  id                    String   @id @default(cuid())
  paymentId             String   @unique               // Generated payment ID
  subscriptionDbId      String                         // FK to Subscription.id
  amountUsdt            Float                          // USDT amount
  walletFrom            String                         // Payer TRC20 address
  walletTo              String                         // Platform TRC20 address
  txHash                String                         // TRC20 transaction hash
  network               String   @default("TRC20")     // Always TRC20
  status                String                         // pending | confirming | confirmed | failed | expired | refunded
  verificationMethod    String   @default("manual_admin")  // manual_admin | semi_manual_onchain
  adminConfirmedBy      String?                            // Admin user ID who confirmed
  adminConfirmedAt      DateTime?                          // When admin confirmed
  adminNotes            String?                            // Admin notes on confirmation
  confirmations         Int      @default(0)
  requiredConfirmations Int      @default(20)          // TRC20 standard
  paidAt                DateTime?
  confirmedAt           DateTime?
  expiresAt             DateTime?
  metadata              String   @default("{}")        // JSON
  createdAt             DateTime @default(now())

  subscription          Subscription @relation(fields: [subscriptionDbId], references: [id], onDelete: Cascade)

  @@index([subscriptionDbId])
  @@index([paymentId])
  @@index([status])
  @@index([txHash])
  @@index([createdAt])
  @@map("subscription_payments")
}

model UsageRecord {
  id                String   @id @default(cuid())
  subscriptionDbId  String                         // FK to Subscription.id
  tenantId          String
  resource          String                         // e.g. "workflows", "actions_per_day", "policies"
  usageCount        Int      @default(0)
  limitValue        Int                            // 0 means unlimited
  periodStart       DateTime
  periodEnd         DateTime
  overageCount      Int      @default(0)
  overageChargeUsdt Float    @default(0.0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscription      Subscription @relation(fields: [subscriptionDbId], references: [id], onDelete: Cascade)

  @@index([subscriptionDbId])
  @@index([tenantId])
  @@index([resource])
  @@index([periodStart, periodEnd])
  @@map("usage_records")
}

// ─── Manual Payment Confirmation (Admin) ────────────────────────────

model ManualPaymentConfirmation {
  id              String   @id @default(cuid())
  paymentId       String   @unique               // Links to SubscriptionPayment.paymentId
  subscriptionId  String                         // Subscription subscriptionId
  tenantId        String
  amountUsdt      Float                          // USDT amount
  txHash          String                         // TRC20 transaction hash
  walletFrom      String                         // Payer TRC20 wallet
  walletTo        String                         // Platform TRC20 wallet
  verifiedByAdmin String                         // Admin user ID who verified
  adminNotes      String?                        // Admin notes
  status          String   @default("confirmed") // confirmed | rejected
  rejectionReason String?                        // Why rejected if rejected
  verifiedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())

  @@index([paymentId])
  @@index([subscriptionId])
  @@index([tenantId])
  @@index([verifiedByAdmin])
  @@map("manual_payment_confirmations")
}

model FeatureAccessLog {
  id                String   @id @default(cuid())
  subscriptionDbId  String                         // FK to Subscription.id
  tenantId          String
  feature           String                         // Feature name from Rust engine
  allowed           Boolean
  denialReason      String?                        // Why access was denied
  resource          String?                        // Associated resource
  userId            String?                        // User who attempted access
  ipAddress         String?                        // Request IP
  createdAt         DateTime @default(now())

  subscription      Subscription @relation(fields: [subscriptionDbId], references: [id], onDelete: Cascade)

  @@index([subscriptionDbId])
  @@index([tenantId])
  @@index([feature])
  @@index([allowed])
  @@index([createdAt])
  @@map("feature_access_logs")
}

// ─── Saga Pattern: Subscription Lifecycle Orchestration ──────────────

model SagaExecution {
  id                  String   @id @default(cuid())
  executionId         String   @unique               // e.g. "saga_trial_creation_abc123"
  sagaType            String                          // trial_creation | trial_conversion | payment_verification | cancellation | renewal | upgrade | downgrade | reactivation
  status              String   @default("pending")    // pending | running | completed | compensating | compensated | failed | timed_out | paused
  tenantId            String
  subscriptionId      String?                         // Linked subscription ID
  currentStepIndex    Int      @default(0)
  totalSteps          Int      @default(0)
  completedSteps      Int      @default(0)
  errorMessage        String?
  compensationReason  String?
  metadata            String   @default("{}")         // JSON: arbitrary metadata
  paymentCurrency     String   @default("USDT")
  paymentNetwork      String   @default("TRC20")
  startedAt           DateTime @default(now())
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  steps               SagaStepRecord[]

  @@index([executionId])
  @@index([sagaType])
  @@index([tenantId])
  @@index([status])
  @@index([subscriptionId])
  @@index([startedAt])
  @@map("saga_executions")
}

model SagaStepRecord {
  id                      String   @id @default(cuid())
  sagaExecutionDbId       String                         // FK to SagaExecution.id
  stepIndex               Int                            // Step order in the saga
  stepName                String                         // e.g. "validate_email", "create_trial_record"
  action                  String                         // Action to execute
  compensatingAction      String                         // Rollback action
  isCritical              Boolean  @default(true)        // Failure triggers compensation
  status                  String   @default("pending")   // pending | running | completed | failed | compensating | compensated | skipped
  input                   String   @default("{}")        // JSON: step input data
  output                  String   @default("{}")        // JSON: step output data
  errorMessage            String?                        // Error message if failed
  compensationError       String?                        // Error during compensation
  retryCount              Int      @default(0)
  requiresExternalInput   Boolean  @default(false)       // Pauses saga awaiting input
  startedAt               DateTime?
  completedAt             DateTime?
  compensationStartedAt   DateTime?
  compensationCompletedAt DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  sagaExecution           SagaExecution @relation(fields: [sagaExecutionDbId], references: [id], onDelete: Cascade)

  @@index([sagaExecutionDbId])
  @@index([stepIndex])
  @@index([status])
  @@map("saga_step_records")
}

// ─── API Credentials (External AI Services) ──────────────────────────
// SECURITY: Campos sensibles (apiKey, apiSecret, password, username) se
// cifran con AES-256-GCM antes de persistir. Solo se enmascaran al leer.
// INVARIANT 4 — defensa en profundidad, la regla DENY es absoluta.

model ApiCredential {
  id            String   @id @default(cuid())
  name          String                          // Human-readable name e.g. "OpenAI Production"
  platform      String                          // Platform ID: openai, anthropic, google, azure, aws, custom, etc.
  type          String   @default("api_key")    // api_key | oauth2 | basic_auth | bearer | custom
  encryptedData String                          // AES-256-GCM encrypted JSON: { apiKey, apiSecret, password, username }
  iv            String                          // Initialization vector (hex)
  authTag       String                          // Authentication tag (hex)
  endpoint      String?                         // Custom endpoint URL if applicable
  scope         String   @default("[]")         // JSON: array of permission scopes
  isActive      Boolean  @default(true)
  lastVerified  DateTime?                       // When the key was last tested
  verifyStatus  String   @default("untested")   // untested | valid | invalid | error
  verifyMessage String?                         // Result message from last verification
  metadata      String   @default("{}")         // JSON: extra config (model, region, etc.)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([platform])
  @@index([isActive])
  @@index([verifyStatus])
  @@map("api_credentials")
}

// ─── Service Credentials (External Agent Connections) ────────────────
// SECURITY: Campos cifrados con AES-256-GCM (ver lib/crypto.ts).
// Los valores nunca se almacenan en localStorage ni en texto plano.
// INVARIANT 4 — defensa en profundidad, la regla DENY es absoluta.

model ServiceCredential {
  id            String   @id @default(cuid())
  serviceId     String                          // e.g. "jira", "slack", "whatsapp", "twilio"
  nombre        String                          // Human-readable service name
  encryptedData String                          // AES-256-GCM encrypted JSON of campos (key-value pairs)
  iv            String                          // Initialization vector (hex)
  authTag       String                          // Authentication tag (hex)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([serviceId])
  @@index([isActive])
  @@map("service_credentials")
}

// ─── Niche Templates & Files (Persistent, not in-memory) ────────────

model NicheTemplate {
  id            String   @id @default(cuid())
  nombre        String                          // Template name
  descripcion   String                          // Template description
  tipo          String   @default("documento")  // documento | formulario | flujo | registro
  nichoId       String                          // Industry niche ID
  estado        String   @default("borrador")   // lista | borrador
  sourceFileId  String?                         // FK to NicheTemplateFile that generated this
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([nichoId])
  @@index([estado])
  @@map("niche_templates")
}

model NicheTemplateFile {
  id                String   @id @default(cuid())
  nombre            String                          // Original file name
  tipo              String                          // MIME type
  tamano            Int                             // File size in bytes
  nichoId           String                          // Industry niche ID
  estado            String   @default("recibido")   // recibido | procesando | completado | error
  plantillaGenerada String?                         // Name of generated template
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([nichoId])
  @@index([estado])
  @@map("niche_template_files")
}
