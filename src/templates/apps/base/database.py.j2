def execute_query(sql: str, params: Optional[Tuple] = None) -> List[Dict[str, Any]]:
    """Execute a SELECT query and return rows as list of dicts.

    Args:
        sql: SQL query with ? placeholders.
        params: Tuple of parameter values.

    Returns:
        List of row dicts.
    """
    params = params or ()
    with get_db() as conn:
        cursor = conn.execute(sql, params)
        columns = [desc[0] for desc in cursor.description] if cursor.description else []
        rows = cursor.fetchall()
        return [dict(zip(columns, row)) for row in rows]


def execute_query_one(sql: str, params: Optional[Tuple] = None) -> Optional[Dict[str, Any]]:
    """Execute a SELECT query and return a single row dict, or None."""
    params = params or ()
    with get_db() as conn:
        cursor = conn.execute(sql, params)
        row = cursor.fetchone()
        if row is None:
            return None
        columns = [desc[0] for desc in cursor.description]
        return dict(zip(columns, row))


def execute_insert(sql: str, params: Optional[Tuple] = None) -> int:
    """Execute an INSERT statement and return the lastrowid.

    Args:
        sql: SQL INSERT with ? placeholders.
        params: Tuple of parameter values.

    Returns:
        The integer rowid of the inserted row.
    """
    params = params or ()
    with get_db() as conn:
        cursor = conn.execute(sql, params)
        return cursor.lastrowid


def execute_update(sql: str, params: Optional[Tuple] = None) -> int:
    """Execute an UPDATE or DELETE statement and return the affected row count.

    Args:
        sql: SQL UPDATE/DELETE with ? placeholders.
        params: Tuple of parameter values.

    Returns:
        Number of rows affected.
    """
    params = params or ()
    with get_db() as conn:
        cursor = conn.execute(sql, params)
        return cursor.rowcount


def execute_transaction(queries: List[Tuple[str, Tuple]]) -> None:
    """Execute multiple SQL statements in a single atomic transaction.

    Args:
        queries: List of (sql, params) tuples.
    """
    with get_db() as conn:
        for sql, params in queries:
            conn.execute(sql, params)


