def _build_create_table_sql(entity_name: str, columns: List[Tuple[str, str, str]]) -> str:
    """Build a CREATE TABLE IF NOT EXISTS statement for one entity."""
    col_defs = [f"    {name} {ctype} {constraints}".strip() for name, ctype, constraints in columns]
    return f"CREATE TABLE IF NOT EXISTS {entity_name} (\n" + ",\n".join(col_defs) + "\n)"


