def sanitize_string(value: str) -> str:
    """Strip whitespace and escape HTML entities to prevent XSS."""
    if not isinstance(value, str):
        return value
    return html.escape(value.strip(), quote=True)


def sanitize_dict(data: Dict[str, Any], skip_keys: Optional[List[str]] = None) -> Dict[str, Any]:
    """Sanitize all string values in a dict, skipping specified keys.

    Args:
        data: Input dict.
        skip_keys: Keys whose values should not be escaped (e.g. "password").

    Returns:
        New dict with sanitized values.
    """
    skip_keys = skip_keys or []
    result: Dict[str, Any] = {}
    for key, value in data.items():
        if key in skip_keys:
            result[key] = value
        elif isinstance(value, str):
            result[key] = sanitize_string(value)
        else:
            result[key] = value
    return result
