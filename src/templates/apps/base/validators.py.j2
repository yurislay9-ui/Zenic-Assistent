def _get_entity_rules(entity_name: str) -> Dict[str, Dict[str, Any]]:
    """Return validation rules for an entity, falling back to a generic set."""
    if entity_name in _ENTITY_FIELD_RULES:
        return _ENTITY_FIELD_RULES[entity_name]
    # Generic entity rules
    return {
        "name": {"required": True, "max_length": 128, "type": str},
        "description": {"required": False, "max_length": 2048, "type": str},
        "status": {"required": False, "type": str, "choices": ["active", "inactive", "archived"]},
    }


def validate_entity_data(
    entity_name: str,
    data: Dict[str, Any],
    fields: Optional[List[str]] = None,
) -> List[str]:
    """Validate data for a given entity against its rule set.

    Args:
        entity_name: Name of the entity (e.g. "user", "product").
        data: Dict of field values from the request.
        fields: Optional explicit field list; if omitted, all rule fields are checked.

    Returns:
        List of error messages (empty if all valid).
    """
    rules = _get_entity_rules(entity_name)
    errors: List[str] = []

    check_fields = fields if fields is not None else list(rules.keys())

    for field in check_fields:
        rule = rules.get(field)
        if rule is None:
            continue

        value = data.get(field)

        # Required check
        if rule.get("required") and (value is None or (isinstance(value, str) and not value.strip())):
            errors.append(f"'{field}' is required")
            continue

        # Skip further checks if value is absent and not required
        if value is None:
            continue

        # Type check
        expected_type = rule.get("type")
        if expected_type and not isinstance(value, expected_type):
            errors.append(f"'{field}' must be of type {expected_type.__name__}")
            continue

        # String checks
        if isinstance(value, str):
            value = value.strip()
            max_len = rule.get("max_length")
            if max_len and len(value) > max_len:
                errors.append(f"'{field}' must be at most {max_len} characters")

        # Numeric min
        min_val = rule.get("min")
        if min_val is not None and isinstance(value, (int, float)) and value < min_val:
            errors.append(f"'{field}' must be at least {min_val}")

        # Choices
        choices = rule.get("choices")
        if choices and value not in choices:
            errors.append(f"'{field}' must be one of {choices}")

        # Named validator
        validator_name = rule.get("validator")
        if validator_name == "email":
            ok, msg = validate_email(value)
            if not ok:
                errors.append(msg)

    return errors


