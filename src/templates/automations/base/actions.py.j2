    async def _database_operation(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """
        Execute a database operation.

        Config keys:
            operation: "backup", "query", "execute" (required)
            sql: SQL query (for query/execute)
            params: Query parameters (list)
            backup_path: Backup destination (for backup)
        """
        operation = config.get("operation", "query")

        if operation == "backup":
            return await self._backup_database(config)
        elif operation == "query":
            return self._execute_query(config)
        elif operation == "execute":
            return self._execute_statement(config)
        else:
            return {"status": "skipped", "reason": f"Unknown operation: {operation}"}

    def _execute_query(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """Execute a SELECT query."""
        sql = config.get("sql", "")
        params = tuple(config.get("params", []))

        if not sql:
            return {"status": "skipped", "reason": "No SQL provided"}

        try:
            conn = sqlite3.connect(Config.DB_PATH)
            conn.row_factory = sqlite3.Row
            cursor = conn.execute(sql, params)
            rows = [dict(r) for r in cursor.fetchall()]
            conn.close()

            return {"status": "completed", "rows": rows, "count": len(rows)}

        except Exception as e:
            return {"status": "failed", "error": str(e)}

    def _execute_statement(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """Execute an INSERT/UPDATE/DELETE statement."""
        sql = config.get("sql", "")
        params = tuple(config.get("params", []))

        if not sql:
            return {"status": "skipped", "reason": "No SQL provided"}

        try:
            conn = sqlite3.connect(Config.DB_PATH)
            cursor = conn.execute(sql, params)
            conn.commit()
            affected = cursor.rowcount
            last_id = cursor.lastrowid
            conn.close()

            return {"status": "completed", "rows_affected": affected, "last_id": last_id}

        except Exception as e:
            return {"status": "failed", "error": str(e)}

    async def _backup_database(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """Backup the database file."""
        backup_dir = config.get("backup_path", "backups/")
        os.makedirs(backup_dir, exist_ok=True)

        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        db_name = os.path.basename(Config.DB_PATH)
        backup_path = os.path.join(backup_dir, f"{db_name}_{timestamp}")

        try:
            shutil.copy2(Config.DB_PATH, backup_path)
            size = os.path.getsize(backup_path)
            return {"status": "completed", "backup_path": backup_path, "size_bytes": size}

        except Exception as e:
            return {"status": "failed", "error": str(e)}

    # ================================================================
    #  FILE OPERATION EXECUTOR
    # ================================================================

    async def _file_operation(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """
        Execute a file operation.

        Config keys:
            operation: "copy", "move", "delete", "read", "write" (required)
            source: Source file path
            destination: Destination file path (for copy/move)
            content: Content to write (for write)
        """
        operation = config.get("operation", "read")
        source = config.get("source", "")
        destination = config.get("destination", "")

        try:
            if operation == "copy":
                shutil.copy2(source, destination)
                return {"status": "completed", "operation": "copy", "from": source, "to": destination}

            elif operation == "move":
                shutil.move(source, destination)
                return {"status": "completed", "operation": "move", "from": source, "to": destination}

            elif operation == "delete":
                os.remove(source)
                return {"status": "completed", "operation": "delete", "path": source}

            elif operation == "read":
                with open(source, "r", encoding="utf-8") as f:
                    content = f.read()
                return {"status": "completed", "operation": "read", "content": content[:10000]}

            elif operation == "write":
                content = config.get("content", "")
                with open(source, "w", encoding="utf-8") as f:
                    f.write(content)
                return {"status": "completed", "operation": "write", "path": source, "bytes": len(content)}

            else:
                return {"status": "skipped", "reason": f"Unknown operation: {operation}"}

        except Exception as e:
            return {"status": "failed", "error": str(e)}

