    async def _generate_report(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """
        Generate a report from data.

        Config keys:
            title: Report title
            sql: SQL query to fetch data
            params: Query parameters
            format: "html" or "csv" (default: html)
            output_path: File path to save report
        """
        title = config.get("title", "Report")
        sql = config.get("sql", "")
        params = tuple(config.get("params", []))
        fmt = config.get("format", "html")
        output_path = config.get("output_path", f"reports/report_{datetime.now().strftime('%Y%m%d_%H%M')}.{fmt}")

        if not sql:
            return {"status": "skipped", "reason": "No SQL query for report data"}

        try:
            # Fetch data
            conn = sqlite3.connect(Config.DB_PATH)
            conn.row_factory = sqlite3.Row
            cursor = conn.execute(sql, params)
            rows = [dict(r) for r in cursor.fetchall()]
            conn.close()

            if not rows:
                return {"status": "completed", "message": "No data for report", "rows": 0}

            # Generate report
            os.makedirs(os.path.dirname(output_path), exist_ok=True)

            if fmt == "csv":
                import csv
                with open(output_path, "w", newline="", encoding="utf-8") as f:
                    writer = csv.DictWriter(f, fieldnames=rows[0].keys())
                    writer.writeheader()
                    writer.writerows(rows)
            else:
                # HTML report
                html = self._build_html_report(title, rows)
                with open(output_path, "w", encoding="utf-8") as f:
                    f.write(html)

            return {"status": "completed", "path": output_path, "rows": len(rows)}

        except Exception as e:
            return {"status": "failed", "error": str(e)}

    @staticmethod
    def _build_html_report(title: str, rows: list) -> str:
        """Build a simple HTML report from data rows."""
        if not rows:
            return f"<html><body><h1>{title}</h1><p>No data</p></body></html>"

        headers = rows[0].keys()
        header_cells = "".join(f"<th>{h}</th>" for h in headers)
        rows_html = ""
        for row in rows:
            cells = "".join(f"<td>{row.get(h, '')}</td>" for h in headers)
            rows_html += f"<tr>{cells}</tr>"

        return f"""<!DOCTYPE html>
<html><head><title>{title}</title>
<style>
    body {{ font-family: sans-serif; margin: 2rem; }}
    h1 {{ color: #2563eb; }}
    table {{ border-collapse: collapse; width: 100%; }}
    th {{ background: #f1f5f9; padding: 8px; text-align: left; border: 1px solid #e2e8f0; }}
    td {{ padding: 8px; border: 1px solid #e2e8f0; }}
    tr:nth-child(even) {{ background: #f8fafc; }}
</style></head><body>
<h1>{title}</h1>
<p>Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')} | Records: {len(rows)}</p>
<table><thead><tr>{header_cells}</tr></thead><tbody>{rows_html}</tbody></table>
</body></html>"""

    # ================================================================
    #  DATA SYNC EXECUTOR
    # ================================================================

    async def _data_sync(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """
        Synchronize data between source and destination.

        Config keys:
            source_type: "database" or "http" (default: database)
            source_query: SQL for database source
            dest_type: "database" or "http" (default: database)
            dest_table: Target table for database dest
            dest_url: URL for HTTP dest
            mapping: Column mapping dict
        """
        source_type = config.get("source_type", "database")
        dest_type = config.get("dest_type", "database")

        # Fetch source data
        if source_type == "database":
            sql = config.get("source_query", "")
            if not sql:
                return {"status": "skipped", "reason": "No source query"}
            conn = sqlite3.connect(Config.DB_PATH)
            conn.row_factory = sqlite3.Row
            rows = [dict(r) for r in conn.execute(sql).fetchall()]
            conn.close()
        else:
            return {"status": "skipped", "reason": f"Source type '{source_type}' not supported yet"}

        if not rows:
            return {"status": "completed", "synced": 0, "message": "No data to sync"}

        # Write to destination
        mapping = config.get("mapping", {})

        if dest_type == "database":
            dest_table = config.get("dest_table", "")
            if not dest_table:
                return {"status": "skipped", "reason": "No destination table"}

            conn = sqlite3.connect(Config.DB_PATH)
            synced = 0
            for row in rows:
                # Apply column mapping
                mapped = {}
                for src_col, val in row.items():
                    dest_col = mapping.get(src_col, src_col)
                    mapped[dest_col] = val

                cols = ", ".join(mapped.keys())
                placeholders = ", ".join(["?"] * len(mapped))
                try:
                    conn.execute(
                        f"INSERT OR REPLACE INTO {dest_table} ({cols}) VALUES ({placeholders})",
                        tuple(mapped.values())
                    )
                    synced += 1
                except Exception as e:
                    logger.warning(f"Sync row failed: {e}")

            conn.commit()
            conn.close()
            return {"status": "completed", "synced": synced, "total": len(rows)}

        elif dest_type == "http":
            if not AIOHTTP_AVAILABLE:
                return {"status": "skipped", "reason": "aiohttp not installed"}
            url = config.get("dest_url", "")
            synced = 0
            async with aiohttp.ClientSession() as session:
                for row in rows:
                    try:
                        async with session.post(url, json=row) as resp:
                            if resp.status < 400:
                                synced += 1
                    except Exception:
                        pass
            return {"status": "completed", "synced": synced, "total": len(rows)}

        return {"status": "skipped", "reason": f"Dest type '{dest_type}' not supported"}

