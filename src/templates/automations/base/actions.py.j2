    # ================================================================
    #  EMAIL EXECUTOR
    # ================================================================

    async def _send_email(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """
        Send an email via SMTP.

        Config keys:
            to: Recipient email (required)
            subject: Email subject (required)
            body: Plain text body
            html: HTML body
            cc: CC recipients (list)
            attachments: File paths to attach (list)
        """
        to = config.get("to", Config.NOTIFICATION_EMAIL)
        subject = config.get("subject", "Automated Notification")
        body = config.get("body", "")
        html = config.get("html", "")

        if not to:
            return {"status": "skipped", "reason": "No recipient specified"}

        msg = MIMEMultipart("alternative")
        msg["From"] = Config.SMTP_USER
        msg["To"] = to
        msg["Subject"] = subject

        if body:
            msg.attach(MIMEText(body, "plain"))
        if html:
            msg.attach(MIMEText(html, "html"))

        try:
            if AIOSMTPLIB_AVAILABLE:
                await aiosmtplib.send(
                    msg.as_string(),
                    hostname=Config.SMTP_HOST,
                    port=Config.SMTP_PORT,
                    username=Config.SMTP_USER,
                    password=Config.SMTP_PASSWORD,
                    use_tls=True,
                )
            else:
                # Sync fallback
                with smtplib.SMTP(Config.SMTP_HOST, Config.SMTP_PORT) as server:
                    server.starttls()
                    if Config.SMTP_USER and Config.SMTP_PASSWORD:
                        server.login(Config.SMTP_USER, Config.SMTP_PASSWORD)
                    server.send_message(msg)

            logger.info(f"Email sent to {to}: {subject}")
            return {"status": "sent", "to": to, "subject": subject}

        except Exception as e:
            logger.error(f"Email failed: {e}")
            return {"status": "failed", "error": str(e)}

