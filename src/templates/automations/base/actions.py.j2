    async def _send_notification(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """
        Send notification via configured channel.

        Config keys:
            channel: "email", "telegram", "log" (default: log)
            message: Notification message
            recipient: Recipient identifier
        """
        channel = config.get("channel", "log")
        message = config.get("message", "Notification triggered")
        recipient = config.get("recipient", "")

        if channel == "email":
            return await self._send_email({
                "to": recipient or Config.NOTIFICATION_EMAIL,
                "subject": "Notification",
                "body": message,
            })
        elif channel == "telegram" and Config.TELEGRAM_BOT_TOKEN:
            return await self._send_telegram(config)
        else:
            # Log channel
            logger.info(f"Notification: {message}")
            return {"status": "logged", "channel": "log", "message": message}

    async def _send_telegram(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """Send Telegram notification via Bot API."""
        if not AIOHTTP_AVAILABLE:
            return {"status": "skipped", "reason": "aiohttp not installed"}

        token = Config.TELEGRAM_BOT_TOKEN
        chat_id = config.get("chat_id", Config.TELEGRAM_CHAT_ID)
        message = config.get("message", "Notification")

        try:
            url = f"https://api.telegram.org/bot{token}/sendMessage"
            async with aiohttp.ClientSession() as session:
                async with session.post(url, json={
                    "chat_id": chat_id,
                    "text": message,
                    "parse_mode": "HTML",
                }) as resp:
                    result = await resp.json()

            if result.get("ok"):
                return {"status": "sent", "channel": "telegram"}
            else:
                return {"status": "failed", "error": result.get("description", "Unknown error")}

        except Exception as e:
            return {"status": "failed", "error": str(e)}

    # ================================================================
