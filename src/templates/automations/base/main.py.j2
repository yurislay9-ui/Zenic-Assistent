}

# Default workflow if none defined
if not WORKFLOWS:
    WORKFLOWS["default"] = {
        "name": "default_automation",
        "description": "Default automation workflow",
        "trigger": {"type": "cron", "hour": 9, "minute": 0},
        "actions": [{"type": "log", "message": "Default workflow executed"}],
    }


# ================================================================
#  SCHEDULER SETUP
# ================================================================

runner = WorkflowRunner()
scheduler = AsyncIOScheduler()


def build_trigger(trigger_config: Dict[str, Any]):
    """Build an APScheduler trigger from config."""
    trigger_type = trigger_config.get("type", "cron")

    if trigger_type == "interval":
        return IntervalTrigger(
            hours=trigger_config.get("hours", 1),
            minutes=trigger_config.get("minutes", 0),
        )
    elif trigger_type == "cron":
        return CronTrigger(
            hour=trigger_config.get("hour", 9),
            minute=trigger_config.get("minute", 0),
            day_of_week=trigger_config.get("day_of_week", "*"),
            day=trigger_config.get("day", "*"),
        )
    else:
        # Default: daily at 9am
        return CronTrigger(hour=9, minute=0)


async def run_workflow_job(workflow_name: str):
    """Job wrapper for scheduler."""
    wf = WORKFLOWS.get(workflow_name, {})
    actions = wf.get("actions", [])
    await runner.run_workflow(workflow_name, actions)


# Register all workflows with the scheduler
for wf_name, wf_config in WORKFLOWS.items():
    trigger = build_trigger(wf_config.get("trigger", {}))
    scheduler.add_job(
        run_workflow_job,
        trigger,
        args=[wf_name],
        id=wf_name,
        name=wf_config.get("name", wf_name),
        replace_existing=True,
    )
    logger.info(f"Scheduled workflow: {wf_name}")


# ================================================================
#  MAIN
# ================================================================

async def main():
    """Main entry point."""
    logger.info(f"{{ '{{' }} project_name {{ '}}' }}} Automation starting...")
    logger.info(f"Registered {len(WORKFLOWS)} workflow(s)")

    scheduler.start()

    # Run all workflows once on startup
    for wf_name in WORKFLOWS:
        try:
            await run_workflow_job(wf_name)
        except Exception as e:
            logger.error(f"Startup run failed for {wf_name}: {e}")

    # Keep running
    try:
        while True:
            await asyncio.sleep(1)
    except (KeyboardInterrupt, SystemExit):
        logger.info("Shutting down...")
        scheduler.shutdown(wait=False)
        logger.info(f"Final stats: {runner.stats}")


if __name__ == "__main__":
    asyncio.run(main())
