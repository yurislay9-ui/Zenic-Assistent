# ================================================================
#  WORKFLOW RUNNER
# ================================================================

class WorkflowRunner:
    """
    Ejecuta workflows de automatizacion con manejo de errores y logging.
    """

    def __init__(self):
        self._executor = ActionExecutor()
        self._run_count = 0
        self._error_count = 0

    async def run_workflow(self, workflow_name: str, actions: list) -> Dict[str, Any]:
        """
        Execute a workflow's actions sequentially.

        Args:
            workflow_name: Name of the workflow
            actions: List of action definitions

        Returns:
            Execution result dict
        """
        self._run_count += 1
        start = datetime.now()
        logger.info(f"Workflow '{workflow_name}' started (run #{self._run_count})")

        results = []
        for i, action in enumerate(actions):
            try:
                result = await self._executor.execute(action)
                results.append({
                    "action": i + 1,
                    "type": action.get("type", "unknown"),
                    "status": "success",
                    "result": result,
                })
                logger.info(f"  Action {i+1} ({action.get('type', 'unknown')}): success")
            except Exception as e:
                self._error_count += 1
                results.append({
                    "action": i + 1,
                    "type": action.get("type", "unknown"),
                    "status": "failed",
                    "error": str(e),
                })
                logger.error(f"  Action {i+1} ({action.get('type', 'unknown')}): FAILED - {e}")

        elapsed = (datetime.now() - start).total_seconds()
        success = all(r["status"] == "success" for r in results)

        logger.info(f"Workflow '{workflow_name}' {'completed' if success else 'completed with errors'} in {elapsed:.2f}s")

        return {
            "workflow": workflow_name,
            "status": "success" if success else "partial",
            "actions_total": len(actions),
            "actions_success": sum(1 for r in results if r["status"] == "success"),
            "actions_failed": sum(1 for r in results if r["status"] == "failed"),
            "elapsed_seconds": round(elapsed, 2),
            "results": results,
        }

    @property
    def stats(self) -> Dict[str, Any]:
        """Runner statistics."""
        return {
            "total_runs": self._run_count,
            "total_errors": self._error_count,
        }


