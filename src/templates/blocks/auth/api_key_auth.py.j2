import os
import secrets
import hashlib
import logging
import time
from typing import Optional, Dict, Any, List
from datetime import datetime

from fastapi import Depends, HTTPException, status
from fastapi.security import APIKeyHeader

logger = logging.getLogger(__name__)

API_KEY_HEADER = APIKeyHeader(name="X-API-Key", auto_error=False)
KEY_PREFIX = "zenic_"
KEY_LENGTH = 32  # bytes of randomness


class APIKeyService:
    """
    API Key Authentication Service.

    Manages API keys with secure hashing and verification.
    Keys are stored hashed (SHA-256) - the plaintext is only
    shown once at creation time.
    """

    def __init__(self):
        self._key_cache: Dict[str, Dict[str, Any]] = {}

    # ================================================================
    #  KEY GENERATION
    # ================================================================

    @staticmethod
    def generate_api_key(user_id: int, name: str, db_conn,
                         expires_days: int = 365) -> Dict[str, Any]:
        """
        Generate a new API key for a user.

        The plaintext key is only returned once - it cannot be
        retrieved later since only the hash is stored.

        Args:
            user_id: Owner of the key
            name: Human-readable key name/description
            db_conn: Database connection
            expires_days: Days until key expires (0 = never)

        Returns:
            Dict with the plaintext API key (SAVE THIS!) and metadata
        """
        # Generate random key
        raw_key = secrets.token_hex(KEY_LENGTH)
        api_key = f"{KEY_PREFIX}{raw_key}"

        # Hash for storage
        key_hash = hashlib.sha256(api_key.encode()).hexdigest()
        key_prefix = api_key[:12]  # Store prefix for identification

        # Calculate expiry
        now = datetime.now().isoformat()
        expires_at = None
        if expires_days > 0:
            expires_at = (datetime.now() + __import__('datetime').timedelta(days=expires_days)).isoformat()

        # Store in database
        key_id = db_conn.execute_insert(
            """INSERT INTO api_keys (user_id, name, key_hash, key_prefix, expires_at, active, created_at)
               VALUES (?, ?, ?, ?, ?, 1, ?)""",
            (user_id, name, key_hash, key_prefix, expires_at, now)
        )

        logger.info(f"APIKeyService: Key created for user {user_id}: {name} (id={key_id})")

        return {
            "id": key_id,
            "key": api_key,  # ONLY TIME the plaintext key is available!
            "name": name,
            "prefix": key_prefix,
            "expires_at": expires_at,
            "message": "Save this key securely - it cannot be retrieved later",
        }

    # ================================================================
    #  KEY VERIFICATION
    # ================================================================

    def verify_api_key(self, key: str, db_conn) -> Optional[Dict[str, Any]]:
        """
        Verify an API key and return the associated identity.

        Args:
            key: The API key to verify
            db_conn: Database connection

        Returns:
            Dict with user_id and key metadata, or None if invalid
        """
        if not key or not key.startswith(KEY_PREFIX):
            return None

        # Check cache first
        cache_key = hashlib.sha256(key.encode()).hexdigest()
        if cache_key in self._key_cache:
            cached = self._key_cache[cache_key]
            # Check expiry from cache
            if cached.get("expires_at"):
                if datetime.now().isoformat() > cached["expires_at"]:
                    del self._key_cache[cache_key]
                    return None
            return cached

        # Hash the key and look up
        key_hash = hashlib.sha256(key.encode()).hexdigest()
        key_prefix = key[:12]

        rows = db_conn.execute_query(
            """SELECT id, user_id, name, key_hash, expires_at, active
               FROM api_keys
               WHERE key_prefix = ? AND active = 1""",
            (key_prefix,)
        )

        if not rows:
            return None

        # Find matching hash
        for row in rows:
            if secrets.compare_digest(row["key_hash"], key_hash):
                # Check expiry
                if row.get("expires_at"):
                    if datetime.now().isoformat() > row["expires_at"]:
                        return None

                # Cache the result
                result = {
                    "key_id": row["id"],
                    "user_id": row["user_id"],
                    "name": row["name"],
                    "expires_at": row.get("expires_at"),
                }
                self._key_cache[cache_key] = result
                return result

        return None

    # ================================================================
    #  KEY MANAGEMENT
    # ================================================================

    @staticmethod
    def revoke_api_key(key_id: int, db_conn) -> bool:
        """
        Revoke an API key by ID.

        Args:
            key_id: The key ID to revoke
            db_conn: Database connection

        Returns:
            True if key was revoked, False if not found
        """
        affected = db_conn.execute_update(
            "UPDATE api_keys SET active = 0, revoked_at = ? WHERE id = ?",
            (datetime.now().isoformat(), key_id)
        )
        return affected > 0

    @staticmethod
    def list_api_keys(user_id: int, db_conn) -> List[Dict[str, Any]]:
        """
        List all API keys for a user (without the actual key values).

        Args:
            user_id: User to list keys for
            db_conn: Database connection

        Returns:
            List of key metadata dicts
        """
        rows = db_conn.execute_query(
            """SELECT id, name, key_prefix, active, expires_at, created_at, revoked_at
               FROM api_keys WHERE user_id = ?
               ORDER BY created_at DESC""",
            (user_id,)
        )

        return [
            {
                "id": r["id"],
                "name": r["name"],
                "prefix": r["key_prefix"],
                "active": bool(r["active"]),
                "expires_at": r.get("expires_at"),
                "created_at": r.get("created_at"),
                "revoked_at": r.get("revoked_at"),
            }
            for r in rows
        ]

    def clear_cache(self):
        """Clear the key verification cache."""
        self._key_cache.clear()


# Singleton instance
_api_key_service = APIKeyService()


async def verify_api_key_dep(
    api_key: str = Depends(API_KEY_HEADER),
) -> Dict[str, Any]:
    """
    FastAPI dependency that validates API key from X-API-Key header.

    Usage:
        @app.get("/api/protected")
        async def protected(identity: dict = Depends(verify_api_key_dep)):
            return {"user_id": identity["user_id"]}
    """
    if not api_key:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="API key required. Provide X-API-Key header.",
        )

    # Import here to avoid circular imports
    from database import execute_query

    identity = _api_key_service.verify_api_key(api_key, type('DB', (), {'execute_query': execute_query})())

    if not identity:
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Invalid or expired API key",
        )

    return identity
