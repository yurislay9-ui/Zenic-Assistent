logger = logging.getLogger(__name__)


class Role(str, Enum):
    """User roles in the system."""
    ADMIN = "admin"
    MANAGER = "manager"
    USER = "user"
    VIEWER = "viewer"


class Permission(str, Enum):
    """System permissions."""
    # Read permissions
    READ_OWN = "read_own"
    READ_ALL = "read_all"

    # Write permissions
    WRITE_OWN = "write_own"
    WRITE_ALL = "write_all"

    # Delete permissions
    DELETE_OWN = "delete_own"
    DELETE_ALL = "delete_all"

    # Management permissions
    MANAGE_USERS = "manage_users"
    MANAGE_ROLES = "manage_roles"
    MANAGE_SYSTEM = "manage_system"

    # Special permissions
    EXPORT_DATA = "export_data"
    IMPORT_DATA = "import_data"
    VIEW_REPORTS = "view_reports"
    GENERATE_REPORTS = "generate_reports"
    MANAGE_API_KEYS = "manage_api_keys"
    MANAGE_WEBHOOKS = "manage_webhooks"


# ================================================================
#  ROLE-PERMISSION MAPPING
# ================================================================

ROLE_PERMISSIONS: Dict[str, set] = {
    Role.ADMIN: {
        Permission.READ_OWN, Permission.READ_ALL,
        Permission.WRITE_OWN, Permission.WRITE_ALL,
        Permission.DELETE_OWN, Permission.DELETE_ALL,
        Permission.MANAGE_USERS, Permission.MANAGE_ROLES,
        Permission.MANAGE_SYSTEM,
        Permission.EXPORT_DATA, Permission.IMPORT_DATA,
        Permission.VIEW_REPORTS, Permission.GENERATE_REPORTS,
        Permission.MANAGE_API_KEYS, Permission.MANAGE_WEBHOOKS,
    },
    Role.MANAGER: {
        Permission.READ_OWN, Permission.READ_ALL,
        Permission.WRITE_OWN, Permission.WRITE_ALL,
        Permission.DELETE_OWN,
        Permission.EXPORT_DATA, Permission.IMPORT_DATA,
        Permission.VIEW_REPORTS, Permission.GENERATE_REPORTS,
        Permission.MANAGE_API_KEYS, Permission.MANAGE_WEBHOOKS,
    },
    Role.USER: {
        Permission.READ_OWN,
        Permission.WRITE_OWN,
        Permission.DELETE_OWN,
        Permission.EXPORT_DATA,
        Permission.VIEW_REPORTS,
    },
    Role.VIEWER: {
        Permission.READ_OWN,
        Permission.VIEW_REPORTS,
    },
}


# ================================================================
#  PERMISSION CHECKING
# ================================================================

def check_permission(user_role: str, required_permission: str) -> bool:
    """
    Check if a role has a specific permission.

    Args:
        user_role: The user's role string
        required_permission: The permission to check

    Returns:
        True if the role has the permission, False otherwise
    """
    permissions = ROLE_PERMISSIONS.get(user_role, set())

    if isinstance(required_permission, str):
        try:
            required_permission = Permission(required_permission)
        except ValueError:
            logger.warning(f"RBAC: Unknown permission: {required_permission}")
            return False

    return required_permission in permissions


def get_role_permissions(role: str) -> List[str]:
    """Get all permissions for a role."""
    permissions = ROLE_PERMISSIONS.get(role, set())
    return [p.value for p in permissions]


def get_user_accessible_resources(user_role: str, user_id: int,
                                  resource_owner_id: int) -> Dict[str, bool]:
    """
    Determine what actions a user can perform on a resource.

    Args:
        user_role: The user's role
        user_id: The user's ID
        resource_owner_id: The resource owner's ID

    Returns:
        Dict with read, write, delete booleans
    """
    is_owner = user_id == resource_owner_id
    is_admin = user_role == Role.ADMIN
    is_manager = user_role == Role.MANAGER

    return {
        "read": is_owner or check_permission(user_role, Permission.READ_ALL),
        "write": (is_owner and check_permission(user_role, Permission.WRITE_OWN)) or
                 check_permission(user_role, Permission.WRITE_ALL) or is_admin,
        "delete": (is_owner and check_permission(user_role, Permission.DELETE_OWN)) or
                  check_permission(user_role, Permission.DELETE_ALL) or is_admin,
    }


