async def require_permission(permission: str):
    """
    FastAPI dependency factory that requires a specific permission.

    Usage:
        @app.delete("/items/{item_id}")
        async def delete_item(
            item_id: int,
            user: dict = Depends(require_permission("delete_all"))
        ):
            ...
    """
    async def _check(user: Dict[str, Any] = Depends(
        __import__('blocks.auth.jwt_auth', fromlist=['get_current_user_dep']).get_current_user_dep
    )):
        if not check_permission(user.get("role", ""), permission):
            raise HTTPException(
                status_code=status.HTTP_403_FORBIDDEN,
                detail=f"Permission '{permission}' required",
            )
        return user
    return _check


async def require_role(role: str):
    """
    FastAPI dependency factory that requires a specific role.

    Usage:
        @app.get("/admin/dashboard")
        async def admin_dashboard(
            user: dict = Depends(require_role("admin"))
        ):
            ...
    """
    async def _check(user: Dict[str, Any] = Depends(
        __import__('blocks.auth.jwt_auth', fromlist=['get_current_user_dep']).get_current_user_dep
    )):
        if user.get("role") != role:
            # Check role hierarchy
            hierarchy = {Role.VIEWER: 0, Role.USER: 1, Role.MANAGER: 2, Role.ADMIN: 3}
            user_level = hierarchy.get(user.get("role", ""), -1)
            required_level = hierarchy.get(role, -1)
            if user_level < required_level:
                raise HTTPException(
                    status_code=status.HTTP_403_FORBIDDEN,
                    detail=f"Role '{role}' or higher required",
                )
        return user
    return _check
