Provides lead management, pipeline stage transitions, lead scoring,
and follow-up tracking for a sales pipeline.
"""

from __future__ import annotations

import sqlite3
from datetime import datetime, timezone
from typing import Any


# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

STAGES: list[str] = [
    "lead",
    "qualified",
    "proposal",
    "negotiation",
    "closed_won",
    "closed_lost",
]

STAGE_INDEX: dict[str, int] = {stage: idx for idx, stage in enumerate(STAGES)}

# Weights for lead scoring (0–100 scale)
_SCORING_WEIGHTS: dict[str, float] = {
    "has_email": 10.0,
    "has_phone": 10.0,
    "company_size": 15.0,
    "budget_confirmed": 20.0,
    "engagement_score": 25.0,
    "source_quality": 20.0,
}


# ---------------------------------------------------------------------------
# Stage transitions
# ---------------------------------------------------------------------------


def move_lead_to_stage(
    lead_id: int,
    new_stage: str,
    db: sqlite3.Connection,
) -> dict[str, Any]:
    """Move a lead to a new pipeline stage.

    The transition is only allowed to the next stage forward or to either
    of the closing stages (closed_won / closed_lost).  Skipping stages
    forward is permitted (e.g. lead → proposal), but moving backwards
    is not.

    Args:
        lead_id: Primary key of the lead.
        new_stage: Target stage name (must be one of STAGES).
        db: Active SQLite database connection.

    Returns:
        Dict with lead_id, previous_stage, new_stage, moved_at.

    Raises:
        ValueError: If the stage is invalid or the transition is not allowed.
    """
    if new_stage not in STAGE_INDEX:
        raise ValueError(
            f"Invalid stage '{new_stage}'. Must be one of: {STAGES}"
        )

    cursor = db.cursor()
    cursor.execute(
        "SELECT stage FROM leads WHERE id = ?",
        (lead_id,),
    )
    row = cursor.fetchone()
    if row is None:
        raise ValueError(f"Lead with id {lead_id} does not exist")

    current_stage = row[0]
    if current_stage not in STAGE_INDEX:
        raise ValueError(f"Lead has unrecognized stage '{current_stage}'")

    current_idx = STAGE_INDEX[current_stage]
    new_idx = STAGE_INDEX[new_stage]

    # Closed stages are terminal unless re-opening from closed_lost
    if current_stage in ("closed_won", "closed_lost"):
        raise ValueError(
            f"Cannot move lead {lead_id} from terminal stage '{current_stage}'"
        )

    # Allow forward progression and closing; disallow backward
    if new_idx < current_idx and new_stage not in ("closed_won", "closed_lost"):
        raise ValueError(
            f"Cannot move lead {lead_id} backwards from "
            f"'{current_stage}' to '{new_stage}'"
        )

    now = datetime.now(timezone.utc).isoformat()
    cursor.execute(
        "UPDATE leads SET stage = ?, updated_at = ? WHERE id = ?",
        (new_stage, now, lead_id),
    )

    # Log the transition
    cursor.execute(
        """INSERT INTO lead_stage_history (lead_id, from_stage, to_stage, created_at)
           VALUES (?, ?, ?, ?)""",
        (lead_id, current_stage, new_stage, now),
    )
    db.commit()

    return {
        "lead_id": lead_id,
        "previous_stage": current_stage,
        "new_stage": new_stage,
        "moved_at": now,
    }


# ---------------------------------------------------------------------------
# Pipeline statistics
# ---------------------------------------------------------------------------


def get_pipeline_stats(db: sqlite3.Connection) -> dict[str, Any]:
    """Return counts of leads per pipeline stage plus totals.

    Args:
        db: Active SQLite database connection.

    Returns:
        Dict with 'stages' (stage_name → count), 'total_leads',
        'open_leads' (excluding closed), and 'conversion_rate'.
    """
    cursor = db.cursor()
    cursor.execute(
        "SELECT stage, COUNT(*) FROM leads GROUP BY stage",
    )
    rows = cursor.fetchall()

    stage_counts: dict[str, int] = {stage: 0 for stage in STAGES}
    for stage, count in rows:
        if stage in stage_counts:
            stage_counts[stage] = count

    total = sum(stage_counts.values())
    open_leads = total - stage_counts.get("closed_won", 0) - stage_counts.get("closed_lost", 0)
    closed_won = stage_counts.get("closed_won", 0)

    conversion_rate = (closed_won / total * 100) if total > 0 else 0.0

    return {
        "stages": stage_counts,
        "total_leads": total,
        "open_leads": open_leads,
        "conversion_rate": round(conversion_rate, 2),
    }


# ---------------------------------------------------------------------------
# Lead scoring
# ---------------------------------------------------------------------------


def score_lead(lead_data: dict[str, Any]) -> float:
    """Score a lead on a 0–100 scale based on profile attributes.

    Scoring criteria:
      - has_email (bool):      +10
      - has_phone (bool):      +10
      - company_size (int):    up to +15 (50+ employees = max)
      - budget_confirmed (bool): +20
      - engagement_score (float, 0–1): up to +25
      - source_quality (str):  up to +20 (referral > organic > paid > cold)

    Args:
        lead_data: Dict containing lead attributes.

    Returns:
        Score between 0.0 and 100.0, rounded to 1 decimal place.
    """
    score = 0.0

    # Contact info
    if lead_data.get("has_email"):
        score += _SCORING_WEIGHTS["has_email"]
    if lead_data.get("has_phone"):
        score += _SCORING_WEIGHTS["has_phone"]

    # Company size — scale: 1–10 = 5pts, 11–49 = 10pts, 50+ = 15pts
    company_size = int(lead_data.get("company_size", 0))
    if company_size >= 50:
        score += 15.0
    elif company_size >= 11:
        score += 10.0
    elif company_size >= 1:
        score += 5.0

    # Budget
    if lead_data.get("budget_confirmed"):
        score += _SCORING_WEIGHTS["budget_confirmed"]

    # Engagement (0–1 scale)
    engagement = float(lead_data.get("engagement_score", 0.0))
    engagement = max(0.0, min(1.0, engagement))
    score += engagement * _SCORING_WEIGHTS["engagement_score"]

    # Source quality
    source = str(lead_data.get("source_quality", "")).lower()
    source_scores = {
        "referral": 20.0,
        "organic": 15.0,
        "paid": 10.0,
        "cold": 5.0,
    }
    score += source_scores.get(source, 0.0)

    return round(min(score, 100.0), 1)


# ---------------------------------------------------------------------------
# Follow-ups
# ---------------------------------------------------------------------------


def get_follow_ups(db: sqlite3.Connection) -> list[dict[str, Any]]:
    """Return leads that are due for a follow-up.

    A lead is due for follow-up if:
      - Its next_follow_up date is in the past or today.
      - It is not in a closed stage.

    Args:
        db: Active SQLite database connection.

    Returns:
        List of dicts with lead details, sorted by follow-up date ascending.
    """
    now_str = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    cursor = db.cursor()
    cursor.execute(
        """SELECT id, name, email, stage, next_follow_up, assigned_to
           FROM leads
           WHERE next_follow_up <= ?
             AND stage NOT IN ('closed_won', 'closed_lost')
           ORDER BY next_follow_up ASC""",
        (now_str,),
    )
    rows = cursor.fetchall()

    follow_ups: list[dict[str, Any]] = []
    for row in rows:
        follow_ups.append(
            {
                "lead_id": row[0],
                "name": row[1],
                "email": row[2],
                "stage": row[3],
                "next_follow_up": row[4],
                "assigned_to": row[5],
            }
        )

    return follow_ups
