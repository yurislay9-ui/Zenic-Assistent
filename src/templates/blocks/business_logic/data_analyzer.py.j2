from __future__ import annotations

import math
from typing import Any


# ---------------------------------------------------------------------------
# Basic statistics
# ---------------------------------------------------------------------------


def calculate_stats(values: list[float]) -> dict[str, float]:
    """Compute descriptive statistics for a list of numeric values.

    Args:
        values: List of numeric values (ints or floats).

    Returns:
        Dict with keys: count, mean, median, min, max, std_dev.
        Returns zeros for all metrics when the list is empty.

    Raises:
        ValueError: If any value is not numeric.
    """
    if not values:
        return {
            "count": 0,
            "mean": 0.0,
            "median": 0.0,
            "min": 0.0,
            "max": 0.0,
            "std_dev": 0.0,
        }

    numeric_values: list[float] = []
    for v in values:
        try:
            numeric_values.append(float(v))
        except (ValueError, TypeError) as exc:
            raise ValueError(f"Non-numeric value encountered: {v!r}") from exc

    n = len(numeric_values)
    sorted_vals = sorted(numeric_values)
    total = sum(sorted_vals)
    mean = total / n

    # Median
    if n % 2 == 1:
        median = sorted_vals[n // 2]
    else:
        median = (sorted_vals[n // 2 - 1] + sorted_vals[n // 2]) / 2.0

    # Population standard deviation
    variance = sum((v - mean) ** 2 for v in sorted_vals) / n
    std_dev = math.sqrt(variance)

    return {
        "count": n,
        "mean": round(mean, 6),
        "median": round(median, 6),
        "min": round(sorted_vals[0], 6),
        "max": round(sorted_vals[-1], 6),
        "std_dev": round(std_dev, 6),
    }


# ---------------------------------------------------------------------------
# Trend detection
# ---------------------------------------------------------------------------


def calculate_trend(values: list[float]) -> str:
    """Determine the trend direction of a time-series using simple linear
    regression slope.

    The series index (0, 1, 2, …) is used as the x-axis.  The slope
    magnitude relative to the mean determines the label:
      - "up"     if slope / mean  >  0.01
      - "down"   if slope / mean  < -0.01
      - "stable" otherwise

    Args:
        values: Ordered list of numeric values.

    Returns:
        One of "up", "down", or "stable".
    """
    if len(values) < 2:
        return "stable"

    n = len(values)
    numeric = [float(v) for v in values]

    # Linear regression: y = a + b*x
    x_mean = (n - 1) / 2.0
    y_mean = sum(numeric) / n

    numerator = sum((i - x_mean) * (numeric[i] - y_mean) for i in range(n))
    denominator = sum((i - x_mean) ** 2 for i in range(n))

    if denominator == 0:
        return "stable"

    slope = numerator / denominator

    # Normalize slope relative to mean to decide significance
    if y_mean == 0:
        return "stable"

    relative_slope = slope / abs(y_mean)

    if relative_slope > 0.01:
        return "up"
    elif relative_slope < -0.01:
        return "down"
    else:
        return "stable"


# ---------------------------------------------------------------------------
# Distribution
# ---------------------------------------------------------------------------


def calculate_distribution(
    values: list[float],
    bins: int = 10,
) -> list[dict[str, Any]]:
    """Bin values into equal-width histogram buckets.

    Args:
        values: List of numeric values.
        bins: Number of bins (must be >= 1).

    Returns:
        List of dicts, each with:
          - bin_start (float): Lower bound of the bin (inclusive).
          - bin_end (float): Upper bound of the bin (exclusive for all but last).
          - count (int): Number of values in the bin.
          - frequency (float): Proportion of total values in the bin.

    Raises:
        ValueError: If bins < 1 or values is empty.
    """
    if bins < 1:
        raise ValueError(f"bins must be >= 1, got {bins}")
    if not values:
        raise ValueError("values must not be empty")

    numeric = [float(v) for v in values]
    min_val = min(numeric)
    max_val = max(numeric)

    # Handle the case where all values are identical
    if min_val == max_val:
        return [
            {
                "bin_start": min_val,
                "bin_end": max_val,
                "count": len(numeric),
                "frequency": 1.0,
            }
        ]

    bin_width = (max_val - min_val) / bins
    total = len(numeric)
    distribution: list[dict[str, Any]] = []

    for i in range(bins):
        bin_start = min_val + i * bin_width
        bin_end = min_val + (i + 1) * bin_width

        # Last bin is inclusive on both ends
        if i == bins - 1:
            count = sum(1 for v in numeric if bin_start <= v <= bin_end)
        else:
            count = sum(1 for v in numeric if bin_start <= v < bin_end)

        distribution.append(
            {
                "bin_start": round(bin_start, 6),
                "bin_end": round(bin_end, 6),
                "count": count,
                "frequency": round(count / total, 6),
            }
        )

    return distribution


# ---------------------------------------------------------------------------
# Period comparison
# ---------------------------------------------------------------------------


def compare_periods(
    current: list[float],
    previous: list[float],
) -> dict[str, Any]:
    """Compare two time periods and compute change metrics.

    Args:
        current: Values for the current period.
        previous: Values for the previous period.

    Returns:
        Dict with:
          - current_mean, previous_mean
          - current_sum, previous_sum
          - absolute_change  (current_mean - previous_mean)
          - percentage_change ((current_mean - previous_mean) / previous_mean * 100)
          - trend: "up", "down", or "stable"
          - current_stats: full stats dict for current period
          - previous_stats: full stats dict for previous period
    """
    current_stats = calculate_stats(current)
    previous_stats = calculate_stats(previous)

    cur_mean = current_stats["mean"]
    prev_mean = previous_stats["mean"]

    absolute_change = round(cur_mean - prev_mean, 6)

    if prev_mean != 0:
        percentage_change = round(
            ((cur_mean - prev_mean) / abs(prev_mean)) * 100, 2
        )
    else:
        percentage_change = 0.0 if cur_mean == 0 else float("inf")

    if absolute_change > 0:
        trend = "up"
    elif absolute_change < 0:
        trend = "down"
    else:
        trend = "stable"

    return {
        "current_mean": cur_mean,
        "previous_mean": prev_mean,
        "current_sum": current_stats["count"] * cur_mean,
        "previous_sum": previous_stats["count"] * prev_mean,
        "absolute_change": absolute_change,
        "percentage_change": percentage_change,
        "trend": trend,
        "current_stats": current_stats,
        "previous_stats": previous_stats,
    }


# ---------------------------------------------------------------------------
# Anomaly detection
# ---------------------------------------------------------------------------


def detect_anomalies(
    values: list[float],
    threshold: float = 2.0,
) -> list[dict[str, Any]]:
    """Detect anomalies using the z-score method.

    A value is considered anomalous if its z-score (distance from the
    mean in standard deviations) exceeds *threshold*.

    Args:
        values: List of numeric values.
        threshold: Number of standard deviations beyond which a value
                   is flagged (must be > 0, default 2.0).

    Returns:
        List of dicts for each anomalous value, each with:
          - index (int): Position in the input list.
          - value (float): The anomalous value.
          - z_score (float): Computed z-score.
          - deviation (str): "above" or "below" the mean.

    Raises:
        ValueError: If threshold <= 0 or fewer than 2 values provided.
    """
    if threshold <= 0:
        raise ValueError(f"threshold must be > 0, got {threshold}")
    if len(values) < 2:
        return []

    numeric = [float(v) for v in values]
    n = len(numeric)
    mean = sum(numeric) / n
    variance = sum((v - mean) ** 2 for v in numeric) / n

    if variance == 0:
        # All values identical — no anomalies possible
        return []

    std_dev = math.sqrt(variance)

    anomalies: list[dict[str, Any]] = []
    for i, val in enumerate(numeric):
        z_score = (val - mean) / std_dev
        if abs(z_score) > threshold:
            anomalies.append(
                {
                    "index": i,
                    "value": round(val, 6),
                    "z_score": round(z_score, 6),
                    "deviation": "above" if z_score > 0 else "below",
                }
            )

    return anomalies
