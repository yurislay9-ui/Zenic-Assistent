from __future__ import annotations

import sqlite3
from datetime import datetime, timezone
from typing import Any


# ---------------------------------------------------------------------------
# Core stock operations
# ---------------------------------------------------------------------------


def update_stock(
    product_id: int,
    quantity_change: int,
    db: sqlite3.Connection,
) -> dict[str, Any]:
    """Adjust the stock level of a product by *quantity_change* units.

    A positive quantity_change adds stock; a negative value removes it.
    Stock is never allowed to fall below zero (after accounting for
    reserved stock).

    Args:
        product_id: Primary key of the product row.
        quantity_change: Number of units to add (positive) or remove (negative).
        db: Active SQLite database connection.

    Returns:
        Dict with product_id, previous_quantity, new_quantity, quantity_change,
        and a list of alert strings (e.g. low-stock warnings).

    Raises:
        ValueError: If the product does not exist or insufficient stock.
    """
    cursor = db.cursor()

    # Fetch current stock
    cursor.execute(
        "SELECT quantity, reserved FROM products WHERE id = ?",
        (product_id,),
    )
    row = cursor.fetchone()
    if row is None:
        raise ValueError(f"Product with id {product_id} does not exist")

    previous_quantity = row[0]
    reserved = row[1]

    new_quantity = previous_quantity + quantity_change

    # Ensure available stock doesn't go negative
    available = new_quantity - reserved
    if available < 0:
        raise ValueError(
            f"Insufficient available stock for product {product_id}. "
            f"Requested change: {quantity_change}, "
            f"current: {previous_quantity}, reserved: {reserved}"
        )

    if new_quantity < 0:
        raise ValueError(
            f"Stock quantity cannot go negative for product {product_id}. "
            f"Current: {previous_quantity}, change: {quantity_change}"
        )

    cursor.execute(
        "UPDATE products SET quantity = ?, updated_at = ? WHERE id = ?",
        (new_quantity, datetime.now(timezone.utc).isoformat(), product_id),
    )

    # Log the movement
    cursor.execute(
        """INSERT INTO stock_movements (product_id, quantity_change, created_at)
           VALUES (?, ?, ?)""",
        (product_id, quantity_change, datetime.now(timezone.utc).isoformat()),
    )
    db.commit()

    # Check for alerts
    alerts: list[str] = []
    if new_quantity <= 0:
        alerts.append("OUT_OF_STOCK")
    elif new_quantity <= reserved * 2:
        alerts.append("LOW_STOCK")

    return {
        "product_id": product_id,
        "previous_quantity": previous_quantity,
        "new_quantity": new_quantity,
        "quantity_change": quantity_change,
        "alerts": alerts,
    }


# ---------------------------------------------------------------------------
# Low-stock checks
# ---------------------------------------------------------------------------


def check_low_stock(
    product_id: int,
    threshold: int,
    db: sqlite3.Connection,
) -> dict[str, Any]:
    """Check whether a single product is below a stock threshold.

    Args:
        product_id: Primary key of the product.
        threshold: Quantity below which the product is considered low-stock.
        db: Active SQLite database connection.

    Returns:
        Dict with product_id, current_quantity, threshold, is_low_stock flag.
    """
    cursor = db.cursor()
    cursor.execute(
        "SELECT quantity FROM products WHERE id = ?",
        (product_id,),
    )
    row = cursor.fetchone()
    if row is None:
        raise ValueError(f"Product with id {product_id} does not exist")

    current_quantity = row[0]
    is_low = current_quantity <= threshold

    return {
        "product_id": product_id,
        "current_quantity": current_quantity,
        "threshold": threshold,
        "is_low_stock": is_low,
    }


def get_stock_alerts(
    threshold: int,
    db: sqlite3.Connection,
) -> list[dict[str, Any]]:
    """Return all products whose stock is at or below *threshold*.

    Args:
        threshold: Quantity at or below which a product triggers an alert.
        db: Active SQLite database connection.

    Returns:
        List of dicts, each with product_id, name, quantity, reserved,
        available, threshold.
    """
    cursor = db.cursor()
    cursor.execute(
        """SELECT id, name, quantity, reserved
           FROM products
           WHERE quantity <= ?
           ORDER BY quantity ASC""",
        (threshold,),
    )
    rows = cursor.fetchall()

    alerts: list[dict[str, Any]] = []
    for row in rows:
        alerts.append(
            {
                "product_id": row[0],
                "name": row[1],
                "quantity": row[2],
                "reserved": row[3],
                "available": row[2] - row[3],
                "threshold": threshold,
            }
        )

    return alerts


# ---------------------------------------------------------------------------
# Reservations
# ---------------------------------------------------------------------------


def reserve_stock(
    product_id: int,
    quantity: int,
    db: sqlite3.Connection,
) -> dict[str, Any]:
    """Reserve *quantity* units of a product (e.g. for a pending order).

    Reserved units reduce available stock but remain in the total quantity
    until the order is fulfilled (stock is actually removed).

    Args:
        product_id: Primary key of the product.
        quantity: Number of units to reserve.
        db: Active SQLite database connection.

    Returns:
        Dict with product_id, reserved, quantity, available.

    Raises:
        ValueError: If insufficient available stock or product not found.
    """
    if quantity <= 0:
        raise ValueError("Reservation quantity must be positive")

    cursor = db.cursor()
    cursor.execute(
        "SELECT quantity, reserved FROM products WHERE id = ?",
        (product_id,),
    )
    row = cursor.fetchone()
    if row is None:
        raise ValueError(f"Product with id {product_id} does not exist")

    current_quantity = row[0]
    current_reserved = row[1]
    available = current_quantity - current_reserved

    if available < quantity:
        raise ValueError(
            f"Insufficient available stock to reserve. "
            f"Available: {available}, requested: {quantity}"
        )

    new_reserved = current_reserved + quantity
    cursor.execute(
        "UPDATE products SET reserved = ?, updated_at = ? WHERE id = ?",
        (new_reserved, datetime.now(timezone.utc).isoformat(), product_id),
    )

    # Log the reservation
    cursor.execute(
        """INSERT INTO stock_reservations (product_id, quantity, created_at)
           VALUES (?, ?, ?)""",
        (product_id, quantity, datetime.now(timezone.utc).isoformat()),
    )
    db.commit()

    return {
        "product_id": product_id,
        "reserved": new_reserved,
        "quantity": current_quantity,
        "available": current_quantity - new_reserved,
    }


def release_reserved_stock(
    product_id: int,
    quantity: int,
    db: sqlite3.Connection,
) -> dict[str, Any]:
    """Release previously reserved stock back to available inventory.

    This is typically called when an order is cancelled or a reservation
    expires.

    Args:
        product_id: Primary key of the product.
        quantity: Number of reserved units to release.
        db: Active SQLite database connection.

    Returns:
        Dict with product_id, reserved, quantity, available.

    Raises:
        ValueError: If release exceeds current reservations or product not found.
    """
    if quantity <= 0:
        raise ValueError("Release quantity must be positive")

    cursor = db.cursor()
    cursor.execute(
        "SELECT quantity, reserved FROM products WHERE id = ?",
        (product_id,),
    )
    row = cursor.fetchone()
    if row is None:
        raise ValueError(f"Product with id {product_id} does not exist")

    current_quantity = row[0]
    current_reserved = row[1]

    if quantity > current_reserved:
        raise ValueError(
            f"Cannot release {quantity} units; only {current_reserved} reserved"
        )

    new_reserved = current_reserved - quantity
    cursor.execute(
        "UPDATE products SET reserved = ?, updated_at = ? WHERE id = ?",
        (new_reserved, datetime.now(timezone.utc).isoformat(), product_id),
    )

    # Log the release
    cursor.execute(
        """INSERT INTO stock_reservations (product_id, quantity, created_at)
           VALUES (?, ?, ?)""",
        (product_id, -quantity, datetime.now(timezone.utc).isoformat()),
    )
    db.commit()

    return {
        "product_id": product_id,
        "reserved": new_reserved,
        "quantity": current_quantity,
        "available": current_quantity - new_reserved,
    }
