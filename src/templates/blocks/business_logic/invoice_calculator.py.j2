from __future__ import annotations

import math
from typing import Any


def calculate_line_total(quantity: float, unit_price: float) -> float:
    """Calculate the total for a single line item.

    Args:
        quantity: Number of units.
        unit_price: Price per unit.

    Returns:
        Line total rounded to 2 decimal places.
    """
    return round(quantity * unit_price, 2)


def apply_tax(subtotal: float, tax_rate: float) -> float:
    """Apply tax rate to a subtotal.

    Args:
        subtotal: Pre-tax amount.
        tax_rate: Tax rate as a percentage (e.g. 8.5 for 8.5%).

    Returns:
        Tax amount rounded to 2 decimal places.
    """
    if subtotal < 0:
        raise ValueError(f"Subtotal cannot be negative: {subtotal}")
    if tax_rate < 0:
        raise ValueError(f"Tax rate cannot be negative: {tax_rate}")
    return round(subtotal * (tax_rate / 100), 2)


def apply_discount(subtotal: float, discount: float) -> float:
    """Apply discount to a subtotal.

    The discount can be either a flat amount or a percentage:
      - If discount <= 1.0 it is treated as a percentage (e.g. 0.10 = 10%).
      - If discount > 1.0 it is treated as a flat monetary amount.

    Args:
        subtotal: Pre-discount amount.
        discount: Discount value (percentage as decimal or flat amount).

    Returns:
        Discount amount rounded to 2 decimal places.

    Raises:
        ValueError: If the discount would exceed the subtotal.
    """
    if subtotal < 0:
        raise ValueError(f"Subtotal cannot be negative: {subtotal}")
    if discount < 0:
        raise ValueError(f"Discount cannot be negative: {discount}")

    if discount <= 1.0:
        discount_amount = round(subtotal * discount, 2)
    else:
        discount_amount = round(discount, 2)

    if discount_amount > subtotal:
        raise ValueError(
            f"Discount ({discount_amount}) cannot exceed subtotal ({subtotal})"
        )

    return discount_amount


def calculate_invoice(
    items: list[dict[str, Any]],
    tax_rate: float = 0.0,
    discount: float = 0.0,
) -> dict[str, Any]:
    """Calculate a full invoice from line items.

    Each item dict must contain: name (str), quantity (float), unit_price (float).

    Calculation order:
      1. Compute each line total and the subtotal.
      2. Apply discount to the subtotal.
      3. Apply tax to the discounted subtotal.

    Args:
        items: List of line-item dicts.
        tax_rate: Tax rate as a percentage (e.g. 8.5 for 8.5%).
        discount: Discount (percentage as decimal or flat amount, see apply_discount).

    Returns:
        Dict with keys: items (with line_total added), subtotal, tax_rate,
        discount, discount_amount, taxable_amount, tax_amount, total.

    Raises:
        ValueError: If any item is missing required fields or has invalid data.
    """
    if not items:
        return {
            "items": [],
            "subtotal": 0.0,
            "tax_rate": tax_rate,
            "discount": discount,
            "discount_amount": 0.0,
            "taxable_amount": 0.0,
            "tax_amount": 0.0,
            "total": 0.0,
        }

    calculated_items: list[dict[str, Any]] = []
    subtotal = 0.0

    for item in items:
        required_keys = {"name", "quantity", "unit_price"}
        missing = required_keys - item.keys()
        if missing:
            raise ValueError(f"Item missing required keys: {missing}")

        quantity = float(item["quantity"])
        unit_price = float(item["unit_price"])

        if quantity < 0:
            raise ValueError(f"Quantity cannot be negative for item '{item['name']}'")
        if unit_price < 0:
            raise ValueError(f"Unit price cannot be negative for item '{item['name']}'")

        line_total = calculate_line_total(quantity, unit_price)
        calculated_items.append(
            {
                "name": item["name"],
                "quantity": quantity,
                "unit_price": unit_price,
                "line_total": line_total,
            }
        )
        subtotal += line_total

    subtotal = round(subtotal, 2)
    discount_amount = apply_discount(subtotal, discount) if discount else 0.0
    taxable_amount = round(subtotal - discount_amount, 2)
    tax_amount = apply_tax(taxable_amount, tax_rate) if tax_rate else 0.0
    total = round(taxable_amount + tax_amount, 2)

    return {
        "items": calculated_items,
        "subtotal": subtotal,
        "tax_rate": tax_rate,
        "discount": discount,
        "discount_amount": discount_amount,
        "taxable_amount": taxable_amount,
        "tax_amount": tax_amount,
        "total": total,
    }


def validate_invoice_data(data: dict[str, Any]) -> list[str]:
    """Validate invoice data and return a list of error messages.

    Checks for:
      - Presence of required top-level keys (items, tax_rate, discount).
      - Each item has name, quantity, unit_price.
      - Numeric values are valid and non-negative.

    Args:
        data: Invoice payload to validate.

    Returns:
        List of human-readable error strings.  Empty list means valid.
    """
    errors: list[str] = []

    # --- Top-level checks ---
    if "items" not in data:
        errors.append("Missing required field: items")
    if "tax_rate" not in data:
        errors.append("Missing required field: tax_rate")
    if "discount" not in data:
        errors.append("Missing required field: discount")

    if errors:
        # Cannot validate items without the container.
        return errors

    # --- items checks ---
    items = data["items"]
    if not isinstance(items, list):
        errors.append("'items' must be a list")
        return errors

    if len(items) == 0:
        errors.append("Invoice must contain at least one item")

    for idx, item in enumerate(items):
        prefix = f"Item {idx}"
        if not isinstance(item, dict):
            errors.append(f"{prefix}: must be a dict")
            continue

        for key in ("name", "quantity", "unit_price"):
            if key not in item:
                errors.append(f"{prefix}: missing '{key}'")

        if "name" in item and not isinstance(item["name"], str):
            errors.append(f"{prefix}: 'name' must be a string")

        if "quantity" in item:
            try:
                q = float(item["quantity"])
                if q < 0:
                    errors.append(f"{prefix}: 'quantity' cannot be negative")
            except (ValueError, TypeError):
                errors.append(f"{prefix}: 'quantity' must be numeric")

        if "unit_price" in item:
            try:
                p = float(item["unit_price"])
                if p < 0:
                    errors.append(f"{prefix}: 'unit_price' cannot be negative")
            except (ValueError, TypeError):
                errors.append(f"{prefix}: 'unit_price' must be numeric")

    # --- tax_rate checks ---
    try:
        tr = float(data["tax_rate"])
        if tr < 0:
            errors.append("tax_rate cannot be negative")
    except (ValueError, TypeError):
        errors.append("tax_rate must be numeric")

    # --- discount checks ---
    try:
        d = float(data["discount"])
        if d < 0:
            errors.append("discount cannot be negative")
    except (ValueError, TypeError):
        errors.append("discount must be numeric")

    return errors
