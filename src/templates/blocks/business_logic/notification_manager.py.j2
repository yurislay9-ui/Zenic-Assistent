from __future__ import annotations

import asyncio
import enum
import logging
import smtplib
import string
from email.mime.text import MIMEText
from typing import Any

try:
    import aiohttp
except ImportError:  # pragma: no cover
    aiohttp = None  # type: ignore[assignment]

logger = logging.getLogger(__name__)


# ---------------------------------------------------------------------------
# Channel enum
# ---------------------------------------------------------------------------


class NotificationChannel(enum.Enum):
    """Supported notification channels."""

    EMAIL = "email"
    TELEGRAM = "telegram"
    LOG = "log"


# ---------------------------------------------------------------------------
# Template formatting
# ---------------------------------------------------------------------------


def format_notification(template: str, data: dict[str, Any]) -> str:
    """Render a notification template using Python's string.Template syntax.

    Template uses $variable or ${variable} placeholders.

    Args:
        template: String with $variable placeholders.
        data: Dict of values to substitute.

    Returns:
        Rendered string with all matching placeholders replaced.

    Raises:
        KeyError: If a required placeholder is missing from data.
    """
    tmpl = string.Template(template)
    try:
        return tmpl.substitute(data)
    except (KeyError, ValueError):
        # Fall back to safe_substitute so partial renders still work
        return tmpl.safe_substitute(data)


# ---------------------------------------------------------------------------
# Email channel
# ---------------------------------------------------------------------------


def send_email_notification(
    to: str,
    subject: str,
    body: str,
    config: dict[str, Any],
) -> dict[str, Any]:
    """Send an email notification via SMTP.

    Expected config keys:
        smtp_host (str): SMTP server hostname.
        smtp_port (int): SMTP server port (default 587).
        smtp_user (str): SMTP login username.
        smtp_password (str): SMTP login password.
        smtp_use_tls (bool): Whether to use STARTTLS (default True).
        from_address (str): Sender email address.

    Args:
        to: Recipient email address.
        subject: Email subject line.
        body: Plain-text email body.
        config: SMTP configuration dict.

    Returns:
        Dict with channel, success, recipient, and optional error.
    """
    smtp_host = config.get("smtp_host", "localhost")
    smtp_port = int(config.get("smtp_port", 587))
    smtp_user = config.get("smtp_user", "")
    smtp_password = config.get("smtp_password", "")
    smtp_use_tls = config.get("smtp_use_tls", True)
    from_address = config.get("from_address", smtp_user or "noreply@example.com")

    msg = MIMEText(body, "plain", "utf-8")
    msg["Subject"] = subject
    msg["From"] = from_address
    msg["To"] = to

    try:
        if smtp_use_tls:
            server = smtplib.SMTP(smtp_host, smtp_port, timeout=30)
            server.ehlo()
            server.starttls()
            server.ehlo()
        else:
            server = smtplib.SMTP(smtp_host, smtp_port, timeout=30)
            server.ehlo()

        if smtp_user and smtp_password:
            server.login(smtp_user, smtp_password)

        server.sendmail(from_address, [to], msg.as_string())
        server.quit()

        return {
            "channel": NotificationChannel.EMAIL.value,
            "success": True,
            "recipient": to,
        }
    except smtplib.SMTPException as exc:
        return {
            "channel": NotificationChannel.EMAIL.value,
            "success": False,
            "recipient": to,
            "error": str(exc),
        }
    except OSError as exc:
        return {
            "channel": NotificationChannel.EMAIL.value,
            "success": False,
            "recipient": to,
            "error": f"Connection error: {exc}",
        }


# ---------------------------------------------------------------------------
# Telegram channel
# ---------------------------------------------------------------------------


async def _async_send_telegram(
    chat_id: str,
    message: str,
    config: dict[str, Any],
) -> dict[str, Any]:
    """Async implementation of Telegram notification via Bot API.

    Expected config keys:
        telegram_bot_token (str): Bot token from @BotFather.
        telegram_api_base (str): API base URL (default: https://api.telegram.org).

    Args:
        chat_id: Target chat ID.
        message: Text message to send.
        config: Telegram configuration dict.

    Returns:
        Dict with channel, success, chat_id, and optional error.
    """
    if aiohttp is None:
        return {
            "channel": NotificationChannel.TELEGRAM.value,
            "success": False,
            "chat_id": chat_id,
            "error": "aiohttp package is not installed",
        }

    bot_token = config.get("telegram_bot_token", "")
    api_base = config.get(
        "telegram_api_base", "https://api.telegram.org"
    ).rstrip("/")

    if not bot_token:
        return {
            "channel": NotificationChannel.TELEGRAM.value,
            "success": False,
            "chat_id": chat_id,
            "error": "telegram_bot_token not configured",
        }

    url = f"{api_base}/bot{bot_token}/sendMessage"
    payload = {
        "chat_id": chat_id,
        "text": message,
        "parse_mode": "HTML",
    }

    try:
        async with aiohttp.ClientSession() as session:
            async with session.post(url, json=payload, timeout=aiohttp.ClientTimeout(total=15)) as resp:
                if resp.status == 200:
                    return {
                        "channel": NotificationChannel.TELEGRAM.value,
                        "success": True,
                        "chat_id": chat_id,
                    }
                body = await resp.text()
                return {
                    "channel": NotificationChannel.TELEGRAM.value,
                    "success": False,
                    "chat_id": chat_id,
                    "error": f"HTTP {resp.status}: {body[:200]}",
                }
    except asyncio.TimeoutError:
        return {
            "channel": NotificationChannel.TELEGRAM.value,
            "success": False,
            "chat_id": chat_id,
            "error": "Request timed out",
        }
    except OSError as exc:
        return {
            "channel": NotificationChannel.TELEGRAM.value,
            "success": False,
            "chat_id": chat_id,
            "error": f"Connection error: {exc}",
        }


def send_telegram_notification(
    chat_id: str,
    message: str,
    config: dict[str, Any],
) -> dict[str, Any]:
    """Send a Telegram notification (synchronous wrapper).

    Internally runs the async implementation on a new event loop
    so the caller does not need to be async.

    Args:
        chat_id: Target Telegram chat ID.
        message: Text to send.
        config: Telegram configuration dict.

    Returns:
        Dict with channel, success, chat_id, and optional error.
    """
    try:
        loop = asyncio.get_running_loop()
    except RuntimeError:
        loop = None

    if loop and loop.is_running():
        # We are already inside an async context — schedule in a new thread
        import concurrent.futures

        with concurrent.futures.ThreadPoolExecutor(max_workers=1) as pool:
            future = pool.submit(
                asyncio.run,
                _async_send_telegram(chat_id, message, config),
            )
            return future.result(timeout=30)
    else:
        return asyncio.run(
            _async_send_telegram(chat_id, message, config)
        )


# ---------------------------------------------------------------------------
# Log channel
# ---------------------------------------------------------------------------


def _send_log_notification(
    recipient: str,
    message: str,
) -> dict[str, Any]:
    """Write a notification to the application log.

    Args:
        recipient: Identifier for the intended recipient.
        message: Notification text.

    Returns:
        Dict with channel, success, recipient.
    """
    logger.info("Notification to %s: %s", recipient, message)
    return {
        "channel": NotificationChannel.LOG.value,
        "success": True,
        "recipient": recipient,
    }


# ---------------------------------------------------------------------------
# Multi-channel dispatch
# ---------------------------------------------------------------------------


def send_notification(
    recipient: str,
    message: str,
    channels: list[NotificationChannel],
    config: dict[str, Any],
) -> dict[str, Any]:
    """Send a notification through one or more channels.

    All channels are attempted regardless of individual failures.

    Args:
        recipient: Email address, chat ID, or generic identifier.
        message: Notification body text.
        channels: List of NotificationChannel enum values to use.
        config: Configuration dict (must contain credentials for
                the selected channels).

    Returns:
        Dict with overall 'success' (True if any channel succeeded),
        and 'results' — a list of per-channel result dicts.
    """
    results: list[dict[str, Any]] = []

    for channel in channels:
        if channel == NotificationChannel.EMAIL:
            result = send_email_notification(
                to=recipient,
                subject=config.get("notification_subject", "Notification from {{ project_name }}"),
                body=message,
                config=config,
            )
        elif channel == NotificationChannel.TELEGRAM:
            result = send_telegram_notification(
                chat_id=recipient,
                message=message,
                config=config,
            )
        elif channel == NotificationChannel.LOG:
            result = _send_log_notification(
                recipient=recipient,
                message=message,
            )
        else:
            result = {
                "channel": str(channel),
                "success": False,
                "error": f"Unsupported channel: {channel}",
            }

        results.append(result)

    overall_success = any(r.get("success", False) for r in results)

    return {
        "success": overall_success,
        "results": results,
    }
