from __future__ import annotations

import csv
import html
import io
import math
from typing import Any


# ---------------------------------------------------------------------------
# Formatting helpers
# ---------------------------------------------------------------------------


def format_currency(value: float) -> str:
    """Format a numeric value as a currency string.

    Uses comma-separated thousands and two decimal places.
    No currency symbol is prepended so the caller can choose.

    Args:
        value: Numeric value to format.

    Returns:
        Formatted string, e.g. '1,234.56'.
    """
    if not isinstance(value, (int, float)):
        raise TypeError(f"Expected numeric value, got {type(value).__name__}")
    if math.isnan(value) or math.isinf(value):
        return "N/A"
    return f"{value:,.2f}"


def format_percentage(value: float) -> str:
    """Format a numeric value as a percentage string.

    The input is treated as a raw number (e.g. 0.085 → '8.50%').

    Args:
        value: Numeric value to format (0.0–1.0 scale, or already ×100).

    Returns:
        Formatted string, e.g. '8.50%'.
    """
    if not isinstance(value, (int, float)):
        raise TypeError(f"Expected numeric value, got {type(value).__name__}")
    if math.isnan(value) or math.isinf(value):
        return "N/A"

    # Auto-detect: if |value| > 1 assume it is already on 0–100 scale
    if abs(value) > 1.0:
        return f"{value:.2f}%"
    return f"{value * 100:.2f}%"


# ---------------------------------------------------------------------------
# Summary statistics
# ---------------------------------------------------------------------------


def generate_summary_stats(
    data: list[dict[str, Any]],
    numeric_columns: list[str],
) -> dict[str, dict[str, float]]:
    """Compute summary statistics for specified numeric columns.

    For each column the following metrics are calculated:
      count, sum, mean, median, min, max, std_dev

    Args:
        data: List of row dicts.
        numeric_columns: Column names to include in the summary.

    Returns:
        Dict mapping column name → dict of metrics.
    """
    result: dict[str, dict[str, float]] = {}

    for col in numeric_columns:
        values: list[float] = []
        for row in data:
            if col in row:
                try:
                    values.append(float(row[col]))
                except (ValueError, TypeError):
                    continue

        if not values:
            result[col] = {
                "count": 0,
                "sum": 0.0,
                "mean": 0.0,
                "median": 0.0,
                "min": 0.0,
                "max": 0.0,
                "std_dev": 0.0,
            }
            continue

        sorted_vals = sorted(values)
        n = len(sorted_vals)
        total = sum(sorted_vals)
        mean = total / n

        # Median
        if n % 2 == 1:
            median = sorted_vals[n // 2]
        else:
            median = (sorted_vals[n // 2 - 1] + sorted_vals[n // 2]) / 2

        # Standard deviation (population)
        variance = sum((v - mean) ** 2 for v in sorted_vals) / n
        std_dev = math.sqrt(variance)

        result[col] = {
            "count": n,
            "sum": round(total, 4),
            "mean": round(mean, 4),
            "median": round(median, 4),
            "min": round(sorted_vals[0], 4),
            "max": round(sorted_vals[-1], 4),
            "std_dev": round(std_dev, 4),
        }

    return result


# ---------------------------------------------------------------------------
# HTML report
# ---------------------------------------------------------------------------


def generate_html_report(
    title: str,
    data: list[dict[str, Any]],
    columns: list[str],
) -> str:
    """Generate a self-contained HTML report from tabular data.

    The output is a complete HTML document with an embedded <style> block
    for basic table styling.  All cell values are HTML-escaped.

    Args:
        title: Report heading.
        data: List of row dicts.
        columns: Column names to render (also used as headers).

    Returns:
        Complete HTML document as a string.
    """
    safe_title = html.escape(title)

    rows_html_parts: list[str] = []
    for row in data:
        cells: list[str] = []
        for col in columns:
            raw = row.get(col, "")
            cells.append(f"<td>{html.escape(str(raw))}</td>")
        rows_html_parts.append(f"<tr>{''.join(cells)}</tr>")

    header_cells = "".join(f"<th>{html.escape(col)}</th>" for col in columns)
    body = "\n".join(rows_html_parts)

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{safe_title}</title>
<style>
  body {{ font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; margin: 2rem; color: #333; }}
  h1 {{ color: #1a1a2e; }}
  table {{ border-collapse: collapse; width: 100%; margin-top: 1rem; }}
  th, td {{ border: 1px solid #ddd; padding: 0.6rem 0.8rem; text-align: left; }}
  th {{ background-color: #1a1a2e; color: #fff; }}
  tr:nth-child(even) {{ background-color: #f9f9f9; }}
  tr:hover {{ background-color: #f0f0f0; }}
</style>
</head>
<body>
<h1>{safe_title}</h1>
<table>
<thead>
<tr>{header_cells}</tr>
</thead>
<tbody>
{body}
</tbody>
</table>
</body>
</html>"""


# ---------------------------------------------------------------------------
# CSV report
# ---------------------------------------------------------------------------


def generate_csv_report(
    data: list[dict[str, Any]],
    columns: list[str],
) -> str:
    """Generate a CSV string from tabular data.

    Args:
        data: List of row dicts.
        columns: Column names (used as header row and key order).

    Returns:
        CSV content as a string.
    """
    output = io.StringIO()
    writer = csv.DictWriter(output, fieldnames=columns, extrasaction="ignore")
    writer.writeheader()

    for row in data:
        # Ensure every column has a value (empty string if missing)
        clean_row = {col: row.get(col, "") for col in columns}
        writer.writerow(clean_row)

    return output.getvalue()
