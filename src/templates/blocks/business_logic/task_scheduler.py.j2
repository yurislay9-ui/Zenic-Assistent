"""
Task Scheduler Module for {{ project_name }}
Generated by Zenic-Agents

Provides task assignment, prioritization, workload tracking,
and auto-assignment to the least loaded user.
"""

from __future__ import annotations

import sqlite3
from datetime import datetime, timezone
from typing import Any


# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

PRIORITY_LEVELS: dict[str, int] = {
    "critical": 4,
    "high": 3,
    "medium": 2,
    "low": 1,
}

VALID_PRIORITIES = set(PRIORITY_LEVELS.keys())


# ---------------------------------------------------------------------------
# Assignment
# ---------------------------------------------------------------------------


def assign_task(
    task_id: int,
    user_id: int,
    db: sqlite3.Connection,
) -> dict[str, Any]:
    """Assign a task to a specific user.

    Args:
        task_id: Primary key of the task.
        user_id: Primary key of the user to assign.
        db: Active SQLite database connection.

    Returns:
        Dict with task_id, user_id, assigned_at, and previous_assignee.

    Raises:
        ValueError: If the task or user does not exist.
    """
    cursor = db.cursor()

    # Validate task
    cursor.execute("SELECT id, assigned_to FROM tasks WHERE id = ?", (task_id,))
    task_row = cursor.fetchone()
    if task_row is None:
        raise ValueError(f"Task with id {task_id} does not exist")

    # Validate user
    cursor.execute("SELECT id FROM users WHERE id = ?", (user_id,))
    if cursor.fetchone() is None:
        raise ValueError(f"User with id {user_id} does not exist")

    previous_assignee = task_row[1]
    now = datetime.now(timezone.utc).isoformat()

    cursor.execute(
        "UPDATE tasks SET assigned_to = ?, updated_at = ? WHERE id = ?",
        (user_id, now, task_id),
    )

    # Log assignment
    cursor.execute(
        """INSERT INTO task_assignments (task_id, user_id, assigned_at)
           VALUES (?, ?, ?)""",
        (task_id, user_id, now),
    )
    db.commit()

    return {
        "task_id": task_id,
        "user_id": user_id,
        "assigned_at": now,
        "previous_assignee": previous_assignee,
    }


# ---------------------------------------------------------------------------
# Prioritization
# ---------------------------------------------------------------------------


def prioritize_tasks(tasks: list[dict[str, Any]]) -> list[dict[str, Any]]:
    """Sort tasks by priority (highest first) and then by deadline (earliest first).

    Each task dict must contain:
      - 'priority': one of the PRIORITY_LEVELS keys
      - 'deadline': ISO-8601 datetime string or None

    Args:
        tasks: List of task dicts to sort.

    Returns:
        New list sorted by priority desc, then deadline asc.
        Tasks without deadlines are placed after those with deadlines
        within the same priority level.
    """
    def _sort_key(task: dict[str, Any]) -> tuple[int, str]:
        priority_name = task.get("priority", "low")
        priority_val = PRIORITY_LEVELS.get(priority_name, 1)

        deadline = task.get("deadline")
        # Tasks with no deadline sort after those with a deadline
        if deadline is None:
            deadline_sort = "9999-12-31T23:59:59"
        else:
            deadline_sort = str(deadline)

        return (-priority_val, deadline_sort)

    return sorted(tasks, key=_sort_key)


# ---------------------------------------------------------------------------
# Workload
# ---------------------------------------------------------------------------


def get_user_workload(
    user_id: int,
    db: sqlite3.Connection,
) -> dict[str, Any]:
    """Calculate a user's current workload from their active tasks.

    Args:
        user_id: Primary key of the user.
        db: Active SQLite database connection.

    Returns:
        Dict with user_id, total_tasks, tasks_by_priority, and
        weighted_load (sum of priority weights for active tasks).

    Raises:
        ValueError: If the user does not exist.
    """
    cursor = db.cursor()

    cursor.execute("SELECT id FROM users WHERE id = ?", (user_id,))
    if cursor.fetchone() is None:
        raise ValueError(f"User with id {user_id} does not exist")

    cursor.execute(
        """SELECT priority, COUNT(*) as cnt
           FROM tasks
           WHERE assigned_to = ?
             AND status NOT IN ('done', 'cancelled')
           GROUP BY priority""",
        (user_id,),
    )
    rows = cursor.fetchall()

    tasks_by_priority: dict[str, int] = {p: 0 for p in PRIORITY_LEVELS}
    weighted_load = 0
    total_tasks = 0

    for priority, count in rows:
        if priority in PRIORITY_LEVELS:
            tasks_by_priority[priority] = count
            weighted_load += PRIORITY_LEVELS[priority] * count
            total_tasks += count

    return {
        "user_id": user_id,
        "total_tasks": total_tasks,
        "tasks_by_priority": tasks_by_priority,
        "weighted_load": weighted_load,
    }


# ---------------------------------------------------------------------------
# Auto-assignment
# ---------------------------------------------------------------------------


def auto_assign(
    task_id: int,
    db: sqlite3.Connection,
) -> dict[str, Any]:
    """Automatically assign a task to the least loaded active user.

    "Least loaded" is determined by weighted_load from get_user_workload.
    In case of a tie, the user with the lower total_tasks count wins.
    If still tied, the user with the smaller id is chosen.

    Args:
        task_id: Primary key of the task.
        db: Active SQLite database connection.

    Returns:
        Dict with task_id, assigned_to (user_id), weighted_load, and
        assigned_at.

    Raises:
        ValueError: If the task does not exist or no assignable user found.
    """
    cursor = db.cursor()

    # Validate task exists and is unassigned
    cursor.execute(
        "SELECT id, assigned_to FROM tasks WHERE id = ?",
        (task_id,),
    )
    task_row = cursor.fetchone()
    if task_row is None:
        raise ValueError(f"Task with id {task_id} does not exist")

    # Get all active users
    cursor.execute("SELECT id FROM users WHERE is_active = 1")
    user_rows = cursor.fetchall()
    if not user_rows:
        raise ValueError("No active users available for auto-assignment")

    # Compute workload for each user and pick the least loaded
    best_user_id: int | None = None
    best_weighted_load = float("inf")
    best_total_tasks = float("inf")

    for (user_id,) in user_rows:
        workload = get_user_workload(user_id, db)
        wl = workload["weighted_load"]
        tt = workload["total_tasks"]

        if (wl < best_weighted_load) or (
            wl == best_weighted_load and tt < best_total_tasks
        ):
            best_user_id = user_id
            best_weighted_load = wl
            best_total_tasks = tt

    if best_user_id is None:
        raise ValueError("Could not determine least loaded user")

    # Assign
    result = assign_task(task_id, best_user_id, db)
    result["weighted_load"] = best_weighted_load

    return result
