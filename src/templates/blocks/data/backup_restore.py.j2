Provides reliable database backup and restore with:
- Consistent SQLite backups using .backup API
- Compressed backups (gzip)
- Backup metadata tracking
- Automatic cleanup of old backups
- Scheduled backup support
"""

import os
import gzip
import shutil
import sqlite3
import logging
import json
from typing import List, Dict, Any, Optional
from datetime import datetime
from pathlib import Path

logger = logging.getLogger(__name__)


class BackupService:
    """
    Database Backup and Restore Service.

    Uses SQLite's built-in .backup API for consistent snapshots
    and gzip for compression.
    """

    def __init__(self, db_path: str, backup_dir: str = ""):
        """
        Initialize backup service.

        Args:
            db_path: Path to the SQLite database file
            backup_dir: Directory for backup storage (default: same as db_path/backups/)
        """
        self._db_path = db_path
        self._backup_dir = backup_dir or os.path.join(os.path.dirname(db_path), "backups")
        os.makedirs(self._backup_dir, exist_ok=True)

        # Ensure metadata table exists
        self._ensure_metadata_table()

    def _get_connection(self) -> sqlite3.Connection:
        """Get database connection."""
        conn = sqlite3.connect(self._db_path)
        conn.row_factory = sqlite3.Row
        return conn

    def _ensure_metadata_table(self):
        """Create backup metadata table if needed."""
        backup_db = os.path.join(self._backup_dir, "_backup_meta.sqlite")
        with sqlite3.connect(backup_db) as conn:
            conn.execute("""
                CREATE TABLE IF NOT EXISTS backup_metadata (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    backup_path TEXT NOT NULL,
                    original_db TEXT NOT NULL,
                    size_bytes INTEGER DEFAULT 0,
                    compressed INTEGER DEFAULT 1,
                    created_at TEXT NOT NULL,
                    schema_version INTEGER DEFAULT 1,
                    status TEXT DEFAULT 'completed'
                )
            """)
            conn.commit()

    # ================================================================
    #  BACKUP OPERATIONS
    # ================================================================

    def create_backup(self, compress: bool = True) -> str:
        """
        Create a consistent backup of the database.

        Uses SQLite's .backup API which provides a consistent
        snapshot even while the database is in use.

        Args:
            compress: Whether to gzip-compress the backup

        Returns:
            Path to the created backup file
        """
        timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
        db_name = os.path.splitext(os.path.basename(self._db_path))[0]
        backup_name = f"{db_name}_{timestamp}.db"
        backup_path = os.path.join(self._backup_dir, backup_name)

        # Use SQLite backup API for consistency
        source = sqlite3.connect(self._db_path)
        dest = sqlite3.connect(backup_path)
        try:
            source.backup(dest)
        finally:
            dest.close()
            source.close()

        original_size = os.path.getsize(backup_path)

        # Compress if requested
        final_path = backup_path
        if compress:
            compressed_path = backup_path + ".gz"
            with open(backup_path, 'rb') as f_in:
                with gzip.open(compressed_path, 'wb', compresslevel=6) as f_out:
                    shutil.copyfileobj(f_in, f_out)
            # Remove uncompressed backup
            os.remove(backup_path)
            final_path = compressed_path

        final_size = os.path.getsize(final_path)

        # Record metadata
        self._record_backup(final_path, original_size, compress)

        logger.info(f"BackupService: Backup created: {final_path} ({final_size:,} bytes)")
        return final_path

    def restore_backup(self, backup_path: str) -> bool:
        """
        Restore database from a backup file.

        Args:
            backup_path: Path to the backup file (.db or .db.gz)

        Returns:
            True if restore succeeded

        Raises:
            FileNotFoundError: If backup file doesn't exist
            RuntimeError: If restore fails
        """
        if not os.path.isfile(backup_path):
            raise FileNotFoundError(f"Backup not found: {backup_path}")

        # Decompress if needed
        db_backup = backup_path
        temp_file = None

        if backup_path.endswith(".gz"):
            temp_file = backup_path.replace(".gz", "")
            with gzip.open(backup_path, 'rb') as f_in:
                with open(temp_file, 'wb') as f_out:
                    shutil.copyfileobj(f_in, f_out)
            db_backup = temp_file

        try:
            # Create safety backup of current DB before overwriting
            safety_backup = self._db_path + ".pre_restore"
            if os.path.exists(self._db_path):
                shutil.copy2(self._db_path, safety_backup)

            # Restore using SQLite backup API
            source = sqlite3.connect(db_backup)
            dest = sqlite3.connect(self._db_path)
            try:
                source.backup(dest)
            except Exception as e:
                # Restore safety backup on failure
                dest.close()
                source.close()
                if os.path.exists(safety_backup):
                    shutil.copy2(safety_backup, self._db_path)
                raise RuntimeError(f"Restore failed: {e}")
            finally:
                dest.close()
                source.close()

            # Clean up safety backup
            if os.path.exists(safety_backup):
                os.remove(safety_backup)

            logger.info(f"BackupService: Restored from {backup_path}")
            return True

        finally:
            # Clean up temp decompressed file
            if temp_file and os.path.exists(temp_file):
                os.remove(temp_file)

    # ================================================================
    #  BACKUP MANAGEMENT
    # ================================================================

    def list_backups(self) -> List[Dict[str, Any]]:
        """
        List all available backups with metadata.

        Returns:
            List of backup metadata dicts, newest first
        """
        backup_db = os.path.join(self._backup_dir, "_backup_meta.sqlite")
        if not os.path.isfile(backup_db):
            return []

        with sqlite3.connect(backup_db) as conn:
            conn.row_factory = sqlite3.Row
            rows = conn.execute(
                "SELECT * FROM backup_metadata ORDER BY created_at DESC"
            ).fetchall()

        result = []
        for r in rows:
            entry = dict(r)
            # Verify backup file still exists
            entry["file_exists"] = os.path.isfile(entry["backup_path"])
            if entry["file_exists"]:
                entry["current_size"] = os.path.getsize(entry["backup_path"])
            result.append(entry)

        return result

    def cleanup_old_backups(self, max_backups: int = 10) -> int:
        """
        Remove oldest backups exceeding max_backups limit.

        Args:
            max_backups: Maximum number of backups to keep

        Returns:
            Number of backups removed
        """
        backups = self.list_backups()
        if len(backups) <= max_backups:
            return 0

        # Sort by creation date (oldest first)
        to_remove = backups[max_backups:]
        removed = 0

        for backup in to_remove:
            try:
                if os.path.isfile(backup["backup_path"]):
                    os.remove(backup["backup_path"])
                removed += 1
                logger.info(f"BackupService: Removed old backup: {backup['backup_path']}")
            except OSError as e:
                logger.error(f"BackupService: Failed to remove {backup['backup_path']}: {e}")

        return removed

    def schedule_backup(self, interval_hours: int = 24):
        """
        Set up periodic backups using APScheduler (if available).

        Args:
            interval_hours: Hours between automatic backups
        """
        try:
            from apscheduler.schedulers.background import BackgroundScheduler

            scheduler = BackgroundScheduler()
            scheduler.add_job(
                self.create_backup,
                'interval',
                hours=interval_hours,
                id='auto_backup',
                replace_existing=True,
            )
            scheduler.start()
            logger.info(f"BackupService: Scheduled backups every {interval_hours}h")

        except ImportError:
            logger.warning("BackupService: APScheduler not available for scheduled backups")

    # ================================================================
    #  INTERNAL HELPERS
    # ================================================================

    def _record_backup(self, backup_path: str, original_size: int, compressed: bool):
        """Record backup metadata."""
        backup_db = os.path.join(self._backup_dir, "_backup_meta.sqlite")
        with sqlite3.connect(backup_db) as conn:
            conn.execute(
                """INSERT INTO backup_metadata (backup_path, original_db, size_bytes, compressed, created_at, status)
                   VALUES (?, ?, ?, ?, ?, ?)""",
                (backup_path, self._db_path, original_size, int(compressed),
                 datetime.now().isoformat(), "completed")
            )
            conn.commit()

    @property
    def stats(self) -> Dict[str, Any]:
        """Backup service statistics."""
        backups = self.list_backups()
        total_size = sum(b.get("current_size", 0) for b in backups if b.get("file_exists"))
        return {
            "total_backups": len(backups),
            "total_size_bytes": total_size,
            "backup_dir": self._backup_dir,
            "db_path": self._db_path,
        }
