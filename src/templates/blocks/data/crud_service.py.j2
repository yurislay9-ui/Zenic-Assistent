"""

import re
import logging
from typing import Optional, Dict, Any, List, Tuple

logger = logging.getLogger(__name__)

# Allowed SQL types for whitelist validation
ALLOWED_SQL_TYPES = {"INTEGER", "REAL", "TEXT", "BLOB"}
ALLOWED_COLUMN_NAME_PATTERN = re.compile(r'^[a-zA-Z_][a-zA-Z0-9_]*$')
ALLOWED_TABLE_NAME_PATTERN = re.compile(r'^[a-zA-Z_][a-zA-Z0-9_]*$')


class CRUDError(Exception):
    """Base CRUD error."""
    pass


class NotFoundError(CRUDError):
    """Entity not found."""
    pass


class DuplicateError(CRUDError):
    """Duplicate entity."""
    pass


class ValidationError(CRUDError):
    """Input validation error."""
    pass


class CRUDService:
    """
    Generic CRUD service with parameterized SQL.

    Provides safe, parameterized database operations for any entity.
    Table and column names are validated against a whitelist pattern
    to prevent SQL injection while allowing dynamic queries.
    """

    def __init__(self, table_name: str, entity_name: str = "",
                 searchable_columns: List[str] = None,
                 unique_columns: List[str] = None):
        """
        Initialize CRUD service.

        Args:
            table_name: Database table name
            entity_name: Human-readable entity name
            searchable_columns: Columns that support LIKE search
            unique_columns: Columns that must be unique
        """
        if not ALLOWED_TABLE_NAME_PATTERN.match(table_name):
            raise ValueError(f"Invalid table name: {table_name}")

        self._table = table_name
        self._entity = entity_name or table_name
        self._searchable = searchable_columns or ["name"]
        self._unique = unique_columns or []

    # ================================================================
    #  READ OPERATIONS
    # ================================================================

    def list(self, search: str = "", page: int = 1, per_page: int = 20,
             filters: Dict[str, Any] = None, db_conn=None) -> Dict[str, Any]:
        """
        List entities with pagination, search, and optional filters.

        Args:
            search: Search term for LIKE queries
            page: Page number (1-based)
            per_page: Items per page
            filters: Column-value pairs for exact matching
            db_conn: Database connection module

        Returns:
            Dict with items, total, page, per_page
        """
        conditions = []
        params = []

        # Search condition
        if search and self._searchable:
            search_parts = []
            for col in self._searchable:
                if ALLOWED_COLUMN_NAME_PATTERN.match(col):
                    search_parts.append(f"{col} LIKE ?")
                    params.append(f"%{search}%")
            if search_parts:
                conditions.append(f"({' OR '.join(search_parts)})")

        # Filter conditions
        if filters:
            for col, value in filters.items():
                if ALLOWED_COLUMN_NAME_PATTERN.match(col):
                    conditions.append(f"{col} = ?")
                    params.append(value)

        where = f" WHERE {' AND '.join(conditions)}" if conditions else ""

        # Count
        count_sql = f"SELECT COUNT(*) as cnt FROM {self._table}{where}"
        count_result = db_conn.execute_query(count_sql, tuple(params))
        total = count_result[0]["cnt"] if count_result else 0

        # Fetch page
        offset = (page - 1) * per_page
        list_sql = f"SELECT * FROM {self._table}{where} ORDER BY id DESC LIMIT ? OFFSET ?"
        params.extend([per_page, offset])
        items = db_conn.execute_query(list_sql, tuple(params))

        return {
            "items": items,
            "total": total,
            "page": page,
            "per_page": per_page,
            "pages": (total + per_page - 1) // per_page if per_page > 0 else 0,
        }

    def get_by_id(self, item_id: int, db_conn=None) -> Optional[Dict[str, Any]]:
        """
        Get a single entity by ID.

        Args:
            item_id: Entity ID
            db_conn: Database connection module

        Returns:
            Entity dict or None if not found
        """
        results = db_conn.execute_query(
            f"SELECT * FROM {self._table} WHERE id = ?",
            (item_id,)
        )
        return results[0] if results else None

    def exists(self, item_id: int, db_conn=None) -> bool:
        """Check if an entity exists by ID."""
        results = db_conn.execute_query(
            f"SELECT 1 as exists_flag FROM {self._table} WHERE id = ? LIMIT 1",
            (item_id,)
        )
        return bool(results)

    # ================================================================
    #  WRITE OPERATIONS
    # ================================================================

    def create(self, data: Dict[str, Any], db_conn=None) -> int:
        """
        Create a new entity.

        Args:
            data: Column-value pairs for the new entity
            db_conn: Database connection module

        Returns:
            ID of the created entity

        Raises:
            DuplicateError: If unique constraint violated
            ValidationError: If data is invalid
        """
        if not data:
            raise ValidationError("No data provided for creation")

        # Validate and sanitize column names
        columns, values = self._validate_and_extract(data)

        # Check unique constraints
        for col in self._unique:
            if col in data:
                existing = db_conn.execute_query(
                    f"SELECT id FROM {self._table} WHERE {col} = ?",
                    (data[col],)
                )
                if existing:
                    raise DuplicateError(f"{self._entity} with {col}='{data[col]}' already exists")

        # Insert with parameterized query
        placeholders = ", ".join(["?"] * len(values))
        cols_str = ", ".join(columns)
        sql = f"INSERT INTO {self._table} ({cols_str}) VALUES ({placeholders})"

        return db_conn.execute_insert(sql, tuple(values))

    def update(self, item_id: int, data: Dict[str, Any], db_conn=None) -> int:
        """
        Update an existing entity.

        Args:
            item_id: Entity ID to update
            data: Column-value pairs to update
            db_conn: Database connection module

        Returns:
            Number of rows affected

        Raises:
            NotFoundError: If entity not found
            ValidationError: If data is invalid
        """
        if not data:
            raise ValidationError("No data provided for update")

        if not self.exists(item_id, db_conn=db_conn):
            raise NotFoundError(f"{self._entity} with id={item_id} not found")

        # Validate and sanitize column names
        columns, values = self._validate_and_extract(data)

        # Check unique constraints (excluding self)
        for col in self._unique:
            if col in data:
                existing = db_conn.execute_query(
                    f"SELECT id FROM {self._table} WHERE {col} = ? AND id != ?",
                    (data[col], item_id)
                )
                if existing:
                    raise DuplicateError(f"{self._entity} with {col}='{data[col]}' already exists")

        # Build UPDATE with parameterized query
        set_parts = [f"{col} = ?" for col in columns]
        sql = f"UPDATE {self._table} SET {', '.join(set_parts)} WHERE id = ?"
        values.append(item_id)

        return db_conn.execute_update(sql, tuple(values))

    def delete(self, item_id: int, db_conn=None) -> int:
        """
        Delete an entity by ID.

        Args:
            item_id: Entity ID to delete
            db_conn: Database connection module

        Returns:
            Number of rows affected

        Raises:
            NotFoundError: If entity not found
        """
        if not self.exists(item_id, db_conn=db_conn):
            raise NotFoundError(f"{self._entity} with id={item_id} not found")

        return db_conn.execute_update(
            f"DELETE FROM {self._table} WHERE id = ?",
            (item_id,)
        )

    # ================================================================
    #  BULK OPERATIONS
    # ================================================================

    def count(self, search: str = "", db_conn=None) -> int:
        """Count total entities, optionally filtered by search."""
        if search and self._searchable:
            search_parts = []
            params = []
            for col in self._searchable:
                if ALLOWED_COLUMN_NAME_PATTERN.match(col):
                    search_parts.append(f"{col} LIKE ?")
                    params.append(f"%{search}%")
            where = f" WHERE {' OR '.join(search_parts)}"
            result = db_conn.execute_query(f"SELECT COUNT(*) as cnt FROM {self._table}{where}", tuple(params))
        else:
            result = db_conn.execute_query(f"SELECT COUNT(*) as cnt FROM {self._table}")

        return result[0]["cnt"] if result else 0

    def bulk_create(self, data_list: List[Dict[str, Any]], db_conn=None) -> List[int]:
        """Create multiple entities in a single transaction."""
        ids = []
        for data in data_list:
            item_id = self.create(data, db_conn=db_conn)
            ids.append(item_id)
        return ids

    def bulk_delete(self, ids: List[int], db_conn=None) -> int:
        """Delete multiple entities by IDs."""
        if not ids:
            return 0
        placeholders = ", ".join(["?"] * len(ids))
        return db_conn.execute_update(
            f"DELETE FROM {self._table} WHERE id IN ({placeholders})",
            tuple(ids)
        )

    # ================================================================
    #  VALIDATION
    # ================================================================

    @staticmethod
    def _validate_and_extract(data: Dict[str, Any]) -> Tuple[List[str], List[Any]]:
        """
        Validate column names and extract values.

        Only allows alphanumeric + underscore column names.
        Returns (validated_columns, values_list).
        """
        columns = []
        values = []

        for col, value in data.items():
            if not ALLOWED_COLUMN_NAME_PATTERN.match(col):
                logger.warning(f"CRUDService: Skipping invalid column name: {col}")
                continue
            if col == "id":
                continue  # Never allow overwriting id
            columns.append(col)
            values.append(value)

        return columns, values

    @staticmethod
    def sanitize_string(value: str) -> str:
        """Sanitize a string value for safe storage."""
        if not isinstance(value, str):
            return value
        # Strip leading/trailing whitespace
        value = value.strip()
        # Remove null bytes
        value = value.replace('\x00', '')
        return value
