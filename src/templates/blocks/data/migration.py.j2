import os
import sqlite3
import logging
from typing import List, Optional, Dict, Any
from dataclasses import dataclass, field
from datetime import datetime
from pathlib import Path

logger = logging.getLogger(__name__)


@dataclass
class Migration:
    """A single database migration."""
    version: int
    description: str
    up_sql: List[str] = field(default_factory=list)
    down_sql: List[str] = field(default_factory=list)

    def __lt__(self, other):
        return self.version < other.version


class MigrationManager:
    """
    Database Migration Manager.

    Tracks applied migrations in a _migrations table and
    applies pending migrations in version order within
    atomic transactions.
    """

    def __init__(self, db_path: str):
        """
        Initialize migration manager.

        Args:
            db_path: Path to the SQLite database file
        """
        self._db_path = db_path
        self._migrations: Dict[int, Migration] = {}
        self._ensure_migration_table()

    def _get_connection(self) -> sqlite3.Connection:
        """Get a database connection."""
        conn = sqlite3.connect(self._db_path)
        conn.row_factory = sqlite3.Row
        conn.execute("PRAGMA foreign_keys=ON")
        return conn

    def _ensure_migration_table(self):
        """Create the migration tracking table if it doesn't exist."""
        with self._get_connection() as conn:
            conn.execute("""
                CREATE TABLE IF NOT EXISTS _migrations (
                    version INTEGER PRIMARY KEY,
                    description TEXT NOT NULL,
                    applied_at TEXT NOT NULL,
                    rollback_at TEXT DEFAULT NULL
                )
            """)
            conn.commit()

    # ================================================================
    #  MIGRATION REGISTRATION
    # ================================================================

    def register(self, migration: Migration):
        """
        Register a migration.

        Args:
            migration: Migration object to register
        """
        if migration.version in self._migrations:
            logger.warning(f"MigrationManager: Version {migration.version} already registered, overwriting")
        self._migrations[migration.version] = migration

    def register_many(self, migrations: List[Migration]):
        """Register multiple migrations."""
        for m in migrations:
            self.register(m)

    # ================================================================
    #  MIGRATION EXECUTION
    # ================================================================

    def migrate(self) -> List[str]:
        """
        Run all pending migrations in version order.

        Each migration runs within its own transaction.
        If a migration fails, it is rolled back and an error is raised.

        Returns:
            List of applied migration descriptions
        """
        pending = self.get_pending()
        applied = []

        for migration in pending:
            try:
                self._apply_migration(migration)
                applied.append(f"v{migration.version}: {migration.description}")
                logger.info(f"MigrationManager: Applied v{migration.version} - {migration.description}")
            except Exception as e:
                logger.error(f"MigrationManager: Failed v{migration.version}: {e}")
                raise RuntimeError(f"Migration v{migration.version} failed: {e}") from e

        return applied

    def rollback(self, steps: int = 1) -> List[str]:
        """
        Rollback the last N applied migrations.

        Args:
            steps: Number of migrations to rollback

        Returns:
            List of rolled back migration descriptions
        """
        applied = self.get_applied()
        rolled_back = []

        # Rollback in reverse order
        for migration in reversed(applied[-steps:]):
            try:
                self._rollback_migration(migration)
                rolled_back.append(f"v{migration.version}: {migration.description}")
                logger.info(f"MigrationManager: Rolled back v{migration.version} - {migration.description}")
            except Exception as e:
                logger.error(f"MigrationManager: Rollback failed v{migration.version}: {e}")
                raise RuntimeError(f"Rollback v{migration.version} failed: {e}") from e

        return rolled_back

    def _apply_migration(self, migration: Migration):
        """Apply a single migration within a transaction."""
        with self._get_connection() as conn:
            try:
                # Execute each SQL statement
                for sql in migration.up_sql:
                    conn.execute(sql)

                # Record migration
                conn.execute(
                    "INSERT INTO _migrations (version, description, applied_at) VALUES (?, ?, ?)",
                    (migration.version, migration.description, datetime.now().isoformat())
                )
                conn.commit()
            except Exception:
                conn.rollback()
                raise

    def _rollback_migration(self, migration: Migration):
        """Rollback a single migration within a transaction."""
        with self._get_connection() as conn:
            try:
                for sql in migration.down_sql:
                    conn.execute(sql)

                # Mark as rolled back
                conn.execute(
                    "DELETE FROM _migrations WHERE version = ?",
                    (migration.version,)
                )
                conn.commit()
            except Exception:
                conn.rollback()
                raise

    # ================================================================
    #  MIGRATION QUERIES
    # ================================================================

    def get_current_version(self) -> int:
        """Get the current database schema version."""
        with self._get_connection() as conn:
            row = conn.execute(
                "SELECT MAX(version) as v FROM _migrations"
            ).fetchone()
            return row["v"] if row and row["v"] is not None else 0

    def get_pending(self) -> List[Migration]:
        """Get migrations that haven't been applied yet."""
        current = self.get_current_version()
        return sorted([m for m in self._migrations.values() if m.version > current])

    def get_applied(self) -> List[Migration]:
        """Get migrations that have been applied."""
        current = self.get_current_version()
        return sorted([m for m in self._migrations.values() if m.version <= current])

    def get_history(self) -> List[Dict[str, Any]]:
        """Get full migration history from the database."""
        with self._get_connection() as conn:
            rows = conn.execute(
                "SELECT version, description, applied_at, rollback_at FROM _migrations ORDER BY version"
            ).fetchall()
            return [dict(r) for r in rows]

    @property
    def stats(self) -> Dict[str, Any]:
        """Migration statistics."""
        return {
            "current_version": self.get_current_version(),
            "registered_migrations": len(self._migrations),
            "pending_migrations": len(self.get_pending()),
            "applied_migrations": len(self.get_applied()),
        }
