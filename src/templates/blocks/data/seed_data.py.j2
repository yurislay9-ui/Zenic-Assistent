    @staticmethod
    def generate_name() -> str:
        """Generate a random full name."""
        return f"{random.choice(FIRST_NAMES)} {random.choice(LAST_NAMES)}"

    @staticmethod
    def generate_email(first_name: str = "", last_name: str = "") -> str:
        """Generate a realistic email from name parts."""
        if not first_name:
            first_name = random.choice(FIRST_NAMES).lower()
        if not last_name:
            last_name = random.choice(LAST_NAMES).lower()

        first = first_name.lower().replace(" ", "")
        last = last_name.lower().replace(" ", "")
        domains = ["gmail.com", "yahoo.com", "outlook.com", "company.com", "empresa.cl"]

        patterns = [
            f"{first}.{last}",
            f"{first}{last}",
            f"{first}_{last}",
            f"{first[0]}{last}",
            f"{first}{random.randint(1, 99)}",
        ]

        return f"{random.choice(patterns)}@{random.choice(domains)}"

    @staticmethod
    def generate_phone() -> str:
        """Generate a realistic phone number."""
        area = random.choice(["+56", "+54", "+52", "+57", "+51"])
        number = f"{random.randint(100, 999)}{random.randint(100, 999)}{random.randint(100, 999)}"
        return f"{area} {number[:3]} {number[3:]}"

    @staticmethod
    def generate_address() -> str:
        """Generate a realistic street address."""
        streets = ["Av. Principal", "Calle Central", "Blvd. Norte", "Pasaje Sur",
