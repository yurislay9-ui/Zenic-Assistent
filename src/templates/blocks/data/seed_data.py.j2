    # ================================================================
    #  DATABASE INSERTION
    # ================================================================

    @classmethod
    def insert_seed_data(cls, table: str, data: List[Dict[str, Any]],
                         db_conn) -> int:
        """
        Insert seed data using parameterized SQL.

        Args:
            table: Target table name
            data: List of dicts with column-value pairs
            db_conn: Database connection with execute_insert

        Returns:
            Number of rows inserted
        """
        if not data:
            return 0

        inserted = 0
        columns = list(data[0].keys())
        cols_str = ", ".join(columns)
        placeholders = ", ".join(["?"] * len(columns))
        sql = f"INSERT OR IGNORE INTO {table} ({cols_str}) VALUES ({placeholders})"

        for row in data:
            try:
                values = tuple(row.get(col) for col in columns)
                db_conn.execute_insert(sql, values)
                inserted += 1
            except Exception as e:
                logger.warning(f"SeedService: Failed to insert into {table}: {e}")

        logger.info(f"SeedService: Inserted {inserted}/{len(data)} rows into {table}")
        return inserted

    @classmethod
    def clear_seed_data(cls, table: str, db_conn) -> int:
        """
        Clear all data from a table (use with caution!).

        Args:
            table: Table to clear
            db_conn: Database connection

        Returns:
            Number of rows deleted
        """
        try:
            count_result = db_conn.execute_query(f"SELECT COUNT(*) as cnt FROM {table}")
            count = count_result[0]["cnt"] if count_result else 0
            db_conn.execute_update(f"DELETE FROM {table}")
            logger.info(f"SeedService: Cleared {count} rows from {table}")
            return count
        except Exception as e:
            logger.error(f"SeedService: Failed to clear {table}: {e}")
            return 0

