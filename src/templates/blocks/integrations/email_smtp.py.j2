"""
Email SMTP Integration Block for Zenic-Agents
=============================================
Production-ready async email service with connection pooling,
retry logic, HTML support, and optional attachments.

Configuration (environment variables or config dict):
  SMTP_HOST     - SMTP server hostname
  SMTP_PORT     - SMTP server port (default: 587)
  SMTP_USER     - SMTP username
  SMTP_PASSWORD - SMTP password
  SMTP_FROM     - Default sender address
  SMTP_USE_TLS  - Enable TLS (default: True)
"""

import asyncio
import os
import ssl
from email.message import EmailMessage
from email.mime.multipart import MIMEMultipart
from email.mime.text import MIMEText
from email.mime.base import MIMEBase
from email import encoders
from pathlib import Path
from typing import Any, Optional, Union

import aiosmtplib
from jinja2 import Environment, FileSystemLoader, select_autoescape


class EmailService:
    """Async email service with connection pooling, retries, and template support."""

    def __init__(self, config: dict) -> None:
        """
        Initialize the email service.

        Args:
            config: Dictionary with keys: host, port, user, password,
                    from_email (optional), use_tls (optional).
                    Falls back to environment variables if not provided.
        """
        self.host: str = config.get("host") or os.environ["SMTP_HOST"]
        self.port: int = int(config.get("port") or os.environ.get("SMTP_PORT", 587))
        self.user: str = config.get("user") or os.environ["SMTP_USER"]
        self.password: str = config.get("password") or os.environ["SMTP_PASSWORD"]
        self.from_email: str = (
            config.get("from_email")
            or os.environ.get("SMTP_FROM")
            or self.user
        )
        self.use_tls: bool = (
            config.get("use_tls", True)
            if config.get("use_tls") is not None
            else os.environ.get("SMTP_USE_TLS", "true").lower() == "true"
        )

        # Connection pool — reuse a single SMTP connection across concurrent sends
        self._connection: Optional[aiosmtplib.SMTP] = None
        self._lock = asyncio.Lock()

        # Template engine for send_template
        template_dir = config.get("template_dir") or os.environ.get(
            "SMTP_TEMPLATE_DIR", "templates/email"
        )
        self._jinja_env = Environment(
            loader=FileSystemLoader(template_dir),
            autoescape=select_autoescape(["html", "xml"]),
        )

        # Retry settings
        self._max_retries: int = int(
            config.get("max_retries") or os.environ.get("SMTP_MAX_RETRIES", 3)
        )
        self._backoff_base: float = float(
            config.get("backoff_base") or os.environ.get("SMTP_BACKOFF_BASE", 2.0)
        )

    # ------------------------------------------------------------------
    # Connection management
    # ------------------------------------------------------------------

    async def _get_connection(self) -> aiosmtplib.SMTP:
        """Return a connected SMTP client, creating one if necessary."""
        async with self._lock:
            if self._connection is not None:
                try:
                    # Verify the connection is still alive
                    await self._connection.noop()
                    return self._connection
                except (aiosmtplib.SMTPException, ConnectionError, OSError):
                    await self._disconnect()

            client = aiosmtplib.SMTP(
                hostname=self.host,
                port=self.port,
                use_tls=self.use_tls,
            )
            await client.connect()
            if not self.use_tls:
                await client.starttls()
            await client.login(self.user, self.password)
            self._connection = client
            return self._connection

    async def _disconnect(self) -> None:
        """Close and discard the pooled connection."""
        if self._connection is not None:
            try:
                await self._connection.quit()
            except Exception:
                pass
            self._connection = None

    async def close(self) -> None:
        """Public cleanup — call this when shutting down the service."""
        await self._disconnect()

    # ------------------------------------------------------------------
    # Public API
    # ------------------------------------------------------------------

    async def send(
        self,
        to: str,
        subject: str,
        body: str,
        html: str = "",
        cc: Optional[list[str]] = None,
        bcc: Optional[list[str]] = None,
        attachments: Optional[list[dict]] = None,
    ) -> dict:
        """
        Send an email.

        Args:
            to:          Recipient address.
            subject:     Email subject line.
            body:        Plain-text body.
            html:        Optional HTML body.
            cc:          Optional list of CC addresses.
            bcc:         Optional list of BCC addresses.
            attachments: Optional list of dicts with keys:
                         - path (str): file path, OR
                         - content (bytes): raw bytes
                         - filename (str): name for the attachment
                         - mime_type (str): e.g. "application/pdf"

        Returns:
            dict with keys: success (bool), message_id (str|None), error (str|None)
        """
        message = self._create_message(
            to=to,
            subject=subject,
            body=body,
            html=html,
            cc=cc,
            bcc=bcc,
            attachments=attachments,
        )
        return await self._send_with_retry(message, [to] + (cc or []) + (bcc or []))

    async def send_template(
        self, to: str, template_name: str, data: dict
    ) -> dict:
        """
        Send an email rendered from a Jinja2 template pair.

        The template pair must consist of:
          - <template_name>.txt  (plain-text)
          - <template_name>.html (HTML)

        Args:
            to:            Recipient address.
            template_name: Name of the template (without extension).
            data:          Context variables for rendering.

        Returns:
            dict with keys: success, message_id, error
        """
        body = self._render_template(f"{template_name}.txt", data)
        html = self._render_template(f"{template_name}.html", data)
        subject = data.get("subject", f"Notification — {template_name}")
        return await self.send(to=to, subject=subject, body=body, html=html)

    # ------------------------------------------------------------------
    # Internal helpers
    # ------------------------------------------------------------------

    def _render_template(self, template: str, data: dict) -> str:
        """
        Render a Jinja2 email template with the given context data.

        Args:
            template: Template file name relative to template_dir.
            data:     Context variables.

        Returns:
            Rendered string.

        Raises:
            FileNotFoundError: If the template does not exist.
        """
        tmpl = self._jinja_env.get_template(template)
        return tmpl.render(**data)

    def _create_message(
        self,
        to: str,
        subject: str,
        body: str,
        html: str = "",
        cc: Optional[list[str]] = None,
        bcc: Optional[list[str]] = None,
        attachments: Optional[list[dict]] = None,
    ) -> EmailMessage:
        """
        Build an EmailMessage (or MIMEMultipart) ready for sending.

        Args:
            to:           Recipient address.
            subject:      Subject line.
            body:         Plain-text body.
            html:         Optional HTML body.
            cc:           Optional CC list.
            bcc:          Optional BCC list.
            attachments:  Optional attachment list.

        Returns:
            An EmailMessage or MIMEMultipart object.
        """
        has_html = bool(html)
        has_attachments = bool(attachments)

        if has_attachments:
            msg = MIMEMultipart("mixed")
        else:
            msg = EmailMessage()

        msg["From"] = self.from_email
        msg["To"] = to
        msg["Subject"] = subject
        if cc:
            msg["Cc"] = ", ".join(cc)
        if bcc:
            msg["Bcc"] = ", ".join(bcc)

        # --- Body ---
        if has_attachments:
            # Wrap the text/html into a related part, then attach files
            alt_part = MIMEMultipart("alternative")
            alt_part.attach(MIMEText(body, "plain", "utf-8"))
            if has_html:
                alt_part.attach(MIMEText(html, "html", "utf-8"))
            msg.attach(alt_part)

            for att in attachments:
                part = MIMEBase(
                    att.get("mime_type", "application/octet-stream").split("/")[0],
                    att.get("mime_type", "application/octet-stream").split("/")[1],
                )
                if "content" in att:
                    part.set_payload(att["content"])
                elif "path" in att:
                    file_path = Path(att["path"])
                    part.set_payload(file_path.read_bytes())
                else:
                    continue
                encoders.encode_base64(part)
                part.add_header(
                    "Content-Disposition",
                    f'attachment; filename="{att.get("filename", "attachment")}"',
                )
                msg.attach(part)
        else:
            msg.set_content(body, subtype="plain", charset="utf-8")
            if has_html:
                msg.add_alternative(html, subtype="html", charset="utf-8")

        return msg

    async def _send_with_retry(
        self, message: EmailMessage, recipients: list[str]
    ) -> dict:
        """
        Attempt to send *message* with exponential-backoff retries.

        Args:
            message:    Fully constructed email message.
            recipients: Flat list of all recipient addresses.

        Returns:
            dict: {success: bool, message_id: str|None, error: str|None}
        """
        last_error: Optional[str] = None

        for attempt in range(1, self._max_retries + 1):
            try:
                client = await self._get_connection()
                await client.send_message(message)
                message_id = message.get("Message-ID", None)
                return {"success": True, "message_id": message_id, "error": None}
            except (
                aiosmtplib.SMTPException,
                ConnectionError,
                OSError,
                asyncio.TimeoutError,
            ) as exc:
                last_error = str(exc)
                # Force reconnection on next attempt
                await self._disconnect()
                if attempt < self._max_retries:
                    delay = self._backoff_base ** attempt
                    await asyncio.sleep(delay)

        return {"success": False, "message_id": None, "error": last_error}
