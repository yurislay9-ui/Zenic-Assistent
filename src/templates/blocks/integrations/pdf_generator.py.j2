"""
PDF Generator Integration Block for Zenic-Agents
=================================================
Production-ready PDF generation from HTML and Jinja2 templates using
WeasyPrint. Includes built-in invoice generation with professional styling.

Configuration (environment variables or constructor args):
  PDF_TEMPLATE_DIR - Default directory for Jinja2 HTML templates
  PDF_CSS_PATH     - Default CSS stylesheet path (optional)
"""

import os
from datetime import datetime
from pathlib import Path
from typing import Any, Optional

from jinja2 import Environment, FileSystemLoader, select_autoescape
from weasyprint import HTML, CSS


class PDFGenerator:
    """Generate PDF documents from HTML strings, templates, or structured data."""

    def __init__(
        self,
        template_dir: Optional[str] = None,
        css_path: Optional[str] = None,
    ) -> None:
        """
        Initialise the PDF generator.

        Args:
            template_dir: Directory containing Jinja2 HTML templates.
                          Falls back to PDF_TEMPLATE_DIR env var or "templates/pdf".
            css_path:     Path to a default CSS stylesheet.
                          Falls back to PDF_CSS_PATH env var.
        """
        self._template_dir: str = (
            template_dir
            or os.environ.get("PDF_TEMPLATE_DIR")
            or "templates/pdf"
        )
        self._css_path: Optional[str] = (
            css_path or os.environ.get("PDF_CSS_PATH") or None
        )

        self._jinja_env = Environment(
            loader=FileSystemLoader(self._template_dir),
            autoescape=select_autoescape(["html", "xml"]),
        )

    # ------------------------------------------------------------------
    # Core generation
    # ------------------------------------------------------------------

    def generate_from_html(
        self,
        html: str,
        output_path: str,
        css: Optional[str] = None,
        base_url: Optional[str] = None,
    ) -> str:
        """
        Convert a raw HTML string to a PDF file.

        Args:
            html:        HTML content string.
            output_path: Destination file path for the PDF.
            css:         Optional CSS string or path to CSS file.
            base_url:    Base URL for resolving relative paths in the HTML.

        Returns:
            Absolute path to the generated PDF file.

        Raises:
            OSError: If the output directory does not exist or cannot be written.
        """
        output = Path(output_path)
        output.parent.mkdir(parents=True, exist_ok=True)

        stylesheets = self._build_stylesheets(css)

        weasy_html = HTML(
            string=html,
            base_url=base_url or str(output.parent.resolve()),
        )
        weasy_html.write_pdf(
            target=str(output),
            stylesheets=stylesheets,
        )
        return str(output.resolve())

    def generate_from_template(
        self,
        template_name: str,
        data: dict,
        output_path: str,
        css: Optional[str] = None,
        base_url: Optional[str] = None,
    ) -> str:
        """
        Render a Jinja2 template to PDF.

        Args:
            template_name: Template file name (relative to template_dir).
            data:          Context variables for rendering.
            output_path:   Destination file path for the PDF.
            css:           Optional CSS override.
            base_url:      Base URL for resolving relative paths.

        Returns:
            Absolute path to the generated PDF file.
        """
        tmpl = self._jinja_env.get_template(template_name)
        html = tmpl.render(**data)
        return self.generate_from_html(
            html=html,
            output_path=output_path,
            css=css,
            base_url=base_url,
        )

    # ------------------------------------------------------------------
    # Invoice generation
    # ------------------------------------------------------------------

    def generate_invoice(
        self,
        invoice_data: dict,
        output_path: str,
        css: Optional[str] = None,
    ) -> str:
        """
        Generate a professional invoice PDF.

        *invoice_data* should contain:
          - invoice_number (str)
          - date (str, optional — defaults to today)
          - due_date (str, optional)
          - from_name, from_address, from_email (str)
          - to_name, to_address, to_email (str)
          - items: list of {description, quantity, unit_price}
          - currency (str, default "USD")
          - tax_rate (float, default 0.0)
          - notes (str, optional)
          - payment_details (str, optional)

        Args:
            invoice_data: Structured invoice information.
            output_path:  Destination file path.
            css:          Optional CSS override.

        Returns:
            Absolute path to the generated PDF file.
        """
        enriched = self._prepare_invoice_data(invoice_data)
        html = self._render_invoice_html(enriched)
        default_css = self._invoice_css()
        return self.generate_from_html(
            html=html,
            output_path=output_path,
            css=css or default_css,
        )

    # ------------------------------------------------------------------
    # Internal helpers
    # ------------------------------------------------------------------

    def _build_stylesheets(self, css: Optional[str] = None) -> list:
        """
        Build the list of WeasyPrint stylesheet objects.

        Priority order:
          1. Default CSS file (if configured)
          2. Caller-supplied CSS (string or file path)

        Args:
            css: Optional CSS string or path.

        Returns:
            List of CSS objects (may be empty).
        """
        stylesheets: list = []

        # Default stylesheet
        if self._css_path and Path(self._css_path).is_file():
            stylesheets.append(CSS(filename=self._css_path))

        # Caller-supplied stylesheet
        if css:
            css_path = Path(css)
            if css_path.is_file():
                stylesheets.append(CSS(filename=str(css_path)))
            else:
                stylesheets.append(CSS(string=css))

        return stylesheets

    @staticmethod
    def _prepare_invoice_data(data: dict) -> dict:
        """Compute derived invoice fields (subtotal, tax, total)."""
        items = data.get("items", [])
        currency = data.get("currency", "USD")
        tax_rate = float(data.get("tax_rate", 0.0))

        subtotal = 0.0
        line_items = []
        for item in items:
            qty = float(item.get("quantity", 1))
            unit_price = float(item.get("unit_price", 0))
            line_total = qty * unit_price
            subtotal += line_total
            line_items.append(
                {
                    "description": item.get("description", ""),
                    "quantity": qty,
                    "unit_price": unit_price,
                    "line_total": line_total,
                }
            )

        tax_amount = subtotal * (tax_rate / 100.0)
        total = subtotal + tax_amount

        return {
            **data,
            "items": line_items,
            "subtotal": subtotal,
            "tax_rate": tax_rate,
            "tax_amount": tax_amount,
            "total": total,
            "currency": currency,
            "date": data.get("date", datetime.now().strftime("%Y-%m-%d")),
            "due_date": data.get("due_date", ""),
        }

    @staticmethod
    def _render_invoice_html(data: dict) -> str:
        """Render an invoice to a self-contained HTML string."""
        currency_symbol = {"USD": "$", "EUR": "€", "GBP": "£"}.get(
            data["currency"], data["currency"]
        )

        items_rows = ""
        for item in data["items"]:
            items_rows += (
                f"<tr>"
                f"<td>{item['description']}</td>"
                f"<td class='num'>{item['quantity']}</td>"
                f"<td class='num'>{currency_symbol}{item['unit_price']:.2f}</td>"
                f"<td class='num'>{currency_symbol}{item['line_total']:.2f}</td>"
                f"</tr>"
            )

        tax_row = ""
        if data["tax_rate"] > 0:
            tax_row = (
                f"<tr class='summary-row'>"
                f"<td colspan='3'>Tax ({data['tax_rate']:.1f}%)</td>"
                f"<td class='num'>{currency_symbol}{data['tax_amount']:.2f}</td>"
                f"</tr>"
            )

        return f"""<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Invoice {data['invoice_number']}</title>
</head>
<body>
  <div class="invoice">
    <header class="invoice-header">
      <div class="invoice-title">
        <h1>INVOICE</h1>
        <p class="invoice-number">#{data['invoice_number']}</p>
      </div>
      <div class="invoice-dates">
        <p><strong>Date:</strong> {data['date']}</p>
        {"<p><strong>Due:</strong> " + data['due_date'] + "</p>" if data.get('due_date') else ""}
      </div>
    </header>

    <section class="parties">
      <div class="party from">
        <h3>From</h3>
        <p>{data.get('from_name', '')}</p>
        <p>{data.get('from_address', '')}</p>
        <p>{data.get('from_email', '')}</p>
      </div>
      <div class="party to">
        <h3>To</h3>
        <p>{data.get('to_name', '')}</p>
        <p>{data.get('to_address', '')}</p>
        <p>{data.get('to_email', '')}</p>
      </div>
    </section>

    <table class="items">
      <thead>
        <tr>
          <th>Description</th>
          <th class='num'>Qty</th>
          <th class='num'>Unit Price</th>
          <th class='num'>Amount</th>
        </tr>
      </thead>
      <tbody>
        {items_rows}
      </tbody>
      <tfoot>
        <tr class='summary-row'>
          <td colspan='3'>Subtotal</td>
          <td class='num'>{currency_symbol}{data['subtotal']:.2f}</td>
        </tr>
        {tax_row}
        <tr class='total-row'>
          <td colspan='3'><strong>Total</strong></td>
          <td class='num'><strong>{currency_symbol}{data['total']:.2f}</strong></td>
        </tr>
      </tfoot>
    </table>

    {"<section class='notes'><h3>Notes</h3><p>" + data['notes'] + "</p></section>" if data.get('notes') else ""}
    {"<section class='payment-details'><h3>Payment Details</h3><p>" + data['payment_details'] + "</p></section>" if data.get('payment_details') else ""}
  </div>
</body>
</html>"""

    @staticmethod
    def _invoice_css() -> str:
        """Return a professional default invoice stylesheet."""
        return """
        @page {
            size: A4;
            margin: 2cm;
        }
        body {
            font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
            color: #333;
            line-height: 1.5;
            font-size: 11pt;
        }
        .invoice {
            max-width: 100%;
        }
        .invoice-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 2rem;
            border-bottom: 3px solid #2563eb;
            padding-bottom: 1rem;
        }
        .invoice-title h1 {
            margin: 0;
            font-size: 28pt;
            color: #2563eb;
            letter-spacing: 2px;
        }
        .invoice-number {
            margin: 0;
            color: #666;
            font-size: 12pt;
        }
        .invoice-dates {
            text-align: right;
        }
        .invoice-dates p {
            margin: 0.2em 0;
        }
        .parties {
            display: flex;
            justify-content: space-between;
            margin-bottom: 2rem;
        }
        .party {
            width: 45%;
        }
        .party h3 {
            margin: 0 0 0.5em 0;
            font-size: 10pt;
            text-transform: uppercase;
            color: #888;
            letter-spacing: 1px;
        }
        .party p {
            margin: 0.1em 0;
        }
        .items {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 1rem;
        }
        .items th {
            background-color: #f8fafc;
            text-align: left;
            padding: 0.6em 0.8em;
            font-size: 9pt;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #64748b;
            border-bottom: 2px solid #e2e8f0;
        }
        .items td {
            padding: 0.6em 0.8em;
            border-bottom: 1px solid #e2e8f0;
        }
        .items .num {
            text-align: right;
        }
        .summary-row td {
            border-bottom: none;
        }
        .total-row td {
            border-top: 2px solid #2563eb;
            font-size: 13pt;
            padding-top: 0.8em;
        }
        .notes, .payment-details {
            margin-top: 2rem;
            padding-top: 1rem;
            border-top: 1px solid #e2e8f0;
        }
        .notes h3, .payment-details h3 {
            font-size: 10pt;
            text-transform: uppercase;
            color: #888;
            letter-spacing: 1px;
        }
        """
