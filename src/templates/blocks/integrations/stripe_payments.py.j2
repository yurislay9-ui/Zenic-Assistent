"""
Stripe Payments Integration Block for Zenic-Agents
==================================================
Production-ready async Stripe integration for payment intents,
customers, subscriptions, and webhook verification.

Configuration (environment variables or constructor args):
  STRIPE_API_KEY       - Stripe secret key
  STRIPE_WEBHOOK_SECRET - Secret for webhook signature verification
"""

import hashlib
import hmac
import os
import time
import uuid
from typing import Any, Optional

import stripe


class StripeService:
    """Async Stripe client with idempotency, retries, and webhook verification."""

    _MAX_RETRIES: int = 3
    _BACKOFF_BASE: float = 2.0

    def __init__(self, api_key: Optional[str] = None) -> None:
        """
        Initialise the Stripe service.

        Args:
            api_key: Stripe secret key. Falls back to STRIPE_API_KEY env var.
        """
        self.api_key: str = api_key or os.environ["STRIPE_API_KEY"]
        stripe.api_key = self.api_key
        # Use the async-friendly stripe interface
        self._webhook_secret: str = os.environ.get("STRIPE_WEBHOOK_SECRET", "")

    # ------------------------------------------------------------------
    # Helpers
    # ------------------------------------------------------------------

    @staticmethod
    def _idempotency_key(prefix: str = "zenic") -> str:
        """Generate a deterministic-unique idempotency key."""
        return f"{prefix}-{uuid.uuid4()}"

    async def _with_retry(self, fn, **kwargs):
        """
        Execute a Stripe SDK call with exponential-backoff retries.

        Retries are only applied on transient errors (rate-limit, connection,
        API connection errors). Non-retryable StripeErrors are raised immediately.

        Args:
            fn: Callable (stripe resource method).
            **kwargs: Passed through to *fn*.

        Returns:
            The Stripe object returned by *fn*.

        Raises:
            stripe.error.StripeError: On non-retryable or exhausted errors.
        """
        last_exc: Optional[Exception] = None

        for attempt in range(1, self._MAX_RETRIES + 1):
            try:
                return await fn(**kwargs)
            except stripe.error.RateLimitError as exc:
                last_exc = exc
                if attempt < self._MAX_RETRIES:
                    delay = self._BACKOFF_BASE ** attempt
                    time.sleep(delay)  # stripe SDK is synchronous internally
            except stripe.error.APIConnectionError as exc:
                last_exc = exc
                if attempt < self._MAX_RETRIES:
                    delay = self._BACKOFF_BASE ** attempt
                    time.sleep(delay)
            except stripe.error.StripeError:
                raise  # non-retryable
        raise last_exc  # type: ignore[misc]

    # ------------------------------------------------------------------
    # Payment Intents
    # ------------------------------------------------------------------

    async def create_payment_intent(
        self,
        amount: int,
        currency: str = "usd",
        metadata: Optional[dict] = None,
        description: Optional[str] = None,
        automatic_payment_methods: bool = True,
    ) -> dict:
        """
        Create a PaymentIntent.

        Args:
            amount:                    Amount in smallest currency unit (e.g. cents).
            currency:                  Three-letter ISO currency code.
            metadata:                  Arbitrary key-value metadata.
            description:               Description for the intent.
            automatic_payment_methods: Enable automatic payment methods.

        Returns:
            Serialised PaymentIntent dict.
        """
        params: dict[str, Any] = {
            "amount": amount,
            "currency": currency,
            "idempotency_key": self._idempotency_key("pi"),
        }
        if metadata:
            params["metadata"] = metadata
        if description:
            params["description"] = description
        if automatic_payment_methods:
            params["automatic_payment_methods"] = {"enabled": True}

        intent = await self._with_retry(
            stripe.PaymentIntent.create, **params
        )
        return intent.to_dict()

    async def confirm_payment(
        self,
        intent_id: str,
        payment_method: Optional[str] = None,
        return_url: Optional[str] = None,
    ) -> dict:
        """
        Confirm a PaymentIntent.

        Args:
            intent_id:      ID of the PaymentIntent to confirm.
            payment_method: ID of the PaymentMethod to use.
            return_url:     URL to redirect after confirmation.

        Returns:
            Serialised PaymentIntent dict.
        """
        params: dict[str, Any] = {
            "idempotency_key": self._idempotency_key("cf"),
        }
        if payment_method:
            params["payment_method"] = payment_method
        if return_url:
            params["return_url"] = return_url

        intent = await self._with_retry(
            stripe.PaymentIntent.confirm, intent_id, **params
        )
        return intent.to_dict()

    # ------------------------------------------------------------------
    # Customers
    # ------------------------------------------------------------------

    async def create_customer(
        self,
        email: str,
        name: str,
        metadata: Optional[dict] = None,
        phone: Optional[str] = None,
    ) -> dict:
        """
        Create a Stripe Customer.

        Args:
            email:    Customer email.
            name:     Customer full name.
            metadata: Arbitrary key-value metadata.
            phone:    Customer phone number.

        Returns:
            Serialised Customer dict.
        """
        params: dict[str, Any] = {
            "email": email,
            "name": name,
            "idempotency_key": self._idempotency_key("cu"),
        }
        if metadata:
            params["metadata"] = metadata
        if phone:
            params["phone"] = phone

        customer = await self._with_retry(stripe.Customer.create, **params)
        return customer.to_dict()

    async def get_customer(self, customer_id: str) -> dict:
        """
        Retrieve a Customer by ID.

        Args:
            customer_id: Stripe Customer ID (cus_…).

        Returns:
            Serialised Customer dict.
        """
        customer = await self._with_retry(
            stripe.Customer.retrieve, customer_id
        )
        return customer.to_dict()

    # ------------------------------------------------------------------
    # Subscriptions
    # ------------------------------------------------------------------

    async def create_subscription(
        self,
        customer_id: str,
        price_id: str,
        metadata: Optional[dict] = None,
        trial_period_days: Optional[int] = None,
        payment_behavior: str = "default_incomplete",
    ) -> dict:
        """
        Create a Subscription for a Customer.

        Args:
            customer_id:       Stripe Customer ID.
            price_id:          Stripe Price ID (price_…).
            metadata:          Arbitrary key-value metadata.
            trial_period_days: Number of trial days before billing.
            payment_behavior:  One of "default_incomplete", "default_latest", etc.

        Returns:
            Serialised Subscription dict.
        """
        params: dict[str, Any] = {
            "customer": customer_id,
            "items": [{"price": price_id}],
            "payment_behavior": payment_behavior,
            "expand": ["latest_invoice.payment_intent"],
            "idempotency_key": self._idempotency_key("sub"),
        }
        if metadata:
            params["metadata"] = metadata
        if trial_period_days is not None:
            params["trial_period_days"] = trial_period_days

        subscription = await self._with_retry(stripe.Subscription.create, **params)
        return subscription.to_dict()

    async def cancel_subscription(
        self,
        subscription_id: str,
        prorate: bool = True,
        invoice_now: bool = True,
    ) -> dict:
        """
        Cancel a Subscription.

        Args:
            subscription_id: Stripe Subscription ID (sub_…).
            prorate:         Whether to prorate unused time.
            invoice_now:     Whether to generate a final invoice.

        Returns:
            Serialised Subscription dict.
        """
        subscription = await self._with_retry(
            stripe.Subscription.delete,
            subscription_id,
            prorate=prorate,
            invoice_now=invoice_now,
            idempotency_key=self._idempotency_key("cancel"),
        )
        return subscription.to_dict()

    # ------------------------------------------------------------------
    # Webhooks
    # ------------------------------------------------------------------

    def verify_webhook_signature(
        self,
        payload: bytes,
        signature: str,
        secret: Optional[str] = None,
        tolerance: int = 300,
    ) -> dict:
        """
        Verify and parse a Stripe webhook signature.

        This uses the official stripe.Webhook.construct_event helper
        which validates the signature header and decodes the event.

        Args:
            payload:   Raw request body bytes.
            signature: Value of the Stripe-Signature header.
            secret:    Webhook signing secret (falls back to STRIPE_WEBHOOK_SECRET).
            tolerance: Max age of the event in seconds.

        Returns:
            Parsed Stripe Event dict.

        Raises:
            stripe.error.SignatureVerificationError: If the signature is invalid.
            ValueError: If no secret is available.
        """
        secret = secret or self._webhook_secret
        if not secret:
            raise ValueError(
                "Webhook secret is required. Set STRIPE_WEBHOOK_SECRET or pass secret=."
            )

        event = stripe.Webhook.construct_event(
            payload=payload,
            sig_header=signature,
            secret=secret,
            tolerance=tolerance,
        )
        return event.to_dict()
