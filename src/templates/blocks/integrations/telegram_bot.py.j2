"""
Telegram Bot Integration Block for Zenic-Agents
================================================
Production-ready async Telegram Bot service with rate limiting,
HMAC verification, and support for messages, documents, and webhooks.

Configuration (environment variables or constructor args):
  TELEGRAM_BOT_TOKEN - Bot token from @BotFather
"""

import asyncio
import os
import time
from pathlib import Path
from typing import Any, Optional

import aiohttp


class TelegramService:
    """Async Telegram Bot client with rate-limit awareness."""

    # Telegram rate limits (per chat / per bot)
    _MSG_PER_CHAT_PER_SEC: float = 1.0       # 1 msg/sec per chat
    _MSG_PER_SEC_GLOBAL: float = 30.0        # 30 msg/sec globally
    _MAX_RETRIES: int = 5
    _BACKOFF_BASE: float = 2.0

    def __init__(self, token: Optional[str] = None) -> None:
        """
        Initialise the Telegram service.

        Args:
            token: Bot token. Falls back to TELEGRAM_BOT_TOKEN env var.
        """
        self.token: str = token or os.environ["TELEGRAM_BOT_TOKEN"]
        self._base_url: str = f"https://api.telegram.org/bot{self.token}"
        self._session: Optional[aiohttp.ClientSession] = None

        # Simple sliding-window rate limiter state
        self._last_send_time: float = 0.0
        self._global_send_times: list[float] = []
        self._chat_locks: dict[str, asyncio.Lock] = {}
        self._lock = asyncio.Lock()  # guards _chat_locks / _global_send_times

    # ------------------------------------------------------------------
    # Session lifecycle
    # ------------------------------------------------------------------

    async def _get_session(self) -> aiohttp.ClientSession:
        """Lazily create (or return) the shared aiohttp session."""
        if self._session is None or self._session.closed:
            timeout = aiohttp.ClientTimeout(total=60)
            self._session = aiohttp.ClientSession(timeout=timeout)
        return self._session

    async def close(self) -> None:
        """Close the underlying HTTP session. Call on shutdown."""
        if self._session and not self._session.closed:
            await self._session.close()
            self._session = None

    # ------------------------------------------------------------------
    # Rate limiting
    # ------------------------------------------------------------------

    async def _acquire_rate(self, chat_id: str) -> None:
        """
        Block until it is safe to send a message to *chat_id* respecting
        both per-chat and global rate limits.
        """
        # Ensure every chat has its own lock
        async with self._lock:
            if chat_id not in self._chat_locks:
                self._chat_locks[chat_id] = asyncio.Lock()

        chat_lock = self._chat_locks[chat_id]
        await chat_lock.acquire()

        try:
            now = time.monotonic()

            # --- Per-chat limit (1 msg / sec) ---
            min_interval = 1.0 / self._MSG_PER_CHAT_PER_SEC
            elapsed = now - self._last_send_time
            if elapsed < min_interval:
                await asyncio.sleep(min_interval - elapsed)

            # --- Global limit (30 msg / sec) ---
            async with self._lock:
                now = time.monotonic()
                # Prune timestamps older than 1 second
                self._global_send_times = [
                    t for t in self._global_send_times if now - t < 1.0
                ]
                if len(self._global_send_times) >= self._MSG_PER_SEC_GLOBAL:
                    oldest = self._global_send_times[0]
                    wait = 1.0 - (now - oldest)
                    if wait > 0:
                        await asyncio.sleep(wait)
                    now = time.monotonic()

                self._global_send_times.append(now)
                self._last_send_time = now
        finally:
            chat_lock.release()

    # ------------------------------------------------------------------
    # Low-level API call
    # ------------------------------------------------------------------

    async def _call(
        self,
        method: str,
        payload: Optional[dict] = None,
        data: Optional[aiohttp.FormData] = None,
    ) -> dict:
        """
        Execute a Telegram Bot API call with retry + exponential backoff.

        Args:
            method:  API method name (e.g. "sendMessage").
            payload: JSON body for the request.
            data:    FormData for multipart uploads.

        Returns:
            Parsed JSON response from Telegram.

        Raises:
            RuntimeError: After exhausting all retry attempts.
        """
        url = f"{self._base_url}/{method}"
        last_error: Optional[str] = None

        for attempt in range(1, self._MAX_RETRIES + 1):
            session = await self._get_session()
            try:
                if data is not None:
                    async with session.post(url, data=data) as resp:
                        body = await resp.json()
                else:
                    async with session.post(url, json=payload or {}) as resp:
                        body = await resp.json()

                if body.get("ok"):
                    return body

                error_code = body.get("error_code", 0)
                description = body.get("description", "Unknown error")

                # 429 — Too Many Requests: honour Retry-After header
                if error_code == 429:
                    retry_after = body.get("parameters", {}).get("retry_after", 5)
                    await asyncio.sleep(retry_after)
                    continue

                # Non-retryable API error
                raise RuntimeError(
                    f"Telegram API error {error_code}: {description}"
                )

            except (aiohttp.ClientError, asyncio.TimeoutError) as exc:
                last_error = str(exc)
                if attempt < self._MAX_RETRIES:
                    delay = self._BACKOFF_BASE ** attempt
                    await asyncio.sleep(delay)

        raise RuntimeError(
            f"Telegram API call '{method}' failed after {self._MAX_RETRIES} "
            f"attempts: {last_error}"
        )

    # ------------------------------------------------------------------
    # Public API
    # ------------------------------------------------------------------

    async def send_message(
        self,
        chat_id: str,
        text: str,
        parse_mode: str = "HTML",
        disable_notification: bool = False,
        reply_to_message_id: Optional[int] = None,
    ) -> dict:
        """
        Send a text message to a chat.

        Args:
            chat_id:               Target chat ID.
            text:                  Message text (max 4096 chars).
            parse_mode:            "HTML" or "MarkdownV2".
            disable_notification:  Send silently.
            reply_to_message_id:   ID of message to reply to.

        Returns:
            Telegram API response dict with the sent Message object.
        """
        await self._acquire_rate(chat_id)

        payload: dict[str, Any] = {
            "chat_id": chat_id,
            "text": text,
            "parse_mode": parse_mode,
            "disable_notification": disable_notification,
        }
        if reply_to_message_id is not None:
            payload["reply_to_message_id"] = reply_to_message_id

        return await self._call("sendMessage", payload=payload)

    async def send_document(
        self,
        chat_id: str,
        file_path: str,
        caption: str = "",
        parse_mode: str = "HTML",
        disable_notification: bool = False,
    ) -> dict:
        """
        Send a document (file) to a chat.

        Args:
            chat_id:              Target chat ID.
            file_path:            Local path to the file to upload.
            caption:              Optional caption (0-1024 chars).
            parse_mode:           Parse mode for the caption.
            disable_notification: Send silently.

        Returns:
            Telegram API response dict with the sent Message object.
        """
        await self._acquire_rate(chat_id)

        path = Path(file_path)
        if not path.is_file():
            raise FileNotFoundError(f"File not found: {file_path}")

        form = aiohttp.FormData()
        form.add_field("chat_id", chat_id)
        form.add_field(
            "document",
            path.open("rb"),
            filename=path.name,
            content_type="application/octet-stream",
        )
        if caption:
            form.add_field("caption", caption)
            form.add_field("parse_mode", parse_mode)
        if disable_notification:
            form.add_field("disable_notification", "true")

        return await self._call("sendDocument", data=form)

    async def get_updates(
        self,
        offset: int = 0,
        limit: int = 100,
        timeout: int = 30,
        allowed_updates: Optional[list[str]] = None,
    ) -> list:
        """
        Fetch pending updates (long-polling).

        Args:
            offset:           Identifier of the first update to return.
            limit:            Max number of updates (1-100).
            timeout:          Long-poll timeout in seconds.
            allowed_updates:  List of update types to receive.

        Returns:
            List of Update objects.
        """
        payload: dict[str, Any] = {
            "offset": offset,
            "limit": limit,
            "timeout": timeout,
        }
        if allowed_updates is not None:
            payload["allowed_updates"] = allowed_updates

        result = await self._call("getUpdates", payload=payload)
        return result.get("result", [])

    async def set_webhook(
        self,
        url: str,
        certificate: Optional[str] = None,
        max_connections: int = 40,
        allowed_updates: Optional[list[str]] = None,
        secret_token: Optional[str] = None,
    ) -> dict:
        """
        Register a webhook URL for receiving updates.

        Args:
            url:              HTTPS URL to send updates to.
            certificate:      Path to self-signed certificate PEM (optional).
            max_connections:  Max simultaneous connections (1-100).
            allowed_updates:  List of update types to receive.
            secret_token:     Secret for X-Telegram-Bot-Api-Secret-Token.

        Returns:
            Telegram API response dict.
        """
        payload: dict[str, Any] = {
            "url": url,
            "max_connections": max_connections,
        }
        if allowed_updates is not None:
            payload["allowed_updates"] = allowed_updates
        if secret_token is not None:
            payload["secret_token"] = secret_token

        if certificate:
            path = Path(certificate)
            if not path.is_file():
                raise FileNotFoundError(f"Certificate not found: {certificate}")
            form = aiohttp.FormData()
            for key, val in payload.items():
                form.add_field(key, str(val))
            form.add_field(
                "certificate",
                path.open("rb"),
                filename=path.name,
                content_type="application/x-pem-file",
            )
            return await self._call("setWebhook", data=form)

        return await self._call("setWebhook", payload=payload)

    async def delete_webhook(self, drop_pending_updates: bool = False) -> dict:
        """
        Remove the current webhook.

        Args:
            drop_pending_updates: Discard all pending updates.

        Returns:
            Telegram API response dict.
        """
        return await self._call(
            "deleteWebhook",
            payload={"drop_pending_updates": drop_pending_updates},
        )
