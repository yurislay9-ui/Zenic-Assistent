        }

    async def send_message(self, phone: str, message: str,
                           preview_url: bool = False) -> Dict[str, Any]:
        """
        Send a text message via WhatsApp.

        Args:
            phone: Recipient phone number (international format, e.g. "5491112345678")
            message: Text message content
            preview_url: Whether to show URL previews

        Returns:
            Dict with message_id and status
        """
        if not AIOHTTP_AVAILABLE:
            return {"status": "skipped", "reason": "aiohttp not installed"}

        if not self._phone_id or not self._token:
            return {"status": "skipped", "reason": "WhatsApp credentials not configured"}

        payload = {
            "messaging_product": "whatsapp",
            "recipient_type": "individual",
            "to": phone,
            "type": "text",
            "text": {
                "body": message,
                "preview_url": preview_url,
            },
        }

        try:
            async with aiohttp.ClientSession() as session:
                async with session.post(
                    self._base_url,
                    headers=self._headers,
                    json=payload,
                    timeout=aiohttp.ClientTimeout(total=30),
                ) as resp:
                    result = await resp.json()

                    if resp.status == 200 and "messages" in result:
                        msg_id = result["messages"][0].get("id", "unknown")
                        logger.info(f"WhatsApp: Message sent to {phone}, id={msg_id}")
                        return {"status": "sent", "message_id": msg_id}
                    else:
                        error = result.get("error", {}).get("message", str(result))
                        logger.error(f"WhatsApp: Send failed: {error}")
                        return {"status": "failed", "error": error}

        except Exception as e:
            logger.error(f"WhatsApp: Exception: {e}")
            return {"status": "failed", "error": str(e)}

